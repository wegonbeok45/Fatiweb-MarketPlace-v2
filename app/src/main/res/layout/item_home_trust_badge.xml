<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="170dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_trust_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_home_trust_icon">

        <ImageView
            android:id="@+id/ivHomeTrustIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            app:srcCompat="@drawable/ic_checkout_truck"
            app:tint="@color/ms_accent_gold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvHomeTrustTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_semibold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/ms_text_primary"
            android:textSize="13sp"
            tools:text="Free delivery" />

        <TextView
            android:id="@+id/tvHomeTrustBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_regular"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/home_ref_text_secondary"
            android:textSize="11sp"
            tools:text="Orders over 99 DT" />
    </LinearLayout>
</LinearLayout>
