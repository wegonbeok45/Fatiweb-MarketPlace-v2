<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminClientsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".AdminClientsActivity">

    <!-- ====== Top app bar ====== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminClientsAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/ms_top_bar_height"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20">

            <TextView
                android:id="@+id/adminClientsTitle"
                style="@style/Ms.Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/admin_title_clients"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/adminClientsBell"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/adminClientsBell"
                android:layout_width="@dimen/ms_min_touch"
                android:layout_height="@dimen/ms_min_touch"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/ms_section_notifications"
                android:focusable="true"
                android:padding="11dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_admin_nav_notifications"
                app:tint="@color/ms_text_primary" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Search bar -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/adminClientsSearchLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_20"
            android:layout_marginEnd="@dimen/space_20"
            android:layout_marginBottom="@dimen/space_12"
            android:hint="@string/admin_clients_search_hint"
            app:boxCornerRadiusBottomEnd="@dimen/ms_radius_md"
            app:boxCornerRadiusBottomStart="@dimen/ms_radius_md"
            app:boxCornerRadiusTopEnd="@dimen/ms_radius_md"
            app:boxCornerRadiusTopStart="@dimen/ms_radius_md"
            app:boxStrokeColor="@color/ms_border_default"
            app:boxBackgroundColor="@color/ms_surface_card"
            app:startIconDrawable="@drawable/ic_admin_nav_clients"
            app:startIconTint="@color/ms_text_tertiary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/adminClientsSearchInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/ms_text_primary"
                android:textColorHint="@color/ms_text_tertiary"
                android:textSize="14sp" />

        </com.google.android.material.textfield.TextInputLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ====== Content ====== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/adminClientsList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingTop="148dp"
            android:paddingBottom="96dp"
            tools:listitem="@layout/item_admin_client_row" />

        <!-- KPI banner — overlaid at top of list, shown only after data loads -->
        <LinearLayout
            android:id="@+id/adminClientsKpiRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_20"
            android:layout_marginTop="@dimen/space_8"
            android:layout_marginEnd="@dimen/space_20"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                style="@style/Ms.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <TextView
                        android:id="@+id/adminClientsTvTotal"
                        style="@style/Ms.Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="28sp"
                        tools:text="1 204" />

                    <TextView
                        style="@style/Ms.Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/admin_clients_total_label" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Ms.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <TextView
                        android:id="@+id/adminClientsTvNew"
                        style="@style/Ms.Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/ms_accent_gold"
                        android:textSize="28sp"
                        tools:text="47" />

                    <TextView
                        style="@style/Ms.Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/admin_clients_new_label" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Empty state -->
        <include
            android:id="@+id/adminClientsEmpty"
            layout="@layout/ms_component_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:visibility="gone" />

        <!-- Error state -->
        <include
            android:id="@+id/adminClientsError"
            layout="@layout/ms_component_error_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:visibility="gone" />

        <!-- Skeleton (initial load) -->
        <LinearLayout
            android:id="@+id/adminClientsLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:visibility="visible">

            <include layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
            <include layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12" />
            <include layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12" />
            <include layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12" />
            <include layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12" />
        </LinearLayout>

        <!-- Load-more spinner -->
        <ProgressBar
            android:id="@+id/adminClientsLoadMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="@dimen/space_20"
            android:visibility="gone" />

    </FrameLayout>

    <!-- ====== Bottom nav ====== -->
    <include
        layout="@layout/include_admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
