<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".ProductDetailsScreen">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/app_top_bar_height"
        android:background="@color/colorSurface"
        android:paddingStart="@dimen/app_top_bar_horizontal_padding"
        android:paddingEnd="@dimen/app_top_bar_horizontal_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            app:cardBackgroundColor="@color/home_surface_raised"
            app:cardCornerRadius="@dimen/surface_button_corner_radius"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/details_back"
                android:padding="@dimen/surface_button_inner_padding"
                app:srcCompat="@drawable/back"
                app:tint="@color/home_text_primary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTopTitle"
            style="@style/AppTopBar.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/details_top_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/actionCluster"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnFavoriteDetails"
                android:layout_width="@dimen/surface_button_size"
                android:layout_height="@dimen/surface_button_size"
                app:cardBackgroundColor="@color/home_surface_raised"
                app:cardCornerRadius="@dimen/surface_button_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/ivFavoriteLottie"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:clickable="false"
                        android:contentDescription="@string/auto_favorite_0116"
                        android:focusable="false"
                        android:padding="4dp"
                        android:scaleType="centerInside"
                        app:lottie_autoPlay="false"
                        app:lottie_loop="false"
                        app:lottie_rawRes="@raw/anim_heart" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ivShare"
                android:layout_width="@dimen/surface_button_size"
                android:layout_height="@dimen/surface_button_size"
                android:layout_marginStart="@dimen/surface_button_spacing"
                app:cardBackgroundColor="@color/home_surface_raised"
                app:cardCornerRadius="@dimen/surface_button_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/details_share"
                    android:padding="@dimen/surface_button_inner_padding"
                    app:srcCompat="@android:drawable/ic_menu_share"
                    app:tint="@color/home_text_primary" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollDetails"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar">

        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/details_horizontal_padding"
            android:paddingTop="@dimen/space_8"
            android:paddingEnd="@dimen/details_horizontal_padding"
            android:paddingBottom="@dimen/space_24">

            <FrameLayout
                android:id="@+id/layoutImageHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="@dimen/details_image_height">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProductImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/home_surface_raised"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorOutline"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:id="@+id/ivProductImage"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/details_image_height"
                        android:adjustViewBounds="false"
                        android:contentDescription="@string/details_image_cd"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/product1example" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTag1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_meta_pill"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:paddingStart="@dimen/space_10"
                    android:paddingTop="@dimen/space_4"
                    android:paddingEnd="@dimen/space_10"
                    android:paddingBottom="@dimen/space_4"
                    android:text="@string/auto_handmade_bc96"
                    android:textColor="@color/home_meta_text"
                    android:textSize="@dimen/text_size_overline"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTag2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_8"
                    android:background="@drawable/bg_details_chip_success"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:paddingStart="@dimen/space_10"
                    android:paddingTop="@dimen/space_4"
                    android:paddingEnd="@dimen/space_10"
                    android:paddingBottom="@dimen/space_4"
                    android:textColor="@color/colorAccentDeep"
                    android:textSize="@dimen/text_size_overline"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="IN STOCK"
                    tools:visibility="visible" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/details_image_cd"
                    app:srcCompat="@drawable/ic_home_star"
                    app:tint="@color/details_star" />

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_4"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/text_size_caption"
                    tools:text="4.8" />

                <TextView
                    android:id="@+id/tvReviews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_8"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_caption"
                    tools:text="(128 reviews)" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_14"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold"
                tools:text="Traditional Tunisian Balgha" />

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_6"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                tools:text="45.500 TND" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProductTrust"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                app:cardBackgroundColor="@color/colorSurfaceVariant"
                app:cardCornerRadius="@dimen/corner_radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <TextView
                        android:id="@+id/tvEditorialCaption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_meta_pill"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        android:paddingStart="@dimen/space_10"
                        android:paddingTop="@dimen/space_4"
                        android:paddingEnd="@dimen/space_10"
                        android:paddingBottom="@dimen/space_4"
                        android:text="@string/details_editorial_caption"
                        android:textColor="@color/home_meta_text"
                        android:textSize="@dimen/text_size_overline" />

                    <TextView
                        android:id="@+id/tvStockHelper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_caption"
                        tools:text="Ready to ship within 24 hours." />

                    <TextView
                        android:id="@+id/tvEditorialIntro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_6"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/details_editorial_intro"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="@dimen/text_size_caption" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvDescriptionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="@string/details_description_title"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_10"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:lineSpacingExtra="5dp"
                android:textColor="@color/home_text_secondary"
                android:textSize="@dimen/text_size_caption"
                tools:text="These traditional shoes are handcrafted using the finest leather, ensuring comfort and durability while maintaining an authentic Tunisian style." />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHighlights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                app:cardBackgroundColor="@color/colorSurface"
                app:cardCornerRadius="@dimen/corner_radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <TextView
                        android:id="@+id/tvBullet1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_caption"
                        tools:text="- Handmade by Tunisian artisans" />

                    <TextView
                        android:id="@+id/tvBullet2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_caption"
                        tools:text="- Premium natural materials" />

                    <TextView
                        android:id="@+id/tvBullet3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_caption"
                        tools:text="- Designed for everyday comfort" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvQuantityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="@string/details_quantity_label"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutQuantitySelector"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/space_12"
                android:background="@drawable/bg_home_meta_pill"
                android:backgroundTint="@color/colorSurfaceVariant"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_6"
                android:paddingEnd="@dimen/space_6">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMinus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="1dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/common_minus"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="52dp"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:gravity="center"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/text_size_body"
                    android:textStyle="bold"
                    tools:text="1" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnPlus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/common_plus"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/loadingIndicator"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutBottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/colorBorderLight"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_20"
            android:paddingTop="@dimen/space_16"
            android:paddingEnd="@dimen/space_20"
            android:paddingBottom="@dimen/space_16">

            <LinearLayout
                android:id="@+id/layoutTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:text="@string/details_total_label"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_overline" />

                <TextView
                    android:id="@+id/tvTotalValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold"
                    tools:text="45.500 TND" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="@dimen/space_14"
                android:layout_weight="1"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="@string/details_add_to_cart"
                android:textAllCaps="false"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold"
                app:cornerRadius="@dimen/corner_radius_large"
                app:elevation="0dp"
                app:icon="@drawable/ic_home_add_cart"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
