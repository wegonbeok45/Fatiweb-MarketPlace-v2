<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".ProductDetailsScreen">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:paddingStart="@dimen/space_20"
        android:paddingTop="@dimen/space_16"
        android:paddingEnd="@dimen/space_20"
        android:paddingBottom="@dimen/space_16"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ivBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="@color/home_surface_raised"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/auto_back_0557"
                android:padding="@dimen/space_12"
                app:srcCompat="@drawable/back"
                app:tint="@color/home_text_primary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTopTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:text="@string/auto_details_3ec3"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_subtitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/actionCluster"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnFavoriteDetails"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardBackgroundColor="@color/home_surface_raised"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/auto_favorite_0116"
                        android:padding="@dimen/space_12"
                        app:srcCompat="@drawable/ic_home_heart"
                        app:tint="@color/home_text_primary" />

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/ivFavoriteLottie"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        app:lottie_autoPlay="false"
                        app:lottie_loop="false"
                        app:lottie_rawRes="@raw/anim_heart" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ivShare"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/space_10"
                app:cardBackgroundColor="@color/home_surface_raised"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/auto_share_5a95"
                    android:padding="@dimen/space_12"
                    app:srcCompat="@android:drawable/ic_menu_share"
                    app:tint="@color/home_text_primary" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollDetails"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar">

        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingTop="@dimen/space_16"
            android:paddingEnd="@dimen/space_20"
            android:paddingBottom="@dimen/space_40">

            <FrameLayout
                android:id="@+id/layoutImageHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="360dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProductImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/home_surface_raised"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorOutline"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:id="@+id/ivProductImage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:contentDescription="@string/auto_product_image_3c38"
                        android:maxHeight="360dp"
                        android:padding="@dimen/space_40"
                        android:scaleType="fitCenter"
                        tools:src="@drawable/product1example" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTag1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_meta_pill"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:paddingStart="@dimen/space_12"
                    android:paddingTop="@dimen/space_6"
                    android:paddingEnd="@dimen/space_12"
                    android:paddingBottom="@dimen/space_6"
                    android:text="@string/auto_handmade_bc96"
                    android:textColor="@color/home_meta_text"
                    android:textSize="@dimen/text_size_overline"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTag2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_8"
                    android:background="@drawable/bg_details_chip_success"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:paddingStart="@dimen/space_12"
                    android:paddingTop="@dimen/space_6"
                    android:paddingEnd="@dimen/space_12"
                    android:paddingBottom="@dimen/space_6"
                    android:textColor="@color/colorAccentDeep"
                    android:textSize="@dimen/text_size_overline"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="IN STOCK"
                    tools:visibility="visible" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    app:srcCompat="@drawable/ic_home_star"
                    app:tint="@color/details_star"
                    android:contentDescription="@string/cd_product_image" />

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_4"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/text_size_caption"
                    tools:text="4.8" />

                <TextView
                    android:id="@+id/tvReviews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_8"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_caption"
                    tools:text="(128 reviews)" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_title_large"
                android:textStyle="bold"
                tools:text="Traditional Tunisian Balgha" />

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold"
                tools:text="45.500 TND" />

            <TextView
                android:id="@+id/tvDescriptionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_32"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="@string/auto_about_product_39b2"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/home_text_secondary"
                android:textSize="@dimen/text_size_body"
                tools:text="These traditional shoes are handcrafted using the finest leather, ensuring comfort and durability while maintaining an authentic Tunisian style." />

            <TextView
                android:id="@+id/tvStockHelper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:textColor="@color/home_text_secondary"
                android:textSize="@dimen/text_size_caption"
                tools:text="Ready to ship within 24 hours." />

            <TextView
                android:id="@+id/tvBullet1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_caption"
                tools:text="• Handmade by Tunisian artisans" />

            <TextView
                android:id="@+id/tvBullet2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_caption"
                tools:text="• Premium natural materials" />

            <TextView
                android:id="@+id/tvBullet3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_caption"
                tools:text="• Designed for everyday comfort" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/space_32"
                android:background="@color/colorOutline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_32"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="@string/auto_quantity_694e"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutQuantitySelector"
                android:layout_width="wrap_content"
                android:layout_height="64dp"
                android:layout_marginTop="@dimen/space_16"
                android:background="@drawable/bg_home_meta_pill"
                android:backgroundTint="#F5F5F5"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_8"
                android:paddingEnd="@dimen/space_8">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMinus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/common_minus"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="56dp"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:gravity="center"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold"
                    tools:text="1" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnPlus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/common_plus"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/text_size_subtitle"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutBottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="0dp"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_24"
            android:paddingTop="@dimen/space_20"
            android:paddingEnd="@dimen/space_24"
            android:paddingBottom="@dimen/space_24">

            <LinearLayout
                android:id="@+id/layoutTotal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans_medium"
                    android:text="@string/auto_total_price_f354"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_overline" />

                <TextView
                    android:id="@+id/tvTotalValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold"
                    tools:text="45.500 TND" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddToCart"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_16"
                android:layout_height="60dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="@string/auto_add_to_cart_638f"
                android:textAllCaps="false"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold"
                app:cornerRadius="30dp"
                app:elevation="4dp"
                app:icon="@drawable/ic_home_add_cart"
                app:iconGravity="textStart"
                app:iconPadding="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
