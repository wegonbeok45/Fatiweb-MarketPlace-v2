<?xml version="1.0" encoding="utf-8"?>
<!-- Bot typing indicator bubble â€” animated three dots -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp">

    <!-- Bot icon -->
    <androidx.cardview.widget.CardView
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_gravity="bottom"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="2dp"
        app:cardBackgroundColor="@color/colorPrimary"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/chat_title"
            android:scaleType="centerCrop"
            android:src="@drawable/ai_pfp" />
    </androidx.cardview.widget.CardView>

    <!-- Typing bubble -->
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="18dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/colorOutline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp">

            <!-- Dot 1 -->
            <View
                android:id="@+id/chatDot1"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_chat_dot"
                android:alpha="0.3" />

            <!-- Dot 2 -->
            <View
                android:id="@+id/chatDot2"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_chat_dot"
                android:alpha="0.6" />

            <!-- Dot 3 -->
            <View
                android:id="@+id/chatDot3"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_chat_dot"
                android:alpha="1.0" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>

