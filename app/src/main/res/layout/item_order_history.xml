<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_12"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/ms_surface_card"
    app:cardCornerRadius="@dimen/ms_radius_lg"
    app:cardElevation="0dp"
    app:strokeColor="@color/ms_border_subtle"
    app:strokeWidth="@dimen/stroke_width_default">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_16"
        android:paddingTop="@dimen/space_14"
        android:paddingEnd="@dimen/space_16"
        android:paddingBottom="@dimen/space_14">

        <!-- Header: order id (left) + status pill (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_semibold"
                    android:letterSpacing="0.02"
                    android:textColor="@color/ms_text_primary"
                    android:textSize="@dimen/text_size_body"
                    tools:ignore="MissingPrefix" />

                <TextView
                    android:id="@+id/tvOrderDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/manrope_regular"
                    android:textColor="@color/ms_text_secondary"
                    android:textSize="@dimen/text_size_caption" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_semibold"
                android:paddingStart="@dimen/space_10"
                android:paddingTop="@dimen/space_4"
                android:paddingEnd="@dimen/space_10"
                android:paddingBottom="@dimen/space_4"
                android:textSize="@dimen/text_size_overline"
                tools:background="@drawable/ms_bg_status_info"
                tools:text="En attente" />
        </LinearLayout>

        <!-- Thumbnails strip -->
        <HorizontalScrollView
            android:id="@+id/hsvOrderThumbnails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layoutOrderThumbnails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <!-- Items summary -->
        <TextView
            android:id="@+id/tvOrderItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_regular"
            android:maxLines="2"
            android:textColor="@color/ms_text_secondary"
            android:textSize="@dimen/text_size_caption" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/space_12"
            android:background="@color/ms_border_subtle" />

        <!-- Footer: total (left) + primary action (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_regular"
                    android:text="@string/orders_history_total_label"
                    android:textColor="@color/ms_text_tertiary"
                    android:textSize="@dimen/text_size_overline" />

                <TextView
                    android:id="@+id/tvOrderTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/manrope_semibold"
                    android:textColor="@color/ms_text_primary"
                    android:textSize="@dimen/text_size_subtitle" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOrderPrimary"
                style="@style/AppButton.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="40dp"
                android:paddingStart="@dimen/space_20"
                android:paddingEnd="@dimen/space_20"
                android:textAllCaps="false"
                android:textSize="@dimen/text_size_caption"
                app:cornerRadius="@dimen/corner_radius_medium" />
        </LinearLayout>
    </LinearLayout>

    <!-- Hidden secondary button kept so the adapter can still bind it without crashing
         (we removed the visible row to declutter — single primary action is cleaner). -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOrderSecondary"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />
</com.google.android.material.card.MaterialCardView>
