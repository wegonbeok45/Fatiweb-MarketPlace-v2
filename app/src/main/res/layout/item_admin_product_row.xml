<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="104dp"
    android:paddingStart="14dp"
    android:paddingTop="14dp"
    android:paddingEnd="14dp"
    android:paddingBottom="14dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/adminProductThumb"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="@color/ms_surface_sunken"
        app:cardCornerRadius="@dimen/corner_radius_medium"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/adminProductImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/cd_product_image"
            android:scaleType="centerCrop" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/adminProductActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/adminProductBtnEdit"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            android:clickable="true"
            android:contentDescription="@string/cd_edit"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/ms_surface_sunken"
            app:cardCornerRadius="@dimen/surface_button_corner_radius"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_edit"
                android:padding="10dp"
                app:srcCompat="@drawable/ic_admin_edit"
                app:tint="@color/ms_text_primary" />
        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/adminProductOverflow"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="10dp"
            android:layout_gravity="center_vertical"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/ms_action_filter"
            android:padding="4dp"
            app:srcCompat="@drawable/ic_ms_more_vert"
            app:tint="@color/ms_text_secondary" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/adminProductBtnDelete"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            android:layout_marginStart="10dp"
            android:clickable="true"
            android:contentDescription="@string/cd_delete"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/ms_surface_card"
            app:cardCornerRadius="@dimen/surface_button_corner_radius"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_delete"
                android:padding="10dp"
                app:srcCompat="@drawable/ic_panier_delete"
                app:tint="?attr/colorError" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminProductContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/adminProductActions"
        app:layout_constraintStart_toEndOf="@id/adminProductThumb"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/adminProductTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/ms_text_primary"
            android:fontFamily="@font/manrope_semibold"
            android:textSize="@dimen/text_size_caption"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/adminProductStateChip"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:layout_marginTop="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/adminProductStateText"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="@android:color/white"
                android:fontFamily="@font/manrope_semibold"
                android:textSize="@dimen/text_size_overline" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/adminProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/ms_text_primary"
                android:fontFamily="@font/manrope_semibold"
                android:textSize="@dimen/text_size_caption" />

            <TextView
                android:id="@+id/adminProductPriceOriginal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:ellipsize="end"
                android:fontFamily="@font/manrope_semibold"
                android:maxLines="1"
                android:textColor="@color/discount_strike_red"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/adminProductDiscountBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_discount_badge"
                android:fontFamily="@font/manrope_bold"
                android:paddingStart="6dp"
                android:paddingTop="2dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/adminProductSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/ms_text_secondary"
            android:fontFamily="@font/manrope_regular"
            android:textSize="@dimen/text_size_overline" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

