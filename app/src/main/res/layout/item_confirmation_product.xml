<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="top"
    android:layout_marginBottom="12dp"
    android:orientation="horizontal">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="56dp"
        android:layout_height="72dp"
        android:layout_marginEnd="14dp"
        app:cardBackgroundColor="@color/colorSurfaceVariant"
        app:cardCornerRadius="@dimen/corner_radius_medium"
        app:cardElevation="0dp"
        app:strokeColor="@color/colorBorderLight"
        app:strokeWidth="1dp">
        <ImageView
            android:id="@+id/ivConfirmItemImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/cd_product_image"
            android:scaleType="centerCrop"
            android:src="@drawable/product1example" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvConfirmItemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="@string/auto_produit_e30e"
            android:textSize="@dimen/text_size_caption"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:fontFamily="@font/manrope" />
        <TextView
            android:id="@+id/tvConfirmItemDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/auto_taille_m_couleur_standard_d6cb"
            android:textSize="@dimen/text_size_overline"
            android:textColor="@color/profile_text_muted"
            android:fontFamily="@font/manrope" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvConfirmItemPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:gravity="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/auto_000_dt_6f0d"
        android:textSize="@dimen/text_size_overline"
        android:textColor="?attr/colorOnSurface"
        android:textStyle="bold"
        android:fontFamily="@font/manrope" />
</LinearLayout>

