<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminVendorsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".AdminVendorsActivity">

    <!-- ====== Top app bar ====== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminVendorsAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <!-- Title bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/ms_top_bar_height"
            android:paddingStart="@dimen/space_4"
            android:paddingEnd="@dimen/space_20">

            <ImageView
                android:id="@+id/adminVendorsBack"
                android:layout_width="@dimen/ms_min_touch"
                android:layout_height="@dimen/ms_min_touch"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/ms_action_back"
                android:focusable="true"
                android:padding="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_back"
                app:tint="@color/ms_text_primary" />

            <TextView
                android:id="@+id/adminVendorsTitle"
                style="@style/Ms.Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:text="@string/admin_vendors_title"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/adminVendorsBack"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Filter chip row -->
        <HorizontalScrollView
            android:id="@+id/adminVendorsFilterScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:paddingBottom="@dimen/space_12"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/adminVendorsChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminVendorsChipAll"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/admin_vendors_filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminVendorsChipPending"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_vendors_filter_pending" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminVendorsChipApproved"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_vendors_filter_approved" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminVendorsChipSuspended"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_vendors_filter_suspended" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminVendorsChipRejected"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_vendors_filter_rejected" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ====== Content ====== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/adminVendorsList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:paddingTop="@dimen/space_12"
            android:paddingBottom="96dp"
            tools:listitem="@layout/item_admin_vendor" />

        <include
            android:id="@+id/adminVendorsEmpty"
            layout="@layout/ms_component_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:visibility="gone" />

        <include
            android:id="@+id/adminVendorsError"
            layout="@layout/ms_component_error_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/adminVendorsLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:visibility="visible">

            <include
                layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include
                layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12" />

            <include
                layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12" />
        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
