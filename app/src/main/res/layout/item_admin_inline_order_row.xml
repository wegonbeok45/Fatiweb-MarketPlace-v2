<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/adminInlineOrderRow"
    android:layout_width="match_parent"
    android:layout_height="62dp"
    android:background="?selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="14dp"
    android:paddingEnd="14dp">

    <View
        android:id="@+id/adminCommRow1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/adminInlineOrderIcon"
        android:layout_width="34dp"
        android:layout_height="34dp"
        app:cardBackgroundColor="@color/profile_card_icon_bg"
        app:cardCornerRadius="999dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_order_status"
            app:srcCompat="@drawable/shoppingbag"
            app:tint="?attr/colorPrimary" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/adminInlineOrderId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/auto_fw0000_817a"
        android:textColor="@color/profile_text_primary"
        android:textSize="@dimen/text_size_caption"
        app:layout_constraintBottom_toTopOf="@id/adminInlineOrderName"
        app:layout_constraintEnd_toStartOf="@id/adminInlineOrderBadge"
        app:layout_constraintStart_toEndOf="@id/adminInlineOrderIcon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/adminInlineOrderName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/auto_commande_87ef"
        android:textColor="@color/profile_text_secondary"
        android:textSize="@dimen/text_size_overline"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/adminInlineOrderBadge"
        app:layout_constraintStart_toEndOf="@id/adminInlineOrderIcon"
        app:layout_constraintTop_toBottomOf="@id/adminInlineOrderId" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/adminInlineOrderBadge"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        app:cardBackgroundColor="@color/status_bg_warning"
        app:cardCornerRadius="999dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <TextView
            android:id="@+id/adminInlineOrderBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/admin_orders_pending_label"
            android:textColor="@color/status_text_warning"
            android:textSize="@dimen/text_size_overline" />
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
