<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutCheckoutRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/details_background">

    <LinearLayout
        android:id="@+id/layoutCheckoutTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_shell_top_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_16"
        android:paddingTop="@dimen/screen_padding_vertical"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingBottom="@dimen/screen_padding_vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivCheckoutBack"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            android:background="@drawable/bg_shell_action_chip"
            android:padding="@dimen/surface_button_inner_padding"
            android:src="@drawable/back"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_back" />

        <TextView
            android:id="@+id/tvCheckoutTitle"
            style="@style/AppText.Subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/auto_d233tails_de_la_commande_e15a"
            android:textColor="?attr/colorOnSurface" />

        <View
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size" />
    </LinearLayout>

    <View
        android:id="@+id/viewCheckoutTopDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/colorBorderLight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutCheckoutTopBar" />

    <LinearLayout
        android:id="@+id/layoutCheckoutSteps"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="@dimen/space_12"
        android:paddingBottom="@dimen/space_4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewCheckoutTopDivider">

        <FrameLayout
            android:id="@+id/btnStep1"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <View
                android:id="@+id/bgStep1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_checkout_step_active" />
            <TextView
                android:id="@+id/tvStep1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:gravity="center"
                android:text="@string/auto_1_c4ca"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_size_caption" />
        </FrameLayout>

        <View
            android:id="@+id/lineStep1to2"
            android:layout_width="24dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="@dimen/space_6"
            android:background="@color/colorBorderLight" />

        <FrameLayout
            android:id="@+id/btnStep2"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <View
                android:id="@+id/bgStep2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_checkout_step_inactive" />
            <TextView
                android:id="@+id/tvStep2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:gravity="center"
                android:text="@string/auto_2_c81e"
                android:textColor="@color/profile_text_muted"
                android:textSize="@dimen/text_size_caption" />
        </FrameLayout>

        <View
            android:id="@+id/lineStep2to3"
            android:layout_width="24dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="@dimen/space_6"
            android:background="@color/colorBorderLight" />

        <FrameLayout
            android:id="@+id/btnStep3"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">
            <View
                android:id="@+id/bgStep3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_checkout_step_inactive" />
            <TextView
                android:id="@+id/tvStep3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:gravity="center"
                android:text="@string/auto_3_eccb"
                android:textColor="@color/profile_text_muted"
                android:textSize="@dimen/text_size_caption" />
        </FrameLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollCheckoutContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/screen_section_gap_small"
        app:layout_constraintBottom_toTopOf="@id/layoutCheckoutBottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutCheckoutSteps">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/layoutStep1Content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:paddingTop="@dimen/space_16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/AppText.SectionLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/auto_adresse_de_livraison_46e1"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/tvCheckoutModifyAddress"
                        style="@style/AppText.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:text="@string/auto_modifier_898c"
                        android:textColor="?attr/colorPrimary" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCheckoutAddress"
                    style="@style/AppCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal"
                        android:padding="@dimen/space_16">

                        <com.google.android.material.card.MaterialCardView
                            style="@style/AppCard.IconContainer"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="@dimen/space_16">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="@dimen/space_10"
                                android:src="@drawable/ic_checkout_pin"  android:contentDescription="@string/cd_checkout_step" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvCheckoutAddressName"
                                style="@style/AppText.Subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_sophie_martin_f1e2" />

                            <TextView
                                android:id="@+id/tvCheckoutAddressLine1"
                                style="@style/AppText.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_4"
                                android:text="@string/auto_12_rue_de_la_4508" />

                            <TextView
                                android:id="@+id/tvCheckoutAddressLine2"
                                style="@style/AppText.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_75002_paris_france_6d7d" />

                            <TextView
                                android:id="@+id/tvCheckoutAddressPhone"
                                style="@style/AppText.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_33_1_23_45_3a9c" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCheckoutActionNeeded"
                    style="@style/AppCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:visibility="gone"
                    app:strokeColor="?attr/colorPrimary"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <TextView
                            android:id="@+id/tvCheckoutActionTitle"
                            style="@style/AppText.Subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            tools:text="Connectez-vous pour continuer" />

                        <TextView
                            android:id="@+id/tvCheckoutActionMessage"
                            style="@style/AppText.Body"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_8"
                            tools:text="Votre compte permet de suivre la commande et de sécuriser la livraison." />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheckoutAction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_16"
                            android:textAllCaps="false"
                            app:backgroundTint="?attr/colorPrimary"
                            app:cornerRadius="22dp"
                            tools:text="Se connecter" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    style="@style/AppText.SectionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    android:text="@string/auto_m201thode_de_livraison_9d30"
                    android:textColor="?attr/colorPrimary" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDeliveryStandard"
                    style="@style/AppCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    app:strokeColor="?attr/colorPrimary"
                    app:strokeWidth="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/space_16">

                        <com.google.android.material.card.MaterialCardView
                            style="@style/AppCard.IconContainer"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="@dimen/space_16"
                            app:cardBackgroundColor="@color/colorSecondary">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="@dimen/space_10"
                                android:src="@drawable/ic_checkout_truck"  android:contentDescription="@string/cd_checkout_step" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AppText.Subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_standard_eb6d" />

                            <TextView
                                style="@style/AppText.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_livraison_sous_3_224_361f" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDeliveryStandardPrice"
                                style="@style/AppText.Overline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_gratuite_6aa0"
                                android:textColor="?attr/colorPrimary" />

                            <ImageView
                                android:id="@+id/ivStandardCheck"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_checkout_check_filled"  android:importantForAccessibility="no" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDeliveryExpress"
                    style="@style/AppCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/space_16">

                        <com.google.android.material.card.MaterialCardView
                            style="@style/AppCard.IconContainer"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="@dimen/space_16">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="@dimen/space_10"
                                android:src="@drawable/ic_checkout_lightning"  android:contentDescription="@string/cd_checkout_step" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/AppText.Subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_express_b144" />

                            <TextView
                                style="@style/AppText.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_demain_avant_13h00_d9d2" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDeliveryExpressPrice"
                                style="@style/AppText.Subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_12500_dt_657b" />

                            <ImageView
                                android:id="@+id/ivExpressRadio"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_checkout_radio_empty"  android:importantForAccessibility="no" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    style="@style/AppText.SectionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    android:text="@string/auto_articles_39a1"
                    android:textColor="?attr/colorPrimary" />

                <LinearLayout
                    android:id="@+id/layoutCheckoutArticles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:layout_marginBottom="@dimen/space_20"
                    android:orientation="horizontal" />

                <TextView
                    style="@style/AppText.SectionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_r201sum201_88af"
                    android:textColor="?attr/colorPrimary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:layout_marginBottom="@dimen/space_24"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/AppText.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/auto_soustotal_337d" />

                    <TextView
                        android:id="@+id/tvCheckoutSubtotal"
                        style="@style/AppText.FieldLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_458000_dt_e6ae" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutStep2Content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:paddingTop="@dimen/space_16"
                android:visibility="gone">

                <TextView
                    style="@style/AppText.SectionLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_m201thode_de_paiement_2fe9"
                    android:textColor="?attr/colorPrimary" />



                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPayCash"
                    style="@style/AppCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    app:strokeColor="?attr/colorPrimary"
                    app:strokeWidth="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/space_14">

                        <com.google.android.material.card.MaterialCardView
                            style="@style/AppCard.IconContainer"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="@dimen/space_16">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="@dimen/space_10"
                                android:src="@drawable/ic_checkout_truck_gray"  android:contentDescription="@string/cd_checkout_step" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvPayCashTitle"
                                style="@style/AppText.Subtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_paiement_224_la_livraison_03c3" />

                            <TextView
                                android:id="@+id/tvPayCashSubtitle"
                                style="@style/AppText.Caption"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_esp232ces_ou_ch232que_au_8693" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivPayCashRadio"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_checkout_radio_filled"  android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutStep3Content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:paddingTop="@dimen/space_24"
                android:paddingBottom="@dimen/space_32"
                android:visibility="gone">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/ivCheckoutSuccessAnimation"
                    android:layout_width="136dp"
                    android:layout_height="136dp"
                    android:layout_marginBottom="@dimen/space_20"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="false"
                    app:lottie_rawRes="@raw/anim_checkout_success" />

                <TextView
                    style="@style/AppText.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/auto_commande_confirm233e_e20b" />

                <TextView
                    style="@style/AppText.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_8"
                    android:gravity="center"
                    android:text="@string/auto_merci_pour_votre_achat_4d4b" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/AppCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                style="@style/AppText.SectionLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/auto_num201ro_de_commande_5078" />
                            <TextView
                                android:id="@+id/tvConfirmationOrderNumber"
                                style="@style/AppText.FieldLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_fw82941_95c4" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="@dimen/space_16"
                            android:layout_marginBottom="@dimen/space_16"
                            android:background="?attr/colorOutline" />

                        <LinearLayout
                            android:id="@+id/layoutStep3Items"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_16"
                            android:orientation="horizontal">
                            <TextView
                                style="@style/AppText.Body"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/auto_estimation_de_livraison_0286" />
                            <TextView
                                android:id="@+id/tvConfirmationEta"
                                style="@style/AppText.FieldLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_14_16_octobre_4d92" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_12"
                            android:orientation="horizontal">
                            <TextView
                                style="@style/AppText.Body"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/auto_total_pay233_0e5e" />
                            <TextView
                                android:id="@+id/tvConfirmationTotal"
                                style="@style/AppText.FieldLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_0000_dt_e668" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTrackOrder"
                    style="@style/AppButton.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    android:text="@string/auto_suivre_ma_commande_7473" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackHome"
                    style="@style/AppButton.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:text="@string/auto_retour_224_laccueil_f63e" />
            </LinearLayout>
        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutCheckoutBottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/details_background"
        android:elevation="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_20"
            android:paddingTop="@dimen/space_12"
            android:paddingEnd="@dimen/space_20"
            android:paddingBottom="@dimen/space_2">

            <TextView
                android:id="@+id/tvCheckoutShippingLabel"
                style="@style/AppText.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_livraison_standard_c598" />

            <TextView
                android:id="@+id/tvCheckoutShippingValue"
                style="@style/AppText.Overline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_gratuite_6aa0"
                android:textColor="?attr/colorPrimary" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginTop="@dimen/space_16"
            android:background="?attr/colorOutline" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingTop="@dimen/space_12"
            android:paddingEnd="@dimen/space_20"
            android:paddingBottom="@dimen/space_12">

            <TextView
                style="@style/AppText.SectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_total_192_payer_2c61" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCheckoutTotal"
                    style="@style/AppText.Title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginTop="@dimen/space_4"
                    android:text="@string/auto_458000_dt_e6ae" />

                <TextView
                    style="@style/AppText.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingBottom="6dp"
                    android:text="@string/auto_tva_incluse_df75" />
            </LinearLayout>
        </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckoutContinue"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/screen_padding_horizontal"
            android:layout_marginBottom="@dimen/space_12"
            android:text="@string/auto_continuer_vers_le_paiement_361d" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layoutLottieLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorLoadingScrim"
        android:clickable="true"
        android:elevation="10dp"
        android:focusable="true"
        android:visibility="gone">

        <com.airbnb.lottie.LottieAnimationView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/anim_checkout_loading" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
