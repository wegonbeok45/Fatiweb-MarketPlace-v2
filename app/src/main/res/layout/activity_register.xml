<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen"
    android:paddingStart="@dimen/auth_screen_padding"
    android:paddingEnd="@dimen/auth_screen_padding"
    android:paddingTop="8dp"
    android:paddingBottom="12dp"
    tools:context=".RegisterActivity">

    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="@dimen/icon_size_large"
        android:layout_height="@dimen/icon_size_large"
        android:importantForAccessibility="no"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/back"
        app:tint="@color/ms_text_primary" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutLoginRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvAlreadyHaveAccount"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_have_account"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvGoToLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvGoToLogin"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_8"
            android:text="@string/login_btn_label"
            android:textColor="@color/ms_text_primary"
            android:textStyle="bold"
            app:layout_constraintBaseline_toBaselineOf="@id/tvAlreadyHaveAccount"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvAlreadyHaveAccount" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/layoutLoginRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivBack">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutRegisterContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRegisterPanel"
                android:layout_width="0dp"
                android:layout_height="@dimen/auth_hero_height_register"
                app:cardCornerRadius="@dimen/corner_radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@color/overlay_white_8"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:importantForAccessibility="no"
                        android:scaleType="centerCrop"
                        app:srcCompat="@drawable/loginscreen1" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_auth_hero_scrim" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="bottom"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/overlay_white_90"
                            app:cardCornerRadius="999dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="10dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="4dp"
                                android:text="@string/register_feature_premium"
                                android:textColor="@color/ms_text_primary"
                                android:textSize="@dimen/text_size_overline"
                                android:fontFamily="@font/manrope_semibold" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/register_feature_subtitle"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/text_size_title"
                            android:fontFamily="@font/manrope_semibold"
                            android:lineSpacingExtra="1dp"
                            android:maxLines="2" />

                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvHeadline"
                style="@style/AppText.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:gravity="center"
                android:text="@string/register_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardRegisterPanel" />

            <TextView
                android:id="@+id/tvSubtitle"
                style="@style/AppText.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:gravity="center"
                android:text="@string/register_welcome_subtitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHeadline" />

            <TextView
                android:id="@+id/tvFullNameLabel"
                style="@style/AppText.FieldLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/register_name_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFullNameField"
                style="@style/AppInput.Layout"
                android:layout_width="0dp"
                android:layout_marginTop="@dimen/space_4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvFullNameLabel">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutFullNameField"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivFullNameIcon"
                        android:layout_width="@dimen/auth_icon_slot_size"
                        android:layout_height="@dimen/auth_icon_slot_size"
                        android:padding="@dimen/space_12"
                        android:importantForAccessibility="no"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/user" />

                    <EditText
                        android:id="@+id/etFullName"
                        style="@style/AppInput.EditText"
                        android:layout_width="0dp"
                        android:hint="@string/register_name_hint"
                        android:inputType="textPersonName"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivFullNameIcon"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvFullNameError"
                style="@style/Ms.Text.Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:text="@string/auth_error_name_inline"
                android:textColor="@color/colorError"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/cardFullNameField"
                app:layout_constraintStart_toStartOf="@id/cardFullNameField"
                app:layout_constraintTop_toBottomOf="@id/cardFullNameField"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvEmailLabel"
                style="@style/AppText.FieldLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/login_email_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvFullNameError" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEmailField"
                style="@style/AppInput.Layout"
                android:layout_width="0dp"
                android:layout_marginTop="@dimen/space_4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvEmailLabel">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutEmailField"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivEmailIcon"
                        android:layout_width="@dimen/auth_icon_slot_size"
                        android:layout_height="@dimen/auth_icon_slot_size"
                        android:padding="@dimen/space_12"
                        android:importantForAccessibility="no"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/envelope" />

                    <EditText
                        android:id="@+id/etEmail"
                        style="@style/AppInput.EditText"
                        android:layout_width="0dp"
                        android:ellipsize="end"
                        android:gravity="start|center_vertical"
                        android:hint="@string/login_email_hint"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:scrollHorizontally="false"
                        android:textAlignment="viewStart"
                        android:textDirection="ltr"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivEmailIcon"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvEmailError"
                style="@style/Ms.Text.Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:text="@string/auth_error_email_inline"
                android:textColor="@color/colorError"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/cardEmailField"
                app:layout_constraintStart_toStartOf="@id/cardEmailField"
                app:layout_constraintTop_toBottomOf="@id/cardEmailField"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvPasswordLabel"
                style="@style/AppText.FieldLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/login_password_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvEmailError" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPasswordField"
                style="@style/AppInput.Layout"
                android:layout_width="0dp"
                android:layout_marginTop="@dimen/space_4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layoutPasswordField"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivPasswordIcon"
                        android:layout_width="@dimen/auth_icon_slot_size"
                        android:layout_height="@dimen/auth_icon_slot_size"
                        android:padding="@dimen/space_12"
                        android:importantForAccessibility="no"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/lock" />

                    <ImageView
                        android:id="@+id/ivPasswordToggle"
                        android:layout_width="@dimen/auth_icon_slot_size"
                        android:layout_height="@dimen/auth_icon_slot_size"
                        android:padding="@dimen/space_12"
                        android:importantForAccessibility="no"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/ic_eye_off"
                        app:tint="@color/ms_text_secondary" />

                    <EditText
                        android:id="@+id/etPassword"
                        style="@style/AppInput.EditText"
                        android:layout_width="0dp"
                        android:hint="@string/login_password_hint"
                        android:inputType="textPassword"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/ivPasswordToggle"
                        app:layout_constraintStart_toEndOf="@id/ivPasswordIcon"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvPasswordError"
                style="@style/Ms.Text.Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:text="@string/auth_password_helper"
                android:textColor="@color/ms_text_secondary"
                app:layout_constraintEnd_toEndOf="@id/cardPasswordField"
                app:layout_constraintStart_toStartOf="@id/cardPasswordField"
                app:layout_constraintTop_toBottomOf="@id/cardPasswordField" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                style="@style/Ms.Button.Primary"
                android:layout_width="0dp"
                android:layout_marginTop="16dp"
                android:text="@string/login_register_cta"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPasswordError" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutOrDivider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnRegister">

                <View
                    android:id="@+id/viewDividerLeft"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/colorOutline"
                    app:layout_constraintBottom_toBottomOf="@id/tvOrSignUpWith"
                    app:layout_constraintEnd_toStartOf="@id/tvOrSignUpWith"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvOrSignUpWith" />

                <TextView
                    android:id="@+id/tvOrSignUpWith"
                    style="@style/AppText.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/space_16"
                    android:paddingEnd="@dimen/space_16"
                    android:text="@string/register_social_divider"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/viewDividerRight"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/divider_height"
                    android:background="@color/colorOutline"
                    app:layout_constraintBottom_toBottomOf="@id/tvOrSignUpWith"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tvOrSignUpWith"
                    app:layout_constraintTop_toTopOf="@id/tvOrSignUpWith" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutSocialButtons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutOrDivider">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoogle"
                    style="@style/AppButton.Secondary"
                    android:layout_width="0dp"
                    android:text="@string/login_google_label"
                    app:icon="@drawable/googlelogo"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/space_8"
                    app:iconSize="@dimen/space_20"
                    app:iconTint="@null"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
