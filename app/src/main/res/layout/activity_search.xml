<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg">

    <LinearLayout
        android:id="@+id/layoutTopSearchBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:elevation="0dp"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingTop="@dimen/space_8"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingBottom="@dimen/space_8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ivSearchBack"
                android:layout_width="@dimen/surface_button_size"
                android:layout_height="@dimen/surface_button_size"
                app:cardBackgroundColor="@color/surface_neutral"
                app:cardCornerRadius="@dimen/surface_button_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_back"
                    android:padding="@dimen/surface_button_inner_padding"
                    app:srcCompat="@drawable/back"
                    app:tint="@color/home_text_primary" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/surface_button_spacing"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/search_header_title"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/text_size_subtitle" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSearchCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="1"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/search_cancel"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_size_caption"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/screen_section_gap_small"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSearchInput"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/home_surface_raised"
                app:cardCornerRadius="23dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_16"
                    android:paddingEnd="@dimen/space_16">

                    <ImageView
                        android:layout_width="@dimen/surface_button_icon_size"
                        android:layout_height="@dimen/surface_button_icon_size"
                        app:srcCompat="@drawable/ic_profile_nav_search"
                        app:tint="@color/home_text_secondary"  android:contentDescription="@string/cd_search" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/space_12"
                        android:layout_weight="1"
                        android:background="@null"
                        android:gravity="center_vertical"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="@string/search_hint_products"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/home_text_primary"
                        android:textColorHint="@color/home_text_secondary"
                        android:textCursorDrawable="@null"
                        android:textSize="@dimen/text_size_caption" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/filterCard"
                android:layout_width="@dimen/input_height"
                android:layout_height="@dimen/input_height"
                android:layout_marginStart="@dimen/space_12"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorPrimary"
                app:cardCornerRadius="@dimen/corner_radius_medium"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivSearchFilter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/space_14"
                    android:contentDescription="@string/cd_filter"
                    app:srcCompat="@drawable/ic_home_filter"
                    app:tint="@android:color/white" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layoutStateHost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopSearchBar">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/layoutDefaultState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingTop="@dimen/space_8"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingBottom="@dimen/screen_section_gap">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layoutSearchAssist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_meta_pill"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_14"
                    android:paddingTop="@dimen/space_12"
                    android:paddingEnd="@dimen/space_14"
                    android:paddingBottom="@dimen/space_12"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="@color/colorSurface"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/colorBorderLight"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/cd_search"
                            android:padding="10dp"
                            app:srcCompat="@drawable/ic_home_filter"
                            app:tint="?attr/colorPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_12"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/search_discovery_title"
                            android:textColor="@color/home_text_primary"
                            android:textSize="@dimen/text_size_body" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_4"
                            android:fontFamily="@font/manrope_regular"
                            android:maxLines="2"
                            android:text="@string/search_discovery_subtitle"
                            android:textColor="@color/home_text_secondary"
                            android:textSize="@dimen/text_size_overline" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_height="wrap_content"
                    android:id="@+id/tvSavedSearchesTitle"
                    android:layout_width="wrap_content"
                    android:layout_marginTop="@dimen/space_20"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/search_saved_title"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/text_size_body"
                    android:visibility="gone" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_10"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/home_surface_raised"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/layoutSavedList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/space_16"
                        android:paddingTop="@dimen/space_10"
                        android:paddingEnd="@dimen/space_16"
                        android:paddingBottom="@dimen/space_10" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_20"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/search_recent_title"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_caption"
                    android:letterSpacing="0.04" />

                <LinearLayout
                    android:id="@+id/layoutRecentList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:orientation="vertical" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/search_popular_title"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_caption"
                    android:letterSpacing="0.04" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPopular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_10"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="4dp"
                    app:singleLine="false"
                    app:singleSelection="false" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/layoutSuggestionsState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingTop="@dimen/space_12"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingBottom="@dimen/screen_section_gap_small"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/search_suggestions_title"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_caption"
                    android:letterSpacing="0.04" />

                <LinearLayout
                    android:id="@+id/layoutSuggestionsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/layoutResultsState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingTop="@dimen/space_12"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingBottom="@dimen/space_12"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/space_4">

                <LinearLayout
                    android:id="@+id/layoutResultsContext"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="@dimen/space_8"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvResultsContextEyebrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_semibold"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="@dimen/text_size_overline" />

                    <TextView
                        android:id="@+id/tvResultsContextTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/manrope_semibold"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_subtitle" />

                    <TextView
                        android:id="@+id/tvResultsContextSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/manrope_regular"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="@dimen/text_size_overline" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvResultsCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope_medium"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="@dimen/text_size_caption" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSaveSearch"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text="@string/search_save_action"
                        android:textAllCaps="false"
                        android:visibility="gone" />

                    <AutoCompleteTextView
                        android:id="@+id/dropdownSort"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_sort_pill"
                        android:contentDescription="@string/cd_sort"
                        android:dropDownVerticalOffset="4dp"
                        android:minWidth="120dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_caption"
                        android:fontFamily="@font/manrope_semibold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutSkeleton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSearchLoadingLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/search_loading_results"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_caption" />

                <include layout="@layout/item_product_card_shimmer" />

                <include layout="@layout/item_product_card_shimmer" />

                <include layout="@layout/item_product_card_shimmer" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/scrollResults"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/space_12"
                android:layout_weight="1"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layoutEmptyStateCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    app:cardBackgroundColor="@color/home_surface_raised"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/layoutEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingTop="28dp"
                        android:paddingEnd="24dp"
                        android:paddingBottom="24dp"
                        android:visibility="gone">

                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/ivSearchEmptyAnimation"
                            android:layout_width="132dp"
                            android:layout_height="132dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="@string/cd_search"
                            android:padding="0dp"
                            android:scaleType="centerInside"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true"
                            app:lottie_rawRes="@raw/anim_search_empty" />

                        <TextView
                            android:id="@+id/tvEmptyStateTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/search_empty_title"
                            android:textColor="@color/home_text_primary"
                            android:textSize="@dimen/text_size_subtitle" />

                        <TextView
                            android:id="@+id/tvEmptyStateSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/manrope_regular"
                            android:gravity="center"
                            android:text="@string/search_empty_subtitle"
                            android:textColor="@color/home_text_secondary"
                            android:textSize="@dimen/text_size_caption" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBrowseCategories"
                            style="@style/AppButton.Primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:layout_marginTop="16dp"
                            android:text="@string/search_browse_categories" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSearchResults"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingBottom="22dp"
                    android:scrollbars="vertical" />
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>
    <TextView
        android:id="@+id/tvActiveFilterBadge"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupActiveFilters"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
