<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itemCategoryEpices"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/home_category_item_gap"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="@dimen/home_category_circle_size"
        android:layout_height="@dimen/home_category_circle_size"
        app:cardBackgroundColor="@color/colorSurface"
        app:cardCornerRadius="@dimen/corner_radius_round"
        app:cardElevation="@dimen/space_0"
        app:strokeColor="@color/colorOutline"
        app:strokeWidth="@dimen/stroke_width_default">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="E"
            android:textColor="@color/colorPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        style="@style/HomeText.CategoryLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_category_label_margin_top"
        android:text="@string/auto_text_052" />
</LinearLayout>

