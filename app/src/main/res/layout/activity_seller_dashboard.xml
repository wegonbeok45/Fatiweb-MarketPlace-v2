<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/sellerDashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".SellerDashboardActivity">

    <!-- ============ Top App Bar ============ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/sellerDashboardAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/sellerDashboardTopBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/admin_top_bar_height"
            android:paddingStart="@dimen/app_top_bar_horizontal_padding"
            android:paddingEnd="@dimen/app_top_bar_horizontal_padding">

            <ImageView
                android:id="@+id/sellerDashboardIvBack"
                android:layout_width="@dimen/app_top_bar_side_slot_size"
                android:layout_height="@dimen/app_top_bar_side_slot_size"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/cd_stat_icon"
                android:focusable="true"
                android:padding="11dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/back"
                app:tint="@color/ms_text_primary" />

            <TextView
                android:id="@+id/sellerDashboardTvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/admin_top_title_margin_start"
                android:fontFamily="@font/manrope_semibold"
                android:text="@string/seller_dashboard_title"
                android:textColor="@color/ms_text_primary"
                android:textSize="@dimen/app_top_bar_title_size"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/sellerDashboardIvBack"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ============ Content ============ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/sellerDashboardScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="8dp"
            android:paddingEnd="20dp">

            <!-- ====== Premium hero card ====== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sellerDashboardHero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_admin_hero_premium">

                    <View
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="end|top"
                        android:layout_marginEnd="-60dp"
                        android:layout_marginTop="-60dp"
                        android:background="@drawable/bg_admin_hero_glow" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="22dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/bg_admin_section_dot" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:fontFamily="@font/manrope_semibold"
                                    android:letterSpacing="0.15"
                                    android:text="@string/seller_dashboard_title"
                                    android:textAllCaps="true"
                                    android:textColor="@color/ms_accent_gold_soft"
                                    android:textSize="10sp" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:fontFamily="@font/manrope_semibold"
                                android:text="@string/seller_dashboard_hero_title"
                                android:textColor="@android:color/white"
                                android:textSize="24sp" />

                            <TextView
                                android:id="@+id/sellerDashboardTvHeroMeta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/manrope_regular"
                                android:lineSpacingExtra="2dp"
                                android:text="@string/seller_dashboard_hero_meta_placeholder"
                                android:textColor="@color/overlay_white_80"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_gravity="top"
                            android:layout_marginStart="12dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_admin_icon_gold_soft" />

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/cd_stat_icon"
                                app:srcCompat="@drawable/shoppingbag"
                                app:tint="@color/ms_accent_gold" />
                        </FrameLayout>

                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <ProgressBar
                android:id="@+id/sellerDashboardProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:indeterminateTint="@color/ms_accent_gold"
                android:visibility="gone" />

            <!-- ====== Performance section ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_admin_section_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/admin_dashboard_overview_title"
                    android:textColor="@color/ms_text_primary"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sellerDashboardStatsRow1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <include
                    android:id="@+id/sellerDashboardClientsCard"
                    layout="@layout/layout_seller_dashboard_stat_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="7dp"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/sellerDashboardRevenueCard"
                    layout="@layout/layout_seller_dashboard_stat_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sellerDashboardStatsRow2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <include
                    android:id="@+id/sellerDashboardOrdersCard"
                    layout="@layout/layout_seller_dashboard_stat_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="7dp"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/sellerDashboardProductsCard"
                    layout="@layout/layout_seller_dashboard_stat_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/sellerDashboardTvStockMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/manrope_regular"
                android:text="@string/seller_dashboard_stock_meta_placeholder"
                android:textColor="@color/ms_text_secondary"
                android:textSize="11sp" />

            <!-- ====== Quick Actions section ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_admin_section_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/admin_dashboard_quick_actions_title"
                    android:textColor="@color/ms_text_primary"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sellerDashboardQuickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <!-- Primary: Add product (dark + gold) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sellerDashboardBtnAddProduct"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_admin_action_dark"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_admin_icon_gold" />
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/cd_stat_icon"
                                app:srcCompat="@drawable/ic_home_add_cart"
                                app:tint="@android:color/white" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/seller_dashboard_add_action"
                            android:textColor="@android:color/white"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/cd_stat_icon"
                            android:rotation="180"
                            app:srcCompat="@drawable/back"
                            app:tint="@color/ms_accent_gold_soft" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Manage products (light premium) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sellerDashboardBtnManageProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_admin_action_light"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_admin_icon_gold_soft" />
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/cd_stat_icon"
                                app:srcCompat="@drawable/ic_home_filter"
                                app:tint="@color/ms_accent_gold" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/seller_dashboard_products_action"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/cd_stat_icon"
                            android:rotation="180"
                            app:srcCompat="@drawable/back"
                            app:tint="@color/ms_text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- View orders (light premium) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sellerDashboardBtnOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_admin_action_light"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_admin_icon_dark" />
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/cd_stat_icon"
                                app:srcCompat="@drawable/shoppingbag"
                                app:tint="@color/ms_accent_gold_soft" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/seller_dashboard_orders_action"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/cd_stat_icon"
                            android:rotation="180"
                            app:srcCompat="@drawable/back"
                            app:tint="@color/ms_text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ====== Recent orders section ====== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="@drawable/bg_admin_section_dot" />

                <TextView
                    android:id="@+id/sellerDashboardRecentTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/seller_dashboard_recent_orders"
                    android:textColor="@color/ms_text_primary"
                    android:textSize="15sp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sellerDashboardRecentCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_admin_card_premium"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/sellerDashboardRecentEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_regular"
                        android:gravity="center"
                        android:padding="28dp"
                        android:text="@string/seller_orders_empty"
                        android:textColor="@color/ms_text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/sellerDashboardRecentOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
