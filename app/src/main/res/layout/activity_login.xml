<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_screen"
    android:paddingStart="@dimen/auth_screen_padding_compact"
    android:paddingEnd="@dimen/auth_screen_padding_compact"
    tools:context=".LoginActivity">

    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="@dimen/icon_size_large"
        android:layout_height="@dimen/icon_size_large"
        android:layout_marginTop="@dimen/space_4"
        android:importantForAccessibility="no"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/back"
        app:tint="@color/ms_text_primary" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutSignUpRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_4"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:minHeight="44dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvNoAccount"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_no_account"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvSignUp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSignUp"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_8"
            android:text="@string/login_register_cta"
            android:textColor="@color/ms_text_primary"
            android:textStyle="bold"
            app:layout_constraintBaseline_toBaselineOf="@id/tvNoAccount"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvNoAccount" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_8"
        android:layout_marginBottom="@dimen/space_8"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/layoutSignUpRow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivBack">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutLoginContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWelcomePanel"
            android:layout_width="0dp"
            android:layout_height="@dimen/auth_hero_height_compact"
            app:cardCornerRadius="@dimen/corner_radius_large"
            app:cardElevation="0dp"
            app:strokeColor="@color/overlay_white_8"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/loginscreen1" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_auth_hero_scrim" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="bottom"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/overlay_white_90"
                        app:cardCornerRadius="999dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="10dp"
                            android:paddingTop="5dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="5dp"
                            android:text="@string/login_hero_badge"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_overline"
                            android:fontFamily="@font/manrope_semibold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:ellipsize="end"
                        android:text="@string/login_feature_bullet"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/text_size_title"
                        android:fontFamily="@font/manrope_semibold"
                        android:lineSpacingExtra="1dp"
                        android:maxLines="2" />

                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvWelcomeTitle"
            style="@style/AppText.Subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10"
            android:gravity="center"
            android:text="@string/login_welcome_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardWelcomePanel" />

        <TextView
            android:id="@+id/tvWelcomeSubtitle"
            style="@style/AppText.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:gravity="center"
            android:maxLines="2"
            android:text="@string/login_welcome_subtitle"
            android:textSize="@dimen/text_size_caption"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWelcomeTitle" />

        <TextView
            android:id="@+id/tvEmailLabel"
            style="@style/AppText.FieldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10"
            android:text="@string/login_email_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWelcomeSubtitle" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEmailField"
            style="@style/AppInput.Layout"
            android:layout_width="0dp"
            android:layout_marginTop="@dimen/space_4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEmailLabel">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutEmailField"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivEmailIcon"
                    android:layout_width="@dimen/auth_icon_slot_size"
                    android:layout_height="@dimen/auth_icon_slot_size"
                    android:padding="@dimen/space_12"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/envelope" />

                <EditText
                    android:id="@+id/etEmail"
                    style="@style/AppInput.EditText"
                    android:layout_width="0dp"
                    android:hint="@string/login_email_hint"
                    android:inputType="textEmailAddress"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivEmailIcon"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvEmailError"
            style="@style/Ms.Text.Label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:text="@string/auth_error_email_inline"
            android:textColor="@color/colorError"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/cardEmailField"
            app:layout_constraintStart_toStartOf="@id/cardEmailField"
            app:layout_constraintTop_toBottomOf="@id/cardEmailField"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvPasswordLabel"
            style="@style/AppText.FieldLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:text="@string/login_password_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEmailError" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPasswordField"
            style="@style/AppInput.Layout"
            android:layout_width="0dp"
            android:layout_marginTop="@dimen/space_4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutPasswordField"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivPasswordIcon"
                    android:layout_width="@dimen/auth_icon_slot_size"
                    android:layout_height="@dimen/auth_icon_slot_size"
                    android:padding="@dimen/space_12"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/lock" />

                <ImageView
                    android:id="@+id/ivPasswordToggle"
                    android:layout_width="@dimen/auth_icon_slot_size"
                    android:layout_height="@dimen/auth_icon_slot_size"
                    android:padding="@dimen/space_12"
                    android:importantForAccessibility="no"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:srcCompat="@drawable/ic_eye_off"
                    app:tint="@color/ms_text_secondary" />

                <EditText
                    android:id="@+id/etPassword"
                    style="@style/AppInput.EditText"
                    android:layout_width="0dp"
                    android:hint="@string/login_password_hint"
                    android:inputType="textPassword"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivPasswordToggle"
                    app:layout_constraintStart_toEndOf="@id/ivPasswordIcon"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvPasswordError"
            style="@style/Ms.Text.Label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:text="@string/auth_error_password_inline"
            android:textColor="@color/colorError"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/cardPasswordField"
            app:layout_constraintStart_toStartOf="@id/cardPasswordField"
            app:layout_constraintTop_toBottomOf="@id/cardPasswordField"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvForgotPassword"
            style="@style/AppText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_6"
            android:text="@string/login_forgot_password"
            android:textColor="@color/ms_text_primary"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvPasswordError" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/AppButton.Primary"
            android:layout_width="0dp"
            android:layout_marginTop="@dimen/space_10"
            android:text="@string/login_btn_label"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvForgotPassword" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutOrDivider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnLogin">

            <View
                android:id="@+id/viewDividerLeft"
                android:layout_width="0dp"
                android:layout_height="@dimen/divider_height"
                android:background="@color/colorOutline"
                app:layout_constraintBottom_toBottomOf="@id/tvOrConnectWith"
                app:layout_constraintEnd_toStartOf="@id/tvOrConnectWith"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvOrConnectWith" />

            <TextView
                android:id="@+id/tvOrConnectWith"
                style="@style/AppText.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/space_16"
                android:paddingEnd="@dimen/space_16"
                android:text="@string/login_social_divider"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/viewDividerRight"
                android:layout_width="0dp"
                android:layout_height="@dimen/divider_height"
                android:background="@color/colorOutline"
                app:layout_constraintBottom_toBottomOf="@id/tvOrConnectWith"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvOrConnectWith"
                app:layout_constraintTop_toTopOf="@id/tvOrConnectWith" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutSocialButtons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutOrDivider">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                style="@style/AppButton.Secondary"
                android:layout_width="0dp"
                android:minHeight="@dimen/auth_social_button_height"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:text="@string/login_google_label"
                app:icon="@drawable/googlelogo"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/space_8"
                app:iconSize="@dimen/space_20"
                app:iconTint="@null"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnPhone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/ms_surface_card"
                app:cardCornerRadius="@dimen/ms_radius_md"
                app:cardElevation="0dp"
                app:strokeColor="@color/ms_border_default"
                app:strokeWidth="@dimen/ms_stroke_hairline"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnGoogle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="10dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                            app:cardBackgroundColor="@color/ms_surface_sunken"
                        app:cardCornerRadius="999dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_home_category_phone"
                            app:tint="@color/ms_text_primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/phone_login_cta"
                        android:textColor="@color/ms_text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/manrope_semibold" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_chevron_right"
                        app:tint="@color/ms_text_tertiary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinueAsGuest"
            style="@style/AppButton.Secondary"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="@dimen/space_10"
            android:text="@string/login_continue_guest"
            android:textAllCaps="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutSocialButtons"
            app:strokeWidth="0dp" />

        <TextView
            android:id="@+id/tvOrContinueAs"
            style="@style/AppText.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:text="@string/login_or_continue_as"
            android:textColor="@color/home_text_secondary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnContinueAsGuest" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
