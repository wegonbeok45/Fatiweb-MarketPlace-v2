<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/home_nav_bg"
    app:cardCornerRadius="@dimen/corner_radius_large"
    app:cardElevation="0dp"
    app:strokeColor="@color/colorBorderLight"
    app:strokeWidth="@dimen/stroke_width_default">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="92dp"
        android:padding="14dp">

        <FrameLayout
            android:id="@+id/ivIconContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_notification_icon_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivNotificationIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/notification"
                app:tint="?attr/colorPrimary"  android:contentDescription="@string/cd_notification_icon" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvNotificationTitle"
            style="@style/HomeText.CategoryLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/auto_welcome_to_fatiweb_b4d1"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_body"
            android:layout_marginEnd="12dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/viewUnreadDot"
            app:layout_constraintStart_toEndOf="@id/ivIconContainer"
            app:layout_constraintTop_toTopOf="@id/ivIconContainer" />

        <TextView
            android:id="@+id/tvNotificationMessage"
            style="@style/HomeText.SearchHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="@string/auto_discover_the_best_of_887b"
            android:textSize="@dimen/text_size_caption"
            android:lineSpacingExtra="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvNotificationTitle"
            app:layout_constraintTop_toBottomOf="@id/tvNotificationTitle" />

        <TextView
            android:id="@+id/tvNotificationTime"
            style="@style/HomeText.SearchHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/auto_just_now_5803"
            android:textSize="@dimen/text_size_overline"
            app:layout_constraintStart_toStartOf="@id/tvNotificationTitle"
            app:layout_constraintTop_toBottomOf="@id/tvNotificationMessage" />

        <View
            android:id="@+id/viewUnreadDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_notification_badge"
            android:importantForAccessibility="no"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvNotificationTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
