<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".explore">

    <LinearLayout
        android:id="@+id/layoutTopSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/home_nav_bg"
        android:orientation="vertical"
        android:paddingBottom="@dimen/home_top_section_bottom_padding"
        android:paddingTop="@dimen/home_top_spacing"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Top bar: logo, title, actions -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/home_horizontal_padding"
            android:layout_marginEnd="@dimen/home_horizontal_padding">

            <ImageView
                android:id="@+id/ivHomeLogo"
                android:layout_width="@dimen/home_logo_width"
                android:layout_height="@dimen/home_logo_height"
                android:contentDescription="@string/auto_text_001"
                android:scaleType="fitCenter"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/fatiweblogo" />

            <LinearLayout
                android:id="@+id/layoutTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintStart_toEndOf="@id/ivHomeLogo"
                app:layout_constraintEnd_toStartOf="@id/layoutTopActions"
                app:layout_constraintTop_toTopOf="@id/ivHomeLogo"
                app:layout_constraintBottom_toBottomOf="@id/ivHomeLogo"
                android:layout_marginStart="@dimen/home_brand_start_margin">

                <TextView
                    android:id="@+id/tvBrand"
                    style="@style/HomeText.Brand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_text_002" />

                <TextView
                    android:id="@+id/tvBrandSubtitle"
                    style="@style/HomeText.CategoryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_2"
                    android:text="@string/auto_text_011"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutTopActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="@id/ivHomeLogo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivHomeLogo">

                <FrameLayout
                    android:id="@+id/ivTopCart"
                    android:layout_width="@dimen/home_action_icon_size"
                    android:layout_height="@dimen/home_action_icon_size">

                    <ImageView
                        android:id="@+id/ivTopCartIcon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/auto_text_003"
                        app:srcCompat="@drawable/ic_bottom_nav_favorites"
                        app:tint="@color/home_text_primary" />

                </FrameLayout>

                <ImageView
                    android:id="@+id/ivTopNotifications"
                    android:layout_width="@dimen/home_action_icon_size"
                    android:layout_height="@dimen/home_action_icon_size"
                    android:layout_marginStart="@dimen/home_action_gap"
                    android:contentDescription="@string/notifications_title"
                    app:srcCompat="@drawable/notification"
                    app:tint="@color/home_text_primary" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Search pill -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutSearchBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_search_height"
            android:layout_marginStart="@dimen/home_horizontal_padding"
            android:layout_marginTop="@dimen/home_search_margin_top"
            android:layout_marginEnd="@dimen/home_horizontal_padding"
            android:background="@drawable/bg_home_search"
            android:paddingStart="@dimen/home_search_padding_horizontal"
            android:paddingEnd="@dimen/home_search_padding_horizontal">

            <ImageView
                android:id="@+id/ivSearch"
                android:layout_width="@dimen/home_action_icon_size"
                android:layout_height="@dimen/home_action_icon_size"
                android:contentDescription="@string/auto_text_004"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_profile_nav_search"
                app:tint="@color/home_text_secondary" />

            <TextView
                android:id="@+id/tvSearchHint"
                style="@style/HomeText.SearchHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_search_text_start"
                android:ellipsize="end"
                android:maxLines="1"
                android:singleLine="true"
                android:text="@string/auto_text_005"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivFilter"
                app:layout_constraintStart_toEndOf="@id/ivSearch"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivFilter"
                android:layout_width="@dimen/home_action_icon_size"
                android:layout_height="@dimen/home_action_icon_size"
                android:contentDescription="@string/auto_text_006"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_home_filter"
                app:tint="@color/home_text_primary" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <View
        android:id="@+id/viewBottomDivider"
        android:layout_width="0dp"
        android:layout_height="@dimen/divider_height"
        android:background="@color/profile_divider"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <include
        android:id="@+id/layoutBottomNav"
        layout="@layout/include_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="@dimen/profile_bottom_nav_height_exact"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollExploreContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/home_scroll_content_bottom_padding"
        app:layout_constraintBottom_toTopOf="@id/viewBottomDivider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/HomeText.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="@dimen/home_section_margin_top"
                android:text="@string/auto_text_011" />

            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="@dimen/home_category_list_margin_top"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="false">

                <!-- Grid Card: Artisanat -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCategoryArtisanat"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/explore_category_card_height"
                    android:layout_margin="@dimen/explore_category_card_spacing"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true"
                    app:cardPreventCornerOverlap="true"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="@dimen/stroke_width_default">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/auto_text_012"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/img_explore_artisanat" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_explore_category_gradient" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|bottom"
                            android:layout_marginStart="@dimen/explore_category_title_start_margin"
                            android:layout_marginBottom="@dimen/space_8"
                            style="@style/HomeText.ProductName"
                            android:textColor="@color/home_banner_text"
                            android:text="@string/auto_text_013" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Grid Card: Cosmetiques -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCategoryCosmetiques"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/explore_category_card_height"
                    android:layout_margin="@dimen/explore_category_card_spacing"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true"
                    app:cardPreventCornerOverlap="true"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="@dimen/stroke_width_default">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/auto_text_014"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/img_explore_cosmetiques" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_explore_category_gradient" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|bottom"
                            android:layout_marginStart="@dimen/explore_category_title_start_margin"
                            android:layout_marginBottom="@dimen/space_8"
                            style="@style/HomeText.ProductName"
                            android:textColor="@color/home_banner_text"
                            android:text="@string/auto_text_015" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Grid Card: Epices -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCategoryEpices"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/explore_category_card_height"
                    android:layout_margin="@dimen/explore_category_card_spacing"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true"
                    app:cardPreventCornerOverlap="true"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="@dimen/stroke_width_default">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/auto_text_016"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/img_explore_epices" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_explore_category_gradient" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|bottom"
                            android:layout_marginStart="@dimen/explore_category_title_start_margin"
                            android:layout_marginBottom="@dimen/space_8"
                            style="@style/HomeText.ProductName"
                            android:textColor="@color/home_banner_text"
                            android:text="@string/auto_text_017" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Grid Card: Vêtements -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCategoryVetements"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/explore_category_card_height"
                    android:layout_margin="@dimen/explore_category_card_spacing"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true"
                    app:cardPreventCornerOverlap="true"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="@dimen/stroke_width_default">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/auto_text_018"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/img_explore_vetements" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_explore_category_gradient" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|bottom"
                            android:layout_marginStart="@dimen/explore_category_title_start_margin"
                            android:layout_marginBottom="@dimen/space_8"
                            style="@style/HomeText.ProductName"
                            android:textColor="@color/home_banner_text"
                            android:text="@string/auto_text_019" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Grid Card: Décoration -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCategoryDecoration"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/explore_category_card_height"
                    android:layout_margin="@dimen/explore_category_card_spacing"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true"
                    app:cardPreventCornerOverlap="true"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="@dimen/stroke_width_default">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/auto_text_020"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/img_explore_decoration" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_explore_category_gradient" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|bottom"
                            android:layout_marginStart="@dimen/explore_category_title_start_margin"
                            android:layout_marginBottom="@dimen/space_8"
                            style="@style/HomeText.ProductName"
                            android:textColor="@color/home_banner_text"
                            android:text="@string/auto_text_021" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Grid Card: Huiles -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCategoryHuiles"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/explore_category_card_height"
                    android:layout_margin="@dimen/explore_category_card_spacing"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true"
                    app:cardPreventCornerOverlap="true"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="@dimen/stroke_width_default">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/auto_text_022"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/img_explore_huiles" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_explore_category_gradient" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|bottom"
                            android:layout_marginStart="@dimen/explore_category_title_start_margin"
                            android:layout_marginBottom="@dimen/space_8"
                            style="@style/HomeText.ProductName"
                            android:textColor="@color/home_banner_text"
                            android:text="@string/auto_text_023" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.gridlayout.widget.GridLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

