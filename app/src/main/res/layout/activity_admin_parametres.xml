<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminParametresRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_body_bg"
    tools:context=".AdminParametresActivity">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminParametresAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_details_top_surface"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <include
            android:id="@+id/adminParametresTopBar"
            layout="@layout/include_admin_top_bar" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/profile_divider" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/adminParametresScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <!-- Boutique Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminParamCardBoutique"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_admin_hero_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:text="@string/auto_fatiweb_market_9c85"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/text_size_title" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"

                        android:text="@string/auto_gestion_de_la_boutique_fde7"
                        android:textColor="@color/surface_warm_muted"
                        android:textSize="@dimen/text_size_caption" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Livraison Card -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:text="@string/auto_methodes_de_livraison_c439"
                android:textColor="@color/profile_text_primary"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textSize="@dimen/text_size_subtitle"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminParamCardLivraison"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/profile_card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            android:id="@+id/adminParamLivrStandard"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"

                            android:text="@string/auto_standard_eb6d"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_caption"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:id="@+id/adminParamLivrStandardEditGroup"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?selectableItemBackgroundBorderless"
                            android:paddingStart="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            
                            <TextView
                                android:id="@+id/adminParamLivrStandardPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="@string/auto_7_dt_297c"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="@dimen/text_size_caption" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="8dp"
                                android:contentDescription="@string/cd_stat_icon"
                                app:srcCompat="@drawable/ic_admin_edit"
                                app:tint="@color/profile_text_secondary" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/profile_divider" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <TextView
                            android:id="@+id/adminParamLivrExpress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"

                            android:text="@string/auto_express_b144"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_caption"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:id="@+id/adminParamLivrExpressEditGroup"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?selectableItemBackgroundBorderless"
                            android:paddingStart="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            
                            <TextView
                                android:id="@+id/adminParamLivrExpressPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"

                                android:text="@string/auto_15_dt_2b20"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="@dimen/text_size_caption" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="8dp"
                                android:contentDescription="@string/cd_stat_icon"
                                app:srcCompat="@drawable/ic_admin_edit"
                                app:tint="@color/profile_text_secondary" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Paiement Card -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:text="@string/auto_modes_de_paiement_a7ff"
                android:textColor="@color/profile_text_primary"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textSize="@dimen/text_size_subtitle"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminParamCardPaiement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/profile_card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"

                            android:text="@string/auto_carte_bancaire_d999"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_caption"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/cd_stat_icon"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/profile_chevron"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/profile_divider" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"

                            android:text="@string/auto_edinar_92ac"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_caption"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/cd_stat_icon"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/profile_chevron"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/profile_divider" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"

                            android:text="@string/auto_cash_a_la_livraison_2636"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_caption"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/cd_stat_icon"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/profile_chevron"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav -->
    <include
        layout="@layout/include_admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

