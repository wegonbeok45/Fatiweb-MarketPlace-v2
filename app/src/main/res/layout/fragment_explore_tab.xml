<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".explore">

    <LinearLayout
        android:id="@+id/layoutTopSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/home_nav_bg"
        android:orientation="vertical"
        android:paddingBottom="@dimen/home_top_section_bottom_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/home_horizontal_padding"
            android:layout_marginTop="@dimen/home_top_spacing"
            android:layout_marginEnd="@dimen/home_horizontal_padding">

            <ImageView
                android:id="@+id/ivHomeLogo"
                android:layout_width="@dimen/home_logo_width"
                android:layout_height="@dimen/home_logo_height"
                android:contentDescription="@string/auto_text_001"
                android:scaleType="fitCenter"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/fatiweblogo" />

            <TextView
                android:id="@+id/tvBrand"
                style="@style/HomeText.Brand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_brand_start_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/auto_text_002"
                app:layout_constraintBottom_toBottomOf="@id/ivHomeLogo"
                app:layout_constraintEnd_toStartOf="@id/layoutTopActions"
                app:layout_constraintStart_toEndOf="@id/ivHomeLogo"
                app:layout_constraintTop_toTopOf="@id/ivHomeLogo" />

            <LinearLayout
                android:id="@+id/layoutTopActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="@id/ivHomeLogo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivHomeLogo">

                <FrameLayout
                    android:id="@+id/ivTopCart"
                    android:layout_width="@dimen/home_action_icon_size"
                    android:layout_height="@dimen/home_action_icon_size">

                    <ImageView
                        android:id="@+id/ivTopCartIcon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/auto_text_003"
                        app:srcCompat="@drawable/ic_bottom_nav_cart"
                        app:tint="@color/home_text_primary" />

                </FrameLayout>

                <FrameLayout
                    android:id="@+id/notificationContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/home_action_gap">

                    <ImageView
                        android:id="@+id/ivTopNotifications"
                        android:layout_width="@dimen/home_action_icon_size"
                        android:layout_height="@dimen/home_action_icon_size"
                        android:contentDescription="@string/notifications_title"
                        app:srcCompat="@drawable/notification"
                        app:tint="@color/home_text_primary" />

                    <View
                        android:id="@+id/notificationBadge"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="end|top"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_notification_badge"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <View
        android:id="@+id/viewBottomDivider"
        android:layout_width="0dp"
        android:layout_height="@dimen/divider_height"
        android:visibility="gone"
        android:background="@color/profile_divider"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/layoutBottomNav"
        android:layout_width="0dp"
        android:layout_height="@dimen/profile_bottom_nav_height_exact"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollExploreContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/home_scroll_content_bottom_padding"
        app:layout_constraintBottom_toTopOf="@id/viewBottomDivider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/HomeText.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="@dimen/home_section_margin_top"
                android:text="@string/auto_text_011" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="@dimen/home_category_list_margin_top"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:gravity="center_horizontal"
                android:layoutAnimation="@anim/layout_animation_fall_down"
                android:orientation="vertical">

                    <!-- Vertical Card List (Stitch V2 Style) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCategoryArtisanat"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/explore_category_card_height"
                        android:layout_marginBottom="@dimen/explore_category_card_spacing"
                        app:cardCornerRadius="@dimen/home_banner_radius"
                        app:cardElevation="@dimen/space_0"
                        app:cardUseCompatPadding="false"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="@dimen/space_0">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_text_012"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/img_explore_artisanat" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_explore_category_gradient" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="start|center_vertical"
                                android:layout_marginStart="@dimen/explore_category_title_start_margin"
                                android:textColor="#FFFFFF"
                                android:textSize="21sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:text="@string/auto_text_013" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCategoryCosmetiques"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/explore_category_card_height"
                        android:layout_marginBottom="@dimen/explore_category_card_spacing"
                        app:cardCornerRadius="@dimen/home_banner_radius"
                        app:cardElevation="@dimen/space_0"
                        app:cardUseCompatPadding="false"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="@dimen/space_0">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_text_014"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/img_explore_cosmetiques" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_explore_category_gradient" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="start|center_vertical"
                                android:layout_marginStart="@dimen/explore_category_title_start_margin"
                                android:textColor="#FFFFFF"
                                android:textSize="21sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:text="@string/auto_text_015" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCategoryEpices"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/explore_category_card_height"
                        android:layout_marginBottom="@dimen/explore_category_card_spacing"
                        app:cardCornerRadius="@dimen/home_banner_radius"
                        app:cardElevation="@dimen/space_0"
                        app:cardUseCompatPadding="false"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="@dimen/space_0">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_text_016"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/img_explore_epices" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_explore_category_gradient" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="start|center_vertical"
                                android:layout_marginStart="@dimen/explore_category_title_start_margin"
                                android:textColor="#FFFFFF"
                                android:textSize="21sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:text="@string/auto_text_017" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCategoryVetements"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/explore_category_card_height"
                        android:layout_marginBottom="@dimen/explore_category_card_spacing"
                        app:cardCornerRadius="@dimen/home_banner_radius"
                        app:cardElevation="@dimen/space_0"
                        app:cardUseCompatPadding="false"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="@dimen/space_0">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_text_018"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/img_explore_vetements" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_explore_category_gradient" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="start|center_vertical"
                                android:layout_marginStart="@dimen/explore_category_title_start_margin"
                                android:textColor="#FFFFFF"
                                android:textSize="21sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:text="@string/auto_text_019" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCategoryDecoration"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/explore_category_card_height"
                        android:layout_marginBottom="@dimen/explore_category_card_spacing"
                        app:cardCornerRadius="@dimen/home_banner_radius"
                        app:cardElevation="@dimen/space_0"
                        app:cardUseCompatPadding="false"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="@dimen/space_0">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_text_020"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/img_explore_decoration" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_explore_category_gradient" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="start|center_vertical"
                                android:layout_marginStart="@dimen/explore_category_title_start_margin"
                                android:textColor="#FFFFFF"
                                android:textSize="21sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:text="@string/auto_text_021" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCategoryHuiles"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/explore_category_card_height"
                        android:layout_marginBottom="@dimen/explore_category_card_spacing"
                        app:cardCornerRadius="@dimen/home_banner_radius"
                        app:cardElevation="@dimen/space_0"
                        app:cardUseCompatPadding="false"
                        app:strokeColor="@android:color/transparent"
                        app:strokeWidth="@dimen/space_0">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_text_022"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/img_explore_huiles" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_explore_category_gradient" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="start|center_vertical"
                                android:layout_marginStart="@dimen/explore_category_title_start_margin"
                                android:textColor="#FFFFFF"
                                android:textSize="21sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:text="@string/auto_text_023" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>








