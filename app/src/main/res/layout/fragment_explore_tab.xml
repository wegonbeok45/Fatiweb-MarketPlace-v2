<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".ExploreTabFragment">

    <LinearLayout
        android:id="@+id/layoutTopSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:orientation="vertical"
        android:paddingStart="@dimen/home_horizontal_padding"
        android:paddingTop="@dimen/home_top_bar_top_margin"
        android:paddingEnd="@dimen/home_horizontal_padding"
        android:paddingBottom="@dimen/home_top_section_bottom_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:text="@string/auto_explore_1819"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_title_large"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutSearchBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_search_height"
            android:layout_marginTop="@dimen/home_search_margin_top"
            app:cardBackgroundColor="@color/home_surface_raised"
            app:cardCornerRadius="@dimen/home_search_radius"
            app:cardElevation="3dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/home_search_padding_horizontal"
                android:paddingEnd="@dimen/home_search_padding_horizontal">

                <ImageView
                    android:id="@+id/ivSearch"
                    android:layout_width="@dimen/home_action_icon_size"
                    android:layout_height="@dimen/home_action_icon_size"
                    android:contentDescription="@string/cd_search"
                    app:srcCompat="@drawable/ic_profile_nav_search"
                    app:tint="@color/home_text_secondary" />

                <TextView
                    android:id="@+id/tvSearchPlaceholder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/home_search_text_start"
                    android:layout_weight="1"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    android:text="@string/auto_search_unique_products_3648"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/home_text_search" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollExploreContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/home_horizontal_padding"
            android:paddingTop="20dp"
            android:paddingEnd="@dimen/home_horizontal_padding"
            android:paddingBottom="100dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/home_surface_raised"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_meta_pill"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="@string/auto_editorial_56d0"
                        android:textColor="@color/home_meta_text"
                        android:textSize="@dimen/text_size_overline"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:lineSpacingExtra="2dp"
                        android:text="@string/auto_the_maker_movement_e7c5"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:lineSpacingExtra="4dp"
                        android:text="@string/auto_discover_the_stories_behind_0aa6"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="@dimen/text_size_body" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="@string/auto_browse_categories_7039"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCategoryArtisanat"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/auto_artisanat_6d19"
                        android:scaleType="centerCrop"
                        app:srcCompat="@drawable/img_explore_artisanat" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_explore_category_gradient" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="bottom"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_home_meta_pill"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:text="@string/auto_master_crafts_368b"
                            android:textColor="@color/home_meta_text"
                            android:textSize="@dimen/text_size_overline"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/auto_traditional_crafts_501b"
                            android:textColor="@android:color/white"
                            android:textSize="@dimen/text_size_title"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:text="@string/auto_authentic_tunisian_handmade_goods_99c3"
                            android:textColor="@color/border_medium"
                            android:textSize="@dimen/text_size_caption" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCategoryCosmetiques"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/auto_cosmetiques_bfba"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/img_explore_cosmetiques" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_explore_category_gradient" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans_bold"
                                android:text="@string/auto_beauty_7a7f"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/text_size_subtitle"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/plus_jakarta_sans_regular"
                                android:text="@string/auto_organic_care_bae4"
                                android:textColor="@color/border_medium"
                                android:textSize="@dimen/text_size_overline" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCategoryEpices"
                    android:layout_width="0dp"
                    android:layout_height="200dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/auto_epices_8354"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/img_explore_epices" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_explore_category_gradient" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans_bold"
                                android:text="@string/auto_spices_34c6"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/text_size_subtitle"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/plus_jakarta_sans_regular"
                                android:text="@string/auto_natural_flavors_7288"
                                android:textColor="@color/border_medium"
                                android:textSize="@dimen/text_size_overline" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCategoryVetements"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/auto_vetements_aee7"
                            android:scaleType="centerCrop"
                            app:srcCompat="@drawable/img_explore_vetements" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_explore_category_gradient" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="24dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/plus_jakarta_sans_bold"
                                android:text="@string/auto_apparel_fc43"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/text_size_subtitle"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/plus_jakarta_sans_regular"
                                android:text="@string/auto_traditional_wear_71f6"
                                android:textColor="@color/border_medium"
                                android:textSize="@dimen/text_size_caption" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCategoryDecoration"
                        android:layout_width="0dp"
                        android:layout_height="190dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_decoration_2436"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/img_explore_decoration" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_explore_category_gradient" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="bottom"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/plus_jakarta_sans_bold"
                                    android:text="@string/auto_home_decor_a8fa"
                                    android:textColor="@android:color/white"
                                    android:textSize="@dimen/text_size_subtitle"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCategoryHuiles"
                        android:layout_width="0dp"
                        android:layout_height="190dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_huiles_3b0b"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/img_explore_huiles" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_explore_category_gradient" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="bottom"
                                android:orientation="vertical"
                                android:padding="20dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/plus_jakarta_sans_bold"
                                    android:text="@string/auto_natural_oils_17f4"
                                    android:textColor="@android:color/white"
                                    android:textSize="@dimen/text_size_subtitle"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
