<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".ExploreTabFragment">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- Top Section — editorial header                     -->
    <!-- ═══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutTopSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/home_ref_bg"
        android:elevation="@dimen/home_header_elevation"
        android:orientation="vertical"
        android:paddingStart="@dimen/home_ref_horizontal_padding"
        android:paddingTop="@dimen/home_ref_top_padding"
        android:paddingEnd="@dimen/home_ref_horizontal_padding"
        android:paddingBottom="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvCategoriesTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_semibold"
                android:includeFontPadding="false"
                android:text="@string/categories_screen_title"
                android:textColor="@color/ms_text_primary"
                android:textSize="@dimen/text_size_title"
                app:layout_constraintBottom_toBottomOf="@id/notificationContainer"
                app:layout_constraintEnd_toStartOf="@id/notificationContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/notificationContainer" />

            <FrameLayout
                android:id="@+id/notificationContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivTopNotifications"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/notifications_title"
                    app:srcCompat="@drawable/notification"
                    app:tint="@color/ms_text_secondary" />

                <View
                    android:id="@+id/notificationBadge"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="9dp"
                    android:layout_marginEnd="9dp"
                    android:background="@drawable/bg_notification_badge"
                    android:backgroundTint="@color/ms_accent_gold"
                    android:visibility="gone" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvCategoriesSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:fontFamily="@font/manrope_regular"
            android:includeFontPadding="false"
            android:text="@string/categories_screen_subtitle"
            android:textColor="@color/home_ref_text_secondary"
            android:textSize="@dimen/text_size_caption" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutSearchBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_search_height"
            android:layout_marginTop="@dimen/home_search_margin_top"
            app:cardBackgroundColor="@color/ms_surface_card"
            app:cardCornerRadius="@dimen/home_search_radius"
            app:cardElevation="0dp"
            app:strokeColor="@color/ms_border_default"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/home_search_padding_horizontal"
                android:paddingEnd="@dimen/home_search_padding_horizontal">

                <ImageView
                    android:layout_width="@dimen/home_action_icon_size"
                    android:layout_height="@dimen/home_action_icon_size"
                    android:contentDescription="@string/cd_search"
                    app:srcCompat="@drawable/ic_profile_nav_search"
                    app:tint="@color/home_ref_text_secondary" />

                <EditText
                    android:id="@+id/etCategorySearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/home_search_text_start"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/manrope_regular"
                    android:hint="@string/categories_search_hint"
                    android:imeOptions="actionSearch"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:textColor="@color/ms_text_primary"
                    android:textColorHint="@color/home_ref_text_secondary"
                    android:textSize="@dimen/home_text_search" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- Scrollable Content                                 -->
    <!-- ═══════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollExploreContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/bottom_nav_reserved_space"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="@dimen/space_24">

            <!-- Featured Categories section title (horizontal-padded) -->
            <LinearLayout
                android:id="@+id/layoutFeaturedHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/home_horizontal_padding"
                android:paddingEnd="@dimen/home_horizontal_padding">

                <TextView
                    android:id="@+id/tvFeaturedCategoriesTitle"
                    style="@style/HomeText.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/categories_featured_title" />

                <TextView
                    android:id="@+id/tvFeaturedCategoriesHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_8"
                    android:fontFamily="@font/manrope_medium"
                    android:includeFontPadding="false"
                    android:letterSpacing="0.04"
                    android:text="@string/categories_featured_hint"
                    android:textAllCaps="true"
                    android:textColor="@color/ms_accent_gold"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Featured carousel — wide, hero-style cards -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeaturedCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingStart="@dimen/home_horizontal_padding"
                android:paddingEnd="@dimen/home_horizontal_padding"
                android:scrollbars="none"
                tools:itemCount="4"
                tools:listitem="@layout/item_marketplace_category_card"
                tools:orientation="horizontal" />

            <!-- All Categories section title -->
            <TextView
                android:id="@+id/tvAllCategoriesTitle"
                style="@style/HomeText.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingStart="@dimen/home_horizontal_padding"
                android:paddingEnd="@dimen/home_horizontal_padding"
                android:text="@string/categories_all_title" />

            <!-- All categories — 2-col grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAllCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:paddingStart="@dimen/home_horizontal_padding"
                android:paddingEnd="@dimen/home_horizontal_padding"
                tools:itemCount="8"
                tools:listitem="@layout/item_marketplace_category_card" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/layoutCategoriesEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="@dimen/space_24"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:background="@drawable/bg_home_empty_state_panel"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_semibold"
                    android:gravity="center"
                    android:text="@string/categories_empty_title"
                    android:textColor="@color/ms_text_primary"
                    android:textSize="@dimen/text_size_subtitle" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/manrope_regular"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/categories_empty_subtitle"
                    android:textColor="@color/home_ref_text_secondary"
                    android:textSize="@dimen/text_size_caption" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
