<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/app_top_bar_height"
        android:background="@color/ms_surface_canvas"
        android:paddingStart="@dimen/app_top_bar_horizontal_padding"
        android:paddingEnd="@dimen/app_top_bar_horizontal_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/app_top_bar_side_slot_size"
            android:layout_height="@dimen/app_top_bar_side_slot_size"
            android:contentDescription="@string/cd_back"
            android:padding="@dimen/surface_button_inner_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/back"
            app:tint="@color/ms_text_primary" />

        <TextView
            style="@style/AppTopBar.Title.Profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/payment_methods_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar">

        <LinearLayout
            android:id="@+id/layoutPaymentContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/profile_horizontal_margin"
            android:paddingTop="@dimen/space_16"
            android:paddingEnd="@dimen/profile_horizontal_margin">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_semibold"
                android:text="@string/payment_methods_saved_cards"
                android:textColor="@color/ms_text_primary"
                android:textSize="@dimen/text_size_subtitle" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPaymentEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:visibility="gone"
                app:cardBackgroundColor="@color/ms_surface_card"
                app:cardCornerRadius="@dimen/corner_radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@color/ms_border_default"
                app:strokeWidth="@dimen/stroke_width_default">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/space_16"
                    android:text="@string/payment_methods_empty"
                    android:textColor="@color/ms_text_secondary"
                    android:textSize="@dimen/text_size_body" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutSavedCardsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddPaymentMethod"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:icon="@drawable/ic_profile_chevron_right"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/space_8"
                android:text="@string/payment_methods_add"
                android:textAllCaps="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:fontFamily="@font/manrope_semibold"
                android:text="@string/payment_methods_billing_address"
                android:textColor="@color/ms_text_primary"
                android:textSize="@dimen/text_size_subtitle" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBillingAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                app:cardBackgroundColor="@color/ms_surface_card"
                app:cardCornerRadius="@dimen/corner_radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@color/ms_border_default"
                app:strokeWidth="@dimen/stroke_width_default">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_16">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/cd_location"
                        app:srcCompat="@drawable/map"
                        app:tint="@color/ms_text_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_12"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBillingAddressTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_semibold"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_body"
                            tools:text="123 Design Avenue, Apt 4B" />

                        <TextView
                            android:id="@+id/tvBillingAddressSubtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/ms_text_secondary"
                            android:textSize="@dimen/text_size_caption"
                            tools:text="San Francisco, CA 94107&#10;United States" />

                        <TextView
                            android:id="@+id/tvBillingAddressEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/payment_methods_address_empty"
                            android:textColor="@color/ms_text_secondary"
                            android:textSize="@dimen/text_size_body"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnEditBillingAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_semibold"
                        android:text="@string/payment_methods_edit_address"
                        android:textColor="@color/ms_surface_inverse"
                        android:textSize="@dimen/text_size_caption" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

