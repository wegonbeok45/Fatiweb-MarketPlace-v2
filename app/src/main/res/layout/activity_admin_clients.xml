<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminClientsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_body_bg"
    tools:context=".AdminClientsActivity">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminClientsAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/profile_header_bg"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/adminClientsTopBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/adminClientsIvBack"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/back"
                app:tint="@color/profile_text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:fontFamily="@font/funnelsans_semibold"
                android:text="Clients"
                android:textColor="@color/profile_text_primary"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/adminClientsIvBack"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/profile_divider" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/adminClientsScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <!-- Stats Row -->
            <LinearLayout
                android:id="@+id/adminClientsStatsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/colorPrimary"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/funnelsans_semibold"
                            android:text="..."
                            android:textColor="#FFFFFF"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/funnelsans_regular"
                            android:text="Total Clients"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/funnelsans_semibold"
                            android:text=""
                            android:visibility="gone"
                            android:textColor="#34A853"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/funnelsans_regular"
                            android:text="Nouveaux"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Section Header -->
            <TextView
                android:id="@+id/adminClientsTvHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/funnelsans_semibold"
                android:text="Liste des Clients"
                android:textColor="@color/profile_text_primary"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Clients Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminClientsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/profile_card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Client 1 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/adminClientRow1"
                        android:layout_width="match_parent"
                        android:layout_height="76dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/adminClientAvatar1"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:cardBackgroundColor="@color/profile_card_icon_bg"
                            app:cardCornerRadius="999dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:fontFamily="@font/funnelsans_semibold"
                                android:text="A"
                                android:textColor="@color/colorPrimary"
                                android:textSize="18sp" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/adminClientId1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/funnelsans_regular"
                            android:text="#001"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="10sp"
                            app:layout_constraintBottom_toTopOf="@id/adminClientName1"
                            app:layout_constraintStart_toEndOf="@id/adminClientAvatar1"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/adminClientName1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/funnelsans_semibold"
                            android:text="Ahmed Ben Ali"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toTopOf="@id/adminClientEmail1"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/adminClientAvatar1"
                            app:layout_constraintTop_toBottomOf="@id/adminClientId1" />

                        <TextView
                            android:id="@+id/adminClientEmail1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/funnelsans_regular"
                            android:text="ahmed.benali@email.com"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/adminClientAvatar1"
                            app:layout_constraintTop_toBottomOf="@id/adminClientName1" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/profile_divider" />

                    <!-- Client 2 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/adminClientRow2"
                        android:layout_width="match_parent"
                        android:layout_height="76dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/adminClientAvatar2"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:cardBackgroundColor="@color/profile_card_icon_bg"
                            app:cardCornerRadius="999dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:fontFamily="@font/funnelsans_semibold"
                                android:text="S"
                                android:textColor="@color/colorPrimary"
                                android:textSize="18sp" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/adminClientId2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/funnelsans_regular"
                            android:text="#002"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="10sp"
                            app:layout_constraintBottom_toTopOf="@id/adminClientName2"
                            app:layout_constraintStart_toEndOf="@id/adminClientAvatar2"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/adminClientName2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/funnelsans_semibold"
                            android:text="Sara Mansour"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toTopOf="@id/adminClientEmail2"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/adminClientAvatar2"
                            app:layout_constraintTop_toBottomOf="@id/adminClientId2" />

                        <TextView
                            android:id="@+id/adminClientEmail2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/funnelsans_regular"
                            android:text="sara.mansour@email.com"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/adminClientAvatar2"
                            app:layout_constraintTop_toBottomOf="@id/adminClientName2" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/profile_divider" />

                    <!-- Client 3 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/adminClientRow3"
                        android:layout_width="match_parent"
                        android:layout_height="76dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:visibility="gone">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/adminClientAvatar3"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:cardBackgroundColor="@color/profile_card_icon_bg"
                            app:cardCornerRadius="999dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:fontFamily="@font/funnelsans_semibold"
                                android:text="Y"
                                android:textColor="@color/colorPrimary"
                                android:textSize="18sp" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/adminClientId3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/funnelsans_regular"
                            android:text="#003"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="10sp"
                            app:layout_constraintBottom_toTopOf="@id/adminClientName3"
                            app:layout_constraintStart_toEndOf="@id/adminClientAvatar3"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/adminClientName3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/funnelsans_semibold"
                            android:text="Youssef Trabelsi"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toTopOf="@id/adminClientEmail3"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/adminClientAvatar3"
                            app:layout_constraintTop_toBottomOf="@id/adminClientId3" />

                        <TextView
                            android:id="@+id/adminClientEmail3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/funnelsans_regular"
                            android:text="youssef.t@email.com"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/adminClientAvatar3"
                            app:layout_constraintTop_toBottomOf="@id/adminClientName3" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav -->
    <include
        layout="@layout/include_admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
