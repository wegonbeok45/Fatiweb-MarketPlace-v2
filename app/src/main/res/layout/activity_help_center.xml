<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_body_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/app_top_bar_height"
        android:background="@color/profile_header_bg"
        android:paddingStart="@dimen/app_top_bar_horizontal_padding"
        android:paddingEnd="@dimen/app_top_bar_horizontal_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/app_top_bar_side_slot_size"
            android:layout_height="@dimen/app_top_bar_side_slot_size"
            android:contentDescription="@string/cd_back"
            android:padding="@dimen/surface_button_inner_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/back"
            app:tint="@color/profile_text_primary" />

        <TextView
            style="@style/AppTopBar.Title.Profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/help_center_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivNotifications"
            android:layout_width="@dimen/app_top_bar_side_slot_size"
            android:layout_height="@dimen/app_top_bar_side_slot_size"
            android:contentDescription="@string/cd_notifications"
            android:padding="@dimen/surface_button_inner_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/notification"
            app:tint="@color/profile_text_primary" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/profile_horizontal_margin"
            android:paddingTop="@dimen/space_16"
            android:paddingEnd="@dimen/profile_horizontal_margin">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHelpSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/home_search_bg"
                app:cardCornerRadius="@dimen/corner_radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/space_14"
                    android:paddingTop="@dimen/space_10"
                    android:paddingEnd="@dimen/space_14"
                    android:paddingBottom="@dimen/space_10">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@string/cd_search"
                        app:srcCompat="@drawable/ic_profile_nav_search"
                        app:tint="@color/profile_text_secondary" />

                    <EditText
                        android:id="@+id/etHelpSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_10"
                        android:layout_weight="1"
                        android:background="@null"
                        android:fontFamily="@font/manrope_regular"
                        android:hint="@string/help_center_search_hint"
                        android:inputType="textCapSentences"
                        android:textColor="@color/profile_text_primary"
                        android:textColorHint="@color/profile_text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:fontFamily="@font/manrope_semibold"
                android:text="@string/help_center_common_topics"
                android:textColor="@color/profile_text_primary"
                android:textSize="@dimen/text_size_body" />

            <LinearLayout
                android:id="@+id/layoutHelpTopics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="vertical">

                <include layout="@layout/item_help_topic" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:fontFamily="@font/manrope_semibold"
                android:text="@string/help_center_contact_us"
                android:textColor="@color/profile_text_primary"
                android:textSize="@dimen/text_size_body" />

            <LinearLayout
                android:id="@+id/layoutHelpContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardContactChat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/home_surface_raised"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="@dimen/stroke_width_default">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/cd_menu"
                            app:srcCompat="@drawable/ic_profile_help"
                            app:tint="@color/profile_text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_12"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/help_center_live_chat"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_body" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/help_center_live_chat_subtitle"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="@dimen/text_size_caption" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="@dimen/space_12"
                    android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardContactEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/home_surface_raised"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="@dimen/stroke_width_default">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/cd_notifications"
                            app:srcCompat="@drawable/notification"
                            app:tint="@color/profile_text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_12"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/help_center_email_support"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_body" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/help_center_email_support_subtitle"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="@dimen/text_size_caption" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBrowseFaqs"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:text="@string/help_center_browse_faqs"
                android:textAllCaps="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

