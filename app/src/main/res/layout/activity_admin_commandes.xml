<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminCommandesRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_body_bg"
    tools:context=".AdminCommandesActivity">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminCommandesAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/profile_header_bg"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/adminCommandesTopBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/adminCommandesIvBack"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/cd_stat_icon"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/back"
                app:tint="@color/profile_text_primary" />

            <TextView
                android:id="@+id/adminCommandesTvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="@string/admin_title_orders"
                android:textColor="@color/profile_text_primary"
                android:textSize="@dimen/text_size_subtitle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/adminCommandesIvSettings"
                app:layout_constraintStart_toEndOf="@id/adminCommandesIvBack"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/adminCommandesIvSettings"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="@string/cd_stat_icon"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:srcCompat="@drawable/settings"
                app:tint="@color/profile_text_primary" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/profile_divider" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/adminCommandesScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp">

            <!-- Stats Row -->
            <LinearLayout
                android:id="@+id/adminCommandesStatsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/adminCommandesTvTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="@string/str_2f43b4"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="@dimen/text_size_title"
                            app:layout_constraintBottom_toTopOf="@id/adminCommandesTvTotalLabel"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/adminCommandesTvTotalLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="@string/admin_orders_total_label"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="@dimen/text_size_overline"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/adminCommandesTvTotal" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/adminCommandesTvPending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="@string/str_2f43b4"
                            android:textColor="?attr/colorError"
                            android:textSize="@dimen/text_size_title"
                            app:layout_constraintBottom_toTopOf="@id/adminCommandesTvPendingLabel"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/adminCommandesTvPendingLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="@string/admin_orders_pending_label"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="@dimen/text_size_overline"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/adminCommandesTvPending" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:id="@+id/adminCommandesTvDelivered"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="@string/str_2f43b4"
                            android:textColor="@color/google_green"
                            android:textSize="@dimen/text_size_title"
                            app:layout_constraintBottom_toTopOf="@id/adminCommandesTvDeliveredLabel"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/adminCommandesTvDeliveredLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="@string/admin_orders_delivered_label"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="@dimen/text_size_overline"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/adminCommandesTvDelivered" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Section Header -->
            <TextView
                android:id="@+id/adminCommandesTvHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:text="@string/admin_orders_recent_title"
                android:textColor="@color/profile_text_primary"
                android:textSize="@dimen/text_size_body"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="1dp">

                    <EditText
                        android:id="@+id/adminCommandesSearchInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="@string/admin_orders_search_hint"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="@color/profile_text_primary"
                        android:textColorHint="@color/profile_text_secondary" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="136dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorBorderLight"
                    app:strokeWidth="1dp">

                    <AutoCompleteTextView
                        android:id="@+id/adminCommandesFilterInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:inputType="none"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/profile_text_primary"
                        android:textColorHint="@color/profile_text_secondary"
                        tools:text="Tous" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Orders Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminCommandesCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/profile_card_bg"
                app:cardCornerRadius="@dimen/corner_radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ProgressBar
                        android:id="@+id/adminCommandesProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="24dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/adminCommandesEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="24dp"
                        android:text="@string/admin_orders_empty"
                        android:textColor="@color/profile_text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/adminCommandesList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav -->
    <include
        layout="@layout/include_admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
