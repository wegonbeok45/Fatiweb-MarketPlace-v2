<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminNotifRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_body_bg"
    tools:context=".AdminNotificationsActivity">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminNotifAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_details_top_surface"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/adminNotifTopBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminNotifIvBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                app:cardBackgroundColor="@color/profile_card_bg"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_stat_icon"
                    android:padding="12dp"
                    app:srcCompat="@drawable/back"
                    app:tint="@color/profile_text_primary" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/adminNotifTvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:text="@string/admin_announcements_title"
                android:textColor="@color/profile_text_primary"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textSize="@dimen/text_size_subtitle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/adminNotifIvSettings"
                app:layout_constraintStart_toEndOf="@id/adminNotifIvBack"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminNotifIvSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                app:cardBackgroundColor="@color/profile_card_bg"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_stat_icon"
                    android:padding="12dp"
                    app:srcCompat="@drawable/settings"
                    app:tint="@color/profile_text_primary" />
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/profile_divider" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/adminNotifScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <!-- Compose Notification Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminNotifComposeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_admin_hero_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_meta_pill"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        android:paddingStart="10dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp"
                        android:text="@string/admin_announcements_compose_title"
                        android:textColor="@color/home_meta_text"
                        android:textSize="@dimen/text_size_overline"
                        android:layout_marginBottom="14dp" />

                    <!-- Title field -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/adminNotifCardTitle"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="10dp"
                        app:cardBackgroundColor="@color/overlay_white_8"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <EditText
                            android:id="@+id/adminNotifEtTitle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:hint="@string/admin_announcements_title_hint"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textColorHint="@color/home_text_secondary"
                            android:textSize="@dimen/text_size_caption"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:inputType="text"
                            android:imeOptions="actionNext" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Message field -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/adminNotifCardMessage"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="@color/overlay_white_8"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <EditText
                            android:id="@+id/adminNotifEtMessage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:hint="@string/admin_announcements_message_hint"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="12dp"
                            android:gravity="top"
                            android:textColor="@android:color/white"
                            android:textColorHint="@color/home_text_secondary"
                            android:textSize="@dimen/text_size_caption"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:inputType="textMultiLine"
                            android:imeOptions="actionDone" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/admin_announcements_audience_label"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="@dimen/text_size_overline" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="@color/overlay_white_8"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <AutoCompleteTextView
                            android:id="@+id/adminNotifAudienceInput"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textColor="@android:color/white"
                            android:textColorHint="@color/home_text_secondary"
                            android:textSize="@dimen/text_size_caption"
                            android:fontFamily="@font/plus_jakarta_sans_regular"
                            android:inputType="none"
                            tools:text="Tous les utilisateurs" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Send Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/adminNotifBtnSend"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:text="@string/admin_announcements_publish"
                        android:textSize="@dimen/text_size_body"
                        app:backgroundTint="@color/home_surface_raised"
                        android:textColor="@color/home_text_primary"
                        app:cornerRadius="16dp"
                        app:strokeWidth="0dp" />

                    <TextView
                        android:id="@+id/adminNotifComposerStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/admin_announcements_status_idle"
                        android:textColor="@color/surface_warm_border"
                        android:textSize="@dimen/text_size_overline" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- History -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_announcements_history_title"
                android:textColor="@color/profile_text_primary"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textSize="@dimen/text_size_subtitle"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminNotifHistoryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/profile_card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/adminNotifHistoryEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="24dp"
                        android:text="@string/admin_announcements_empty"
                        android:textColor="@color/profile_text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:visibility="gone" />

                    <ProgressBar
                        android:id="@+id/adminNotifHistoryProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="24dp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/adminNotifHistoryList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_notification" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav -->
    <include
        layout="@layout/include_admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
