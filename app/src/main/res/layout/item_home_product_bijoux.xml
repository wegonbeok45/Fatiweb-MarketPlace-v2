<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProductBijoux"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/home_products_column_gap"
    android:layout_weight="1"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_product_image_height">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/home_product_surface"
            app:cardCornerRadius="@dimen/home_product_image_radius"
            app:cardElevation="@dimen/home_product_card_elevation"
            app:strokeWidth="@dimen/space_0">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/auto_text_063"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/product2example" />
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/btnFavoriteBijoux"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="end|top"
            android:layout_margin="8dp"
            android:background="@drawable/bg_home_product_heart">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/ic_home_heart"
                app:tint="@color/home_text_primary" />

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/ivFavoriteBijoux"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:contentDescription="@string/auto_text_064"
                app:lottie_rawRes="@raw/anim_heart"
                app:lottie_autoPlay="false"
                app:lottie_loop="false" />
        </FrameLayout>
    </FrameLayout>

    <TextView
        style="@style/HomeText.ProductName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_product_name_margin_top"
        android:ellipsize="end"
        android:maxLines="2"
        android:minLines="2"
        android:text="@string/auto_text_065" />

    <TextView
        style="@style/HomeText.ProductSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_product_subtitle_margin_top"
        android:ellipsize="end"
        android:maxLines="1"
        android:minLines="1"
        android:text="@string/auto_text_066" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_product_price_row_height"
        android:layout_marginTop="@dimen/home_product_price_row_margin_top"
        android:gravity="bottom|center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="bottom"
            android:orientation="horizontal">

            <TextView
                style="@style/HomeText.ProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/price_amount_bijoux" />

            <TextView
                style="@style/HomeText.ProductPriceUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_product_price_unit_margin_start"
                android:text="@string/currency_dt" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddCartBijoux"
            android:layout_width="@dimen/home_add_cart_button_width"
            android:layout_height="@dimen/home_add_cart_button_height"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:insetTop="@dimen/space_0"
            android:insetBottom="@dimen/space_0"
            android:insetLeft="@dimen/space_0"
            android:insetRight="@dimen/space_0"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="@string/home_add_to_cart_short"
            android:textAllCaps="false"
            android:textColor="@color/colorOnAccentDeep"
            android:textSize="10sp"
            app:backgroundTint="@color/home_add_cart_bg"
            app:cornerRadius="@dimen/home_add_cart_button_radius"
            app:icon="@drawable/ic_home_add_cart"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="@dimen/icon_size_small"
            app:iconTint="@color/colorOnAccentDeep"
            app:strokeWidth="@dimen/space_0" />
    </LinearLayout>
</LinearLayout>


