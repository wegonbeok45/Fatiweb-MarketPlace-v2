<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_body_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/app_top_bar_height"
        android:background="@color/profile_header_bg"
        android:paddingStart="@dimen/app_top_bar_horizontal_padding"
        android:paddingEnd="@dimen/app_top_bar_horizontal_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/app_top_bar_side_slot_size"
            android:layout_height="@dimen/app_top_bar_side_slot_size"
            android:contentDescription="@string/cd_back"
            android:padding="@dimen/surface_button_inner_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/back"
            app:tint="@color/profile_text_primary" />

        <TextView
            style="@style/AppTopBar.Title.Profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/about_curator_top_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="@dimen/profile_horizontal_margin"
            android:paddingTop="@dimen/space_24"
            android:paddingEnd="@dimen/profile_horizontal_margin">

            <LinearLayout
                android:id="@+id/layoutBrandBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardBackgroundColor="@color/home_search_bg"
                    app:cardCornerRadius="@dimen/corner_radius_large"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/manrope_semibold"
                        android:gravity="center"
                        android:text="@string/about_curator_mark"
                        android:textColor="@color/profile_text_primary"
                        android:textSize="24sp" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_12"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/app_name"
                    android:textColor="@color/profile_text_primary"
                    android:textSize="@dimen/text_size_subtitle" />

                <TextView
                    android:id="@+id/tvAboutVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/profile_text_secondary"
                    android:textSize="@dimen/text_size_caption" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_16"
                    android:gravity="center"
                    android:text="@string/about_curator_description"
                    android:textColor="@color/profile_text_secondary"
                    android:textSize="@dimen/text_size_body" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAboutPrimaryLinks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_20"
                android:orientation="vertical">

                <include layout="@layout/layout_about_links_primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAboutSecondaryLinks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="vertical">

                <include layout="@layout/layout_about_links_secondary" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/about_curator_footer"
                android:textColor="@color/profile_text_secondary"
                android:textSize="@dimen/text_size_caption" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

