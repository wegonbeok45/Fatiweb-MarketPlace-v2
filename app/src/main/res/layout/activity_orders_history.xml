<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/profile_top_bar_height"
        android:background="@color/home_nav_bg"
        android:paddingStart="@dimen/profile_horizontal_margin"
        android:paddingEnd="@dimen/profile_horizontal_margin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/profile_top_bar_icon_size"
            android:layout_height="@dimen/profile_top_bar_icon_size"
            android:contentDescription="@string/details_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/back"
            app:tint="@color/home_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/orders_history_title"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_subtitle"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar">

        <LinearLayout
            android:id="@+id/layoutEmptyOrdersState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="40dp"
            android:paddingBottom="24dp"
            android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="168dp"
                    android:layout_height="168dp"
                    app:cardBackgroundColor="@color/home_surface_raised"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorOutline"
                    app:strokeWidth="1dp">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/ivEmptyOrdersAnimation"
                        android:layout_width="132dp"
                        android:layout_height="132dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_back"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        app:lottie_rawRes="@raw/anim_empty_orders" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvEmptyOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center"
                    android:text="@string/orders_history_empty"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />

                <TextView
                    android:id="@+id/tvEmptyOrdersSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/orders_history_empty_subtitle"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_caption" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOrdersBrowseHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/orders_history_empty_action"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:paddingHorizontal="32dp"
                    app:backgroundTint="?attr/colorPrimary"
                    app:cornerRadius="26dp"
                    app:elevation="0dp" />
            </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrders"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/loadingIndicator"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

