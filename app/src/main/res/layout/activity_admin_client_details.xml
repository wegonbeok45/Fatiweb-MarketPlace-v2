<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_header_bg"
    tools:context=".AdminClientDetailsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/adminClientDetailsAppBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/adminClientDetailsIvBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_shell_action_chip"
                android:contentDescription="@string/admin_back"
                android:padding="12dp"
                android:src="@drawable/back"
                app:tint="@color/profile_text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/admin_client_details_title"
                android:textColor="@color/profile_text_primary"
                android:textSize="20sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/adminClientDetailsProgress"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/profile_section_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <ImageView
                            android:id="@+id/adminClientDetailsAvatar"
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:background="@drawable/bg_admin_avatar_frame"
                            android:contentDescription="@string/cd_profile_avatar"
                            android:padding="3dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/profile_avatar_art" />

                        <TextView
                            android:id="@+id/adminClientDetailsName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:fontFamily="@font/poppins_semibold"
                            android:gravity="center"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="22sp"
                            tools:text="Mohmed Gnounou" />

                        <TextView
                            android:id="@+id/adminClientDetailsEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="14sp"
                            tools:text="client@email.com" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/adminClientDetailsRole"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_admin_client_chip"
                                android:fontFamily="@font/poppins_medium"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:textColor="@color/profile_text_primary"
                                android:textSize="13sp"
                                tools:text="Client" />

                            <TextView
                                android:id="@+id/adminClientDetailsStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:background="@drawable/bg_admin_client_chip"
                                android:fontFamily="@font/poppins_medium"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:textColor="@color/profile_text_primary"
                                android:textSize="13sp"
                                tools:text="Actif" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="96dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/profile_card_bg"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/profile_section_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/adminClientDetailsTotalOrders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_semibold"
                                android:textColor="@color/profile_text_primary"
                                android:textSize="24sp"
                                tools:text="12" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/admin_client_details_total_orders"
                                android:textColor="@color/profile_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="96dp"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/profile_card_bg"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/profile_section_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:id="@+id/adminClientDetailsJoined"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:fontFamily="@font/poppins_semibold"
                                android:gravity="center"
                                android:maxLines="1"
                                android:textColor="@color/profile_text_primary"
                                android:textSize="15sp"
                                tools:text="13 mai 2026" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/admin_client_details_joined"
                                android:textColor="@color/profile_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/profile_section_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semibold"
                            android:text="@string/admin_client_details_contact_block"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/adminClientDetailsPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="14sp"
                            tools:text="+216 22 222 222" />

                        <TextView
                            android:id="@+id/adminClientDetailsAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="2dp"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="14sp"
                            tools:text="Tunis, Ariana\n1000 - +216..." />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/adminClientDetailsContact"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:text="@string/admin_client_contact"
                                android:textAllCaps="false"
                                android:textColor="@color/colorPrimary"
                                app:cornerRadius="16dp"
                                app:strokeColor="@color/colorOutline" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/adminClientDetailsPromote"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="@string/admin_client_make_vendeur"
                                android:textAllCaps="false"
                                app:backgroundTint="@color/colorPrimary"
                                app:cornerRadius="16dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/adminClientDetailsRevoke"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="@string/admin_client_revoke_vendeur"
                                android:textAllCaps="false"
                                android:textColor="@color/colorError"
                                android:visibility="gone"
                                app:cornerRadius="16dp"
                                app:strokeColor="@color/colorError" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/profile_section_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semibold"
                            android:text="@string/admin_client_details_order_history"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="16sp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/adminClientDetailsOrdersList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            tools:itemCount="3"
                            tools:listitem="@layout/item_admin_client_order_history" />

                        <TextView
                            android:id="@+id/adminClientDetailsOrdersEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="18dp"
                            android:text="@string/admin_client_details_no_orders"
                            android:textColor="@color/profile_text_secondary"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
