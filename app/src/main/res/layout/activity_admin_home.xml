<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminHomeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".AdminHomeActivity">

    <!-- ============ Top app bar ============ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminHomeAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/ms_top_bar_height"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20">

            <TextView
                android:id="@+id/adminHomeTitle"
                style="@style/Ms.Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/admin_home_title"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/adminHomeBell"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/adminHomeBell"
                android:layout_width="@dimen/ms_min_touch"
                android:layout_height="@dimen/ms_min_touch"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/ms_section_notifications"
                android:focusable="true"
                android:padding="11dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_admin_nav_notifications"
                app:tint="@color/ms_text_primary" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ============ Scrollable content ============ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/adminHomeScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="96dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:paddingTop="@dimen/space_4">

            <!-- ====== Hero card ====== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminHomeHero"
                style="@style/Ms.Card.Hero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_20">

                    <TextView
                        style="@style/Ms.Text.Overline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_home_hero_eyebrow"
                        android:textColor="@color/ms_accent_gold_soft" />

                    <TextView
                        android:id="@+id/adminHomeHeroTitle"
                        style="@style/Ms.Text.Display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="@string/admin_home_hero_title"
                        android:textColor="@color/ms_text_inverse"
                        android:textSize="24sp" />

                    <TextView
                        android:id="@+id/adminHomeHeroSubtitle"
                        style="@style/Ms.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:text="@string/admin_home_hero_subtitle"
                        android:textColor="@color/ms_text_inverse_muted" />

                    <!-- Revenue + Orders row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Ms.Text.Overline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/vendor_home_kpi_revenue_label"
                                android:textColor="@color/ms_text_inverse_muted" />

                            <TextView
                                android:id="@+id/adminHomeHeroRevenue"
                                style="@style/Ms.Text.KpiValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/ms_text_inverse"
                                tools:text="12 450 DT" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Ms.Text.Overline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/admin_home_kpi_orders_label"
                                android:textColor="@color/ms_text_inverse_muted" />

                            <TextView
                                android:id="@+id/adminHomeHeroOrders"
                                style="@style/Ms.Text.KpiValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/ms_text_inverse"
                                tools:text="234" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ====== Pending approvals banner ====== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminHomePendingCard"
                style="@style/Ms.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:visibility="gone"
                tools:visibility="visible">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/space_16">

                    <ImageView
                        android:id="@+id/adminHomePendingIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/ms_bg_icon_chip_gold"
                        android:padding="8dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/ic_admin_nav_notifications"
                        app:tint="@color/ms_accent_gold" />

                    <TextView
                        android:id="@+id/adminHomePendingTitle"
                        style="@style/Ms.Text.Label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_12"
                        android:text="@string/admin_home_pending_approvals_title"
                        app:layout_constraintEnd_toStartOf="@id/adminHomePendingCta"
                        app:layout_constraintStart_toEndOf="@id/adminHomePendingIcon"
                        app:layout_constraintTop_toTopOf="@id/adminHomePendingIcon" />

                    <TextView
                        android:id="@+id/adminHomePendingCount"
                        style="@style/Ms.Text.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_12"
                        android:textColor="@color/ms_text_secondary"
                        app:layout_constraintBottom_toBottomOf="@id/adminHomePendingIcon"
                        app:layout_constraintEnd_toStartOf="@id/adminHomePendingCta"
                        app:layout_constraintStart_toEndOf="@id/adminHomePendingIcon"
                        app:layout_constraintTop_toBottomOf="@id/adminHomePendingTitle"
                        tools:text="3 demande(s) vendeur" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/adminHomePendingCta"
                        style="@style/Ms.Button.Ghost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_home_pending_approvals_cta"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ====== Section: Overview ====== -->
            <include
                android:id="@+id/adminHomeOverviewHeader"
                layout="@layout/ms_component_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24" />

            <!-- KPI grid row 1: Users | Vendors -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal"
                android:weightSum="2">

                <include
                    android:id="@+id/adminHomeKpiUsers"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_6"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/adminHomeKpiVendors"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- KPI grid row 2: Products | Orders -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal"
                android:weightSum="2">

                <include
                    android:id="@+id/adminHomeKpiProducts"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_6"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/adminHomeKpiOrders"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- KPI grid row 3: Pending vendors | Low stock -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal"
                android:weightSum="2">

                <include
                    android:id="@+id/adminHomeKpiPendingVendors"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_6"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/adminHomeKpiLowStock"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- ====== Section: Quick actions ====== -->
            <include
                android:id="@+id/adminHomeActionsHeader"
                layout="@layout/ms_component_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="vertical">

                <include
                    android:id="@+id/adminHomeActionVendors"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_8" />

                <include
                    android:id="@+id/adminHomeActionUsers"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_8" />

                <include
                    android:id="@+id/adminHomeActionOrders"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_8" />

                <include
                    android:id="@+id/adminHomeActionAnalytics"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_8" />

                <include
                    android:id="@+id/adminHomeActionSettings"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ====== Section: Recent orders ====== -->
            <include
                android:id="@+id/adminHomeActivityHeader"
                layout="@layout/ms_component_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Ms.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/adminHomeActivityList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never" />

                    <include
                        android:id="@+id/adminHomeActivityEmpty"
                        layout="@layout/ms_component_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <include
                        android:id="@+id/adminHomeActivityError"
                        layout="@layout/ms_component_error_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/adminHomeActivityLoading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/ms_bg_skeleton_block" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="@dimen/space_8"
                            android:background="@drawable/ms_bg_skeleton_block" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="@dimen/space_8"
                            android:background="@drawable/ms_bg_skeleton_block" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ============ Bottom nav ============ -->
    <include
        layout="@layout/include_admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
