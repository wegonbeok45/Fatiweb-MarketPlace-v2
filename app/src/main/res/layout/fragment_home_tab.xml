<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/layoutTopSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintWidth_max="800dp"
        android:background="@color/colorSurface"
        android:elevation="@dimen/home_header_elevation"
        android:orientation="vertical"
        android:paddingBottom="@dimen/home_top_section_bottom_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/home_horizontal_padding"
            android:layout_marginTop="@dimen/home_top_bar_top_margin"
            android:layout_marginEnd="@dimen/home_horizontal_padding">

            <TextView
                android:id="@+id/tvBrand"
                style="@style/HomeText.Brand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_brand_start_margin"
                android:text="@string/auto_fatiweb_a4a8"
                android:textColor="@color/home_text_primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/layoutTopActions"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/layoutTopActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="@id/tvBrand"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvBrand">

                <FrameLayout
                    android:id="@+id/ivTopCart"
                    android:layout_width="@dimen/home_action_touch_size"
                    android:layout_height="@dimen/home_action_touch_size">

                    <ImageView
                        android:id="@+id/ivTopCartIcon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/home_action_icon_padding"
                        android:contentDescription="@string/cd_nav_cart"
                        app:srcCompat="@drawable/ic_bottom_nav_cart"
                        app:tint="@color/home_text_primary" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTopCartBadge"
                        android:layout_width="@dimen/main_bottom_badge_size"
                        android:layout_height="@dimen/main_bottom_badge_size"
                        android:layout_gravity="end|top"
                        android:visibility="gone"
                        app:cardBackgroundColor="?attr/colorError"
                        app:cardCornerRadius="@dimen/corner_radius_round"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <TextView
                            android:id="@+id/tvTopCartBadge"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textColor="@color/colorOnError"
                            android:textSize="@dimen/text_size_overline"
                            android:textStyle="bold"
                            tools:text="2" />
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>

                <ImageView
                    android:id="@+id/ivTopFavorites"
                    android:layout_width="@dimen/home_action_touch_size"
                    android:layout_height="@dimen/home_action_touch_size"
                    android:layout_marginStart="@dimen/home_action_gap"
                    android:padding="@dimen/home_action_icon_padding"
                    android:contentDescription="@string/cd_nav_favorites"
                    app:srcCompat="@drawable/ic_bottom_nav_favorites"
                    app:tint="@color/home_text_primary" />

                <FrameLayout
                    android:id="@+id/notificationContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/home_action_gap">

                    <ImageView
                        android:id="@+id/ivTopNotifications"
                        android:layout_width="@dimen/home_action_touch_size"
                        android:layout_height="@dimen/home_action_touch_size"
                        android:padding="@dimen/home_action_icon_padding"
                        android:contentDescription="@string/notifications_title"
                        app:srcCompat="@drawable/notification"
                        app:tint="@color/home_text_primary" />

                    <View
                        android:id="@+id/notificationBadge"
                        android:layout_width="@dimen/space_8"
                        android:layout_height="@dimen/space_8"
                        android:layout_gravity="end|top"
                        android:layout_marginTop="0dp"
                        android:layout_marginEnd="0dp"
                        android:background="@drawable/bg_notification_badge"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutSearchBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_search_height"
            android:layout_marginStart="@dimen/home_horizontal_padding"
            android:layout_marginTop="@dimen/home_search_margin_top"
            android:layout_marginEnd="@dimen/home_horizontal_padding"
            android:background="@drawable/bg_home_search"
            android:elevation="3dp"
            android:paddingStart="@dimen/home_search_padding_horizontal"
            android:paddingEnd="@dimen/home_search_padding_horizontal">

                <ImageView
                    android:id="@+id/ivSearch"
                    android:layout_width="@dimen/home_action_touch_size"
                    android:layout_height="@dimen/home_action_touch_size"
                    android:padding="@dimen/home_action_icon_padding"
                    android:contentDescription="@string/cd_search"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_profile_nav_search"
                app:tint="@color/home_text_secondary" />

            <TextView
                android:id="@+id/tvSearchHint"
                style="@style/HomeText.SearchHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_search_text_start"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/search_hint_products"
                android:textColor="@color/home_text_secondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivFilter"
                app:layout_constraintStart_toEndOf="@id/ivSearch"
                app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/ivFilter"
                    android:layout_width="@dimen/home_action_touch_size"
                    android:layout_height="@dimen/home_action_touch_size"
                    android:padding="@dimen/home_action_icon_padding"
                    android:contentDescription="@string/cd_filter"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_home_filter"
                app:tint="@color/home_text_primary" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollHomeContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_max="800dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/home_bottom_safe_content_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <HorizontalScrollView
                android:id="@+id/hsvAnnouncements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/home_horizontal_padding"
                    android:paddingEnd="@dimen/home_horizontal_padding">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBannerPrimary"
                        android:layout_width="@dimen/home_banner_primary_card_width"
                        android:layout_height="@dimen/home_banner_card_height"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/home_banner_card_radius"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_home_hero_primary"
                            android:orientation="vertical"
                            android:padding="@dimen/home_banner_inner_padding">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/home_banner_chip_height"
                                android:background="@drawable/bg_home_metric_chip"
                                android:gravity="center"
                                android:paddingStart="@dimen/home_banner_chip_padding_horizontal"
                                android:paddingEnd="@dimen/home_banner_chip_padding_horizontal"
                                android:text="@string/home_banner_primary_chip"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/text_size_overline"
                                android:textStyle="bold"
                                android:fontFamily="@font/plus_jakarta_sans_bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_16"
                                android:text="@string/home_banner_primary_title"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/text_size_title"
                                android:textStyle="bold"
                                android:fontFamily="@font/plus_jakarta_sans_bold"
                                android:lineSpacingExtra="0dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_8"
                                android:text="@string/home_banner_primary_subtitle"
                                android:textColor="@color/border_medium"
                                android:textSize="@dimen/text_size_caption"
                                android:fontFamily="@font/plus_jakarta_sans_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBannerSecondary"
                        android:layout_width="@dimen/home_banner_secondary_card_width"
                        android:layout_height="@dimen/home_banner_card_height"
                        android:layout_marginStart="@dimen/home_banner_gap"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/home_banner_card_radius"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_home_hero_secondary"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="@dimen/home_banner_inner_padding">

                            <ImageView
                                android:layout_width="@dimen/home_banner_icon_size"
                                android:layout_height="@dimen/home_banner_icon_size"
                                android:contentDescription="@string/cd_logo"
                                app:srcCompat="@drawable/ic_checkout_truck"
                                app:tint="@color/home_text_primary" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/home_banner_secondary_title_margin_top"
                                android:text="@string/home_banner_secondary_title"
                                android:textColor="@color/home_text_primary"
                                android:textSize="@dimen/text_size_title"
                                android:textStyle="bold"
                                android:fontFamily="@font/plus_jakarta_sans_bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/layoutBannerDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/home_banner_dots_margin_top"
                android:orientation="horizontal"
                android:visibility="gone">

                <View
                    android:id="@+id/dotBanner1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_home_banner_dot_active" />

                <View
                    android:id="@+id/dotBanner2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_home_banner_dot_inactive" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutFeatureStrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:background="@drawable/bg_home_feature_strip"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:elevation="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_feature_count"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_body"
                        android:textStyle="bold"
                        android:fontFamily="@font/plus_jakarta_sans_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/home_feature_subtitle"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:fontFamily="@font/plus_jakarta_sans_regular" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_trusted_label"
                    android:textColor="@color/home_text_primary"
                    android:background="@drawable/bg_home_metric_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textSize="@dimen/text_size_overline"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/HomeText.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_section_categories" />

                <TextView
                    android:id="@+id/tvCategoriesSeeAll"
                    style="@style/HomeText.SectionAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_see_all" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_category_tile_height"
                android:layout_marginTop="@dimen/home_category_list_margin_top"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="@dimen/home_horizontal_padding"
                android:paddingEnd="@dimen/home_horizontal_padding"
                android:scrollbars="none" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="28dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvFeaturedProductsTitle"
                    style="@style/HomeText.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_section_featured" />

                <TextView
                    android:id="@+id/tvFeaturedProductsSeeAll"
                    style="@style/HomeText.SectionAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_see_all" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/layoutFeaturedShimmer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:columnCount="2"
                android:visibility="gone">
                <include layout="@layout/item_product_card_shimmer" />
                <include layout="@layout/item_product_card_shimmer" />
                <include layout="@layout/item_product_card_shimmer" />
                <include layout="@layout/item_product_card_shimmer" />
            </GridLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeaturedProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:nestedScrollingEnabled="false"
                tools:itemCount="2"
                tools:listitem="@layout/item_home_catalog_product" />

            <TextView
                android:id="@+id/tvFeaturedProductsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:background="@drawable/bg_home_empty_state_panel"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:paddingStart="24dp"
                android:paddingTop="20dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp"
                android:text="@string/home_section_empty"
                android:textColor="@color/profile_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFeaturedProductsRefresh"
                style="@style/AppButton.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="@string/home_refresh_catalog"
                android:textAllCaps="false"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="28dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvLatestProductsTitle"
                    style="@style/HomeText.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_section_latest" />

                <TextView
                    android:id="@+id/tvLatestProductsSeeAll"
                    style="@style/HomeText.SectionAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_see_all" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/layoutLatestShimmer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:columnCount="2"
                android:visibility="gone">
                <include layout="@layout/item_product_card_shimmer" />
                <include layout="@layout/item_product_card_shimmer" />
                <include layout="@layout/item_product_card_shimmer" />
                <include layout="@layout/item_product_card_shimmer" />
            </GridLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLatestProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="@dimen/home_horizontal_padding"
                android:paddingEnd="@dimen/home_horizontal_padding"
                tools:itemCount="2"
                tools:listitem="@layout/item_home_catalog_product" />

            <TextView
                android:id="@+id/tvLatestProductsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:background="@drawable/bg_home_empty_state_panel"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:paddingStart="24dp"
                android:paddingTop="20dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp"
                android:text="@string/home_section_empty"
                android:textColor="@color/profile_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLatestProductsRefresh"
                style="@style/AppButton.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="@string/home_refresh_catalog"
                android:textAllCaps="false"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="28dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDiscoverProductsTitle"
                    style="@style/HomeText.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_section_discover" />

                <TextView
                    android:id="@+id/tvDiscoverProductsSeeAll"
                    style="@style/HomeText.SectionAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_see_all" />
            </LinearLayout>

            <GridLayout
                android:id="@+id/layoutDiscoverShimmer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:columnCount="2"
                android:visibility="gone">
                <include layout="@layout/item_product_card_shimmer" />
                <include layout="@layout/item_product_card_shimmer" />
                <include layout="@layout/item_product_card_shimmer" />
                <include layout="@layout/item_product_card_shimmer" />
            </GridLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDiscoverProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:nestedScrollingEnabled="false"
                tools:itemCount="2"
                tools:listitem="@layout/item_home_catalog_product" />

            <TextView
                android:id="@+id/tvDiscoverProductsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:background="@drawable/bg_home_empty_state_panel"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:paddingStart="24dp"
                android:paddingTop="20dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp"
                android:text="@string/home_section_empty"
                android:textColor="@color/profile_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDiscoverProductsRefresh"
                style="@style/AppButton.Secondary"
                android:layout_width="wrap_content"
