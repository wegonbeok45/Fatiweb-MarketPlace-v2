<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/layoutTopSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/home_nav_bg"
        android:elevation="@dimen/home_header_elevation"
        android:orientation="vertical"
        android:paddingBottom="@dimen/home_top_section_bottom_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/home_horizontal_padding"
            android:layout_marginTop="@dimen/home_top_spacing"
            android:layout_marginEnd="@dimen/home_horizontal_padding">

            <ImageView
                android:id="@+id/ivHomeLogo"
                android:layout_width="@dimen/home_logo_width"
                android:layout_height="@dimen/home_logo_height"
                android:contentDescription="@string/auto_text_001"
                android:scaleType="fitCenter"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/fatiweblogo" />

            <TextView
                android:id="@+id/tvBrand"
                style="@style/HomeText.Brand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_brand_start_margin"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/auto_text_002"
                app:layout_constraintBottom_toBottomOf="@id/ivHomeLogo"
                app:layout_constraintEnd_toStartOf="@id/layoutTopActions"
                app:layout_constraintStart_toEndOf="@id/ivHomeLogo"
                app:layout_constraintTop_toTopOf="@id/ivHomeLogo" />

            <LinearLayout
                android:id="@+id/layoutTopActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="@id/ivHomeLogo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivHomeLogo">

                <FrameLayout
                    android:id="@+id/ivTopCart"
                    android:layout_width="@dimen/home_action_icon_size"
                    android:layout_height="@dimen/home_action_icon_size">

                    <ImageView
                        android:id="@+id/ivTopCartIcon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/auto_text_003"
                        app:srcCompat="@drawable/ic_bottom_nav_cart"
                        app:tint="@color/home_text_primary" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTopCartBadge"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="end|top"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/colorError"
                        app:cardCornerRadius="@dimen/corner_radius_round"
                        app:cardElevation="@dimen/space_0"
                        app:strokeWidth="@dimen/space_0">

                        <TextView
                            android:id="@+id/tvTopCartBadge"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textColor="@color/colorOnError"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            tools:text="2" />
                    </com.google.android.material.card.MaterialCardView>

                </FrameLayout>



                <FrameLayout
                    android:id="@+id/notificationContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/home_action_gap">

                    <ImageView
                        android:id="@+id/ivTopNotifications"
                        android:layout_width="@dimen/home_action_icon_size"
                        android:layout_height="@dimen/home_action_icon_size"
                        android:contentDescription="@string/notifications_title"
                        app:srcCompat="@drawable/notification"
                        app:tint="@color/home_text_primary" />

                    <View
                        android:id="@+id/notificationBadge"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="end|top"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_notification_badge"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutSearchBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_search_height"
            android:layout_marginStart="@dimen/home_horizontal_padding"
            android:layout_marginTop="@dimen/home_search_margin_top"
            android:layout_marginEnd="@dimen/home_horizontal_padding"
            android:background="@drawable/bg_home_search"
            android:paddingStart="@dimen/home_search_padding_horizontal"
            android:paddingEnd="@dimen/home_search_padding_horizontal">

            <ImageView
                android:id="@+id/ivSearch"
                android:layout_width="@dimen/home_action_icon_size"
                android:layout_height="@dimen/home_action_icon_size"
                android:contentDescription="@string/auto_text_004"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_profile_nav_search"
                app:tint="@color/home_text_secondary" />

            <TextView
                android:id="@+id/tvSearchHint"
                style="@style/HomeText.SearchHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_search_text_start"
                android:ellipsize="end"
                android:maxLines="1"
                android:singleLine="true"
                android:text="@string/auto_text_005"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivFilter"
                app:layout_constraintStart_toEndOf="@id/ivSearch"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivFilter"
                android:layout_width="@dimen/home_action_icon_size"
                android:layout_height="@dimen/home_action_icon_size"
                android:contentDescription="@string/auto_text_006"
                android:scaleType="centerInside"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_home_filter"
                app:tint="@color/home_text_primary" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <View
        android:id="@+id/viewBottomDivider"
        android:layout_width="0dp"
        android:layout_height="@dimen/divider_height"
        android:visibility="gone"
        android:background="@color/profile_divider"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollHomeContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/home_scroll_content_bottom_padding"
        app:layout_constraintBottom_toTopOf="@id/viewBottomDivider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <HorizontalScrollView
                android:id="@+id/hsvAnnouncements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_banner_margin_top"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/home_horizontal_padding"
                    android:paddingEnd="@dimen/home_horizontal_padding">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBannerPrimary"
                        android:layout_width="@dimen/home_banner_primary_width"
                        android:layout_height="@dimen/home_banner_height"
                        app:cardCornerRadius="@dimen/home_banner_radius"
                        app:cardElevation="@dimen/space_0"
                        app:strokeWidth="@dimen/space_0">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_text_044"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/bg_home_banner_primary" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_home_banner_scrim" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom"
                                android:layout_margin="@dimen/home_banner_chip_margin"
                                android:orientation="vertical">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="@dimen/home_banner_chip_height"
                                    android:layout_marginBottom="@dimen/space_8"
                                    app:cardBackgroundColor="@color/home_chip_bg"
                                    app:cardCornerRadius="@dimen/home_banner_chip_radius"
                                    app:cardElevation="@dimen/space_0"
                                    app:strokeWidth="@dimen/space_0">

                                    <TextView
                                        style="@style/HomeText.BannerChip"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:paddingStart="@dimen/home_banner_chip_padding_horizontal"
                                        android:paddingEnd="@dimen/home_banner_chip_padding_horizontal"
                                        android:text="@string/auto_text_045" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    style="@style/HomeText.BannerTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_text_046" />

                                <TextView
                                    style="@style/HomeText.BannerSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_4"
                                    android:text="@string/auto_text_047" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBannerSecondary"
                        android:layout_width="@dimen/home_banner_secondary_width"
                        android:layout_height="@dimen/home_banner_height"
                        android:layout_marginStart="@dimen/home_banner_gap"
                        app:cardCornerRadius="@dimen/home_banner_radius"
                        app:cardElevation="@dimen/space_0"
                        app:strokeWidth="@dimen/space_0">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/auto_text_048"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/bg_home_banner_secondary" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_home_banner_scrim" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom|start"
                                android:layout_margin="@dimen/home_banner_chip_margin"
                                android:orientation="vertical">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="@dimen/home_banner_chip_height"
                                    android:layout_marginBottom="@dimen/space_8"
                                    app:cardBackgroundColor="@color/home_chip_bg"
                                    app:cardCornerRadius="@dimen/home_banner_chip_radius"
                                    app:cardElevation="@dimen/space_0"
                                    app:strokeWidth="@dimen/space_0">

                                    <TextView
                                        style="@style/HomeText.BannerChip"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_gravity="center"
                                        android:paddingStart="@dimen/home_banner_chip_padding_horizontal"
                                        android:paddingEnd="@dimen/home_banner_chip_padding_horizontal"
                                        android:text="@string/auto_text_049" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    style="@style/HomeText.BannerTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:text="@string/home_banner_secondary_title" />

                                <TextView
                                    style="@style/HomeText.BannerSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/space_4"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:text="@string/home_banner_secondary_subtitle" />
                            </LinearLayout>
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/layoutBannerDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <View
                    android:id="@+id/dotBanner1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_home_banner_dot_active" />

                <View
                    android:id="@+id/dotBanner2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_home_banner_dot_inactive" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="@dimen/home_section_margin_top"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/HomeText.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_text_050" />

                <TextView
                    android:id="@+id/tvCategoriesSeeAll"
                    style="@style/HomeText.SectionAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textAlignment="viewEnd"
                    android:text="@string/auto_text_051" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/hsvCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/home_category_list_margin_top"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/home_horizontal_padding"
                    android:paddingEnd="@dimen/home_horizontal_padding">

                    <include layout="@layout/item_home_category_chip" />
                    <include layout="@layout/item_home_category_chip_epices" />
                    <include layout="@layout/item_home_category_chip_vetements" />
                    <include layout="@layout/item_home_category_chip_deco" />
                    <include layout="@layout/item_home_category_chip_huiles" />
                    <include layout="@layout/item_home_category_chip" />
                    <include layout="@layout/item_home_category_chip_epices" />
                    <include layout="@layout/item_home_category_chip_vetements" />
                    <include layout="@layout/item_home_category_chip_deco" />
                    <include layout="@layout/item_home_category_chip_huiles" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                style="@style/HomeText.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="@dimen/home_section_margin_top"
                android:text="@string/auto_text_055" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="@dimen/home_products_grid_margin_top"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include layout="@layout/item_home_product_chechia" />
                    <include layout="@layout/item_home_product_bijoux" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/home_products_row_gap"
                    android:orientation="horizontal">

                    <include layout="@layout/item_home_product_marqoum" />
                    <include layout="@layout/item_home_product_balgha" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/layoutBottomNav"
        android:layout_width="0dp"
        android:layout_height="@dimen/profile_bottom_nav_height_exact"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

