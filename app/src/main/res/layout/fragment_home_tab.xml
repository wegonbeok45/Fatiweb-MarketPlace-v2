<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/layoutTopSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintWidth_max="800dp"
        android:background="@color/colorSurface"
        android:elevation="@dimen/home_header_elevation"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/home_horizontal_padding"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="@dimen/home_horizontal_padding">

            <ImageView
                android:id="@+id/ivHomeLogo"
                android:layout_width="40dp"
                android:layout_height="32dp"
                android:contentDescription="@string/cd_logo"
                android:scaleType="fitCenter"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/iconlogo" />

            <TextView
                android:id="@+id/tvBrand"
                style="@style/HomeText.Brand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/auto_fatiweb_a4a8"
                android:textColor="@color/home_text_primary"
                app:layout_constraintBottom_toBottomOf="@id/ivHomeLogo"
                app:layout_constraintEnd_toStartOf="@id/layoutTopActions"
                app:layout_constraintStart_toEndOf="@id/ivHomeLogo"
                app:layout_constraintTop_toTopOf="@id/ivHomeLogo" />

            <LinearLayout
                android:id="@+id/layoutTopActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="@id/ivHomeLogo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivHomeLogo">

                <FrameLayout
                    android:id="@+id/ivTopCart"
                    android:layout_width="24dp"
                    android:layout_height="24dp">

                    <ImageView
                        android:id="@+id/ivTopCartIcon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/auto_text_003"
                        app:srcCompat="@drawable/ic_bottom_nav_cart"
                        app:tint="@color/home_text_primary" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTopCartBadge"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="end|top"
                        android:visibility="gone"
                        app:cardBackgroundColor="?attr/colorError"
                        app:cardCornerRadius="@dimen/corner_radius_round"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <TextView
                            android:id="@+id/tvTopCartBadge"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textColor="@color/colorOnError"
                            android:textSize="@dimen/text_size_overline"
                            android:textStyle="bold"
                            tools:text="2" />
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>

                <ImageView
                    android:id="@+id/ivTopFavorites"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="16dp"
                    android:contentDescription="@string/auto_text_003"
                    app:srcCompat="@drawable/ic_bottom_nav_favorites"
                    app:tint="@color/home_text_primary" />

                <FrameLayout
                    android:id="@+id/notificationContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp">

                    <ImageView
                        android:id="@+id/ivTopNotifications"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/notifications_title"
                        app:srcCompat="@drawable/notification"
                        app:tint="@color/home_text_primary" />

                    <View
                        android:id="@+id/notificationBadge"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="end|top"
                        android:layout_marginTop="0dp"
                        android:layout_marginEnd="0dp"
                        android:background="@drawable/bg_notification_badge"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutSearchBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="@dimen/home_horizontal_padding"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="@dimen/home_horizontal_padding"
            android:background="@drawable/bg_home_search"
            android:elevation="2dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/ivSearch"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/auto_text_004"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_profile_nav_search"
                app:tint="@color/home_text_secondary" />

            <TextView
                android:id="@+id/tvSearchHint"
                style="@style/HomeText.SearchHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/auto_search_products_makers_or_3406"
                android:textColor="@color/home_text_secondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/ivFilter"
                app:layout_constraintStart_toEndOf="@id/ivSearch"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivFilter"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/auto_text_006"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_home_filter"
                app:tint="@color/home_text_primary" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollHomeContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_max="800dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <HorizontalScrollView
                android:id="@+id/hsvAnnouncements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/home_horizontal_padding"
                    android:paddingEnd="@dimen/home_horizontal_padding">

                    <!-- Banner card widths are fixed dp for now; consider percent-of-screen or weighted widths for better tablet / foldable compatibility. -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBannerPrimary"
                        android:layout_width="300dp"
                        android:layout_height="220dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_home_hero_primary"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="30dp"
                                android:background="@drawable/bg_home_metric_chip"
                                android:gravity="center"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:text="@string/auto_editors_pick_caf1"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/text_size_overline"
                                android:textStyle="bold"
                                android:fontFamily="@font/plus_jakarta_sans_bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:text="@string/auto_a_more_premium_way_75b9"
                                android:textColor="@android:color/white"
                                android:textSize="@dimen/text_size_title"
                                android:textStyle="bold"
                                android:fontFamily="@font/plus_jakarta_sans_bold"
                                android:lineSpacingExtra="0dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/auto_better_discovery_cleaner_checkout_4083"
                                android:textColor="@color/border_medium"
                                android:textSize="@dimen/text_size_caption"
                                android:fontFamily="@font/plus_jakarta_sans_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBannerSecondary"
                        android:layout_width="200dp"
                        android:layout_height="220dp"
                        android:layout_marginStart="16dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_home_hero_secondary"
                            android:gravity="bottom"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:contentDescription="@string/cd_logo"
                                app:srcCompat="@drawable/ic_checkout_truck"
                                app:tint="@color/home_text_primary" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:text="@string/auto_premium_browsing_6dc6"
                                android:textColor="@color/home_text_primary"
                                android:textSize="@dimen/text_size_title"
                                android:textStyle="bold"
                                android:fontFamily="@font/plus_jakarta_sans_bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/layoutBannerDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <View
                    android:id="@+id/dotBanner1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_home_banner_dot_active" />

                <View
                    android:id="@+id/dotBanner2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_home_banner_dot_inactive" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:background="@drawable/bg_home_feature_strip"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_350_curated_items_87fa"
                        android:textColor="@color/home_text_primary"
                        android:textSize="@dimen/text_size_body"
                        android:textStyle="bold"
                        android:fontFamily="@font/plus_jakarta_sans_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/auto_from_tunisias_finest_makers_352e"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="@dimen/text_size_caption"
                        android:fontFamily="@font/plus_jakarta_sans_regular" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_trusted_c040"
                    android:textColor="@color/home_text_primary"
                    android:background="@drawable/bg_home_metric_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:textSize="@dimen/text_size_overline"
                    android:textStyle="bold"
                    android:fontFamily="@font/plus_jakarta_sans_bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/HomeText.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_categories_af1b" />

                <TextView
                    android:id="@+id/tvCategoriesSeeAll"
                    style="@style/HomeText.SectionAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_see_all_453d" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/hsvCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/home_horizontal_padding"
                    android:paddingEnd="@dimen/home_horizontal_padding">

                    <include layout="@layout/item_home_category_chip" />
                    <include layout="@layout/item_home_category_chip_epices" />
                    <include layout="@layout/item_home_category_chip_vetements" />
                    <include layout="@layout/item_home_category_chip_deco" />
                    <include layout="@layout/item_home_category_chip_huiles" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvLatestProductsTitle"
                style="@style/HomeText.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="28dp"
                android:text="@string/auto_fresh_arrivals_1c94" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLatestProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:nestedScrollingEnabled="false"
                tools:itemCount="2"
                tools:listitem="@layout/item_home_catalog_product" />

            <TextView
                android:id="@+id/tvLatestProductsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:gravity="center"
                android:text="@string/home_section_empty"
                android:textColor="@color/profile_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLatestProductsRefresh"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:text="@string/auto_refresh_catalog_0ae2"
                android:textAllCaps="false"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDiscoverProductsTitle"
                style="@style/HomeText.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="28dp"
                android:text="@string/auto_curated_for_you_d4ea" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDiscoverProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:nestedScrollingEnabled="false"
                tools:itemCount="2"
                tools:listitem="@layout/item_home_catalog_product" />

            <TextView
                android:id="@+id/tvDiscoverProductsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_horizontal_padding"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="@dimen/home_horizontal_padding"
                android:gravity="center"
                android:text="@string/home_section_empty"
                android:textColor="@color/profile_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDiscoverProductsRefresh"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:text="@string/auto_discover_more_0653"
                android:textAllCaps="false"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/layoutBottomNav"
        android:layout_width="0dp"
        android:layout_height="@dimen/profile_bottom_nav_height_exact"
        app:layout_constraintWidth_max="800dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
