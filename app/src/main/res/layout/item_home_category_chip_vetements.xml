<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itemCategoryVetements"
    android:layout_width="@dimen/home_category_tile_width"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/home_category_tile_height"
    android:layout_marginEnd="@dimen/space_12"
    android:background="@drawable/bg_home_category_tile"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="@dimen/home_category_tile_padding"
    android:paddingTop="@dimen/home_category_tile_padding"
    android:paddingEnd="@dimen/home_category_tile_padding"
    android:paddingBottom="@dimen/home_category_tile_padding">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="@dimen/home_category_icon_tile_size"
        android:layout_height="@dimen/home_category_icon_tile_size"
        app:cardBackgroundColor="@color/home_category_bg"
        app:cardCornerRadius="@dimen/home_category_icon_tile_radius"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:layout_width="@dimen/home_category_icon_size"
            android:layout_height="@dimen/home_category_icon_size"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_category"
            app:srcCompat="@drawable/ic_home_cat_vetements"
            app:tint="@color/home_category_icon" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        style="@style/HomeText.CategoryLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_category_label_margin_top"
        android:gravity="center"
        android:maxLines="2"
        android:text="@string/auto_text_053"
        android:textAlignment="center"
        android:textColor="@color/home_text_primary" />
</LinearLayout>
