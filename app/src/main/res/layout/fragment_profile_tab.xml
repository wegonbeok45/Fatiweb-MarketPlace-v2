<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_body_bg"
    tools:context=".user">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/app_top_bar_height"
        android:background="@color/profile_header_bg"
        android:paddingStart="@dimen/app_top_bar_horizontal_padding"
        android:paddingEnd="@dimen/app_top_bar_horizontal_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/app_top_bar_side_slot_size"
            android:layout_height="@dimen/app_top_bar_side_slot_size"
            android:contentDescription="@string/cd_back"
            android:padding="@dimen/surface_button_inner_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/back"
            app:tint="@color/profile_text_primary" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/AppTopBar.Title.Profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_tab_profile"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivNotifications"
            android:layout_width="@dimen/app_top_bar_side_slot_size"
            android:layout_height="@dimen/app_top_bar_side_slot_size"
            android:contentDescription="@string/cd_notifications"
            android:padding="@dimen/surface_button_inner_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/notification"
            app:tint="@color/profile_text_primary" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/viewTopDivider"
        android:layout_width="0dp"
        android:layout_height="@dimen/divider_height"
        android:background="@color/profile_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/profile_header_padding_top"
        android:paddingBottom="@dimen/profile_header_padding_bottom"
        android:background="@color/profile_header_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewTopDivider">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAvatar"
            android:layout_width="@dimen/profile_header_avatar_size"
            android:layout_height="@dimen/profile_header_avatar_size"
            app:cardCornerRadius="@dimen/profile_header_avatar_corner_radius"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_profile_avatar"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/profile_avatar_art" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEdit"
            android:layout_width="@dimen/profile_edit_button_size_exact"
            android:layout_height="@dimen/profile_edit_button_size_exact"
            android:layout_marginEnd="-4dp"
            android:layout_marginBottom="-4dp"
            app:cardBackgroundColor="?attr/colorPrimary"
            app:cardCornerRadius="@dimen/profile_header_edit_corner_radius"
            app:cardElevation="2dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/colorSurface"
            app:layout_constraintBottom_toBottomOf="@id/cardAvatar"
            app:layout_constraintEnd_toEndOf="@id/cardAvatar">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/ic_profile_edit"
                app:tint="@color/white"  android:contentDescription="@string/cd_edit" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvUserName"
            style="@style/ProfileText.Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/profile_name_margin_top_compact"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="@string/user_guest_name"
            android:textColor="@color/profile_text_primary"
            android:textSize="@dimen/text_size_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardAvatar" />

        <TextView
            android:id="@+id/tvAccountHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:gravity="center"
            android:maxLines="2"
            android:textColor="@color/profile_text_secondary"
            android:textSize="@dimen/text_size_caption"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutMeta"
            tools:text="guest@fatiweb.tn • Email vérifié" />

        <LinearLayout
            android:id="@+id/layoutMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:background="@drawable/bg_home_meta_pill"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_12"
            android:paddingTop="@dimen/space_8"
            android:paddingEnd="@dimen/space_12"
            android:paddingBottom="@dimen/space_8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvUserName">

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_signup_chip"
                android:textColor="@color/colorAccentDeep"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold"
                android:fontFamily="@font/plus_jakarta_sans_bold" />

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_notification_badge"
                android:backgroundTint="@color/profile_text_muted" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/profile_location_fallback"
                android:textColor="@color/profile_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:fontFamily="@font/plus_jakarta_sans_regular" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cardAdmin"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="@dimen/space_12"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/profile_admin_dashboard_action"
            android:textAllCaps="false"
            android:visibility="gone"
            app:backgroundTint="@color/profile_edit_bg"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_admin_shield"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/profile_edit_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAccountHint"
            app:rippleColor="@color/profile_card_icon_bg"
            app:strokeColor="@color/colorBorderLight"
            app:strokeWidth="1dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollProfileContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/profile_content_overlap_margin"
        android:background="@drawable/bg_profile_content"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="@dimen/profile_horizontal_margin"
        android:paddingTop="@dimen/space_12"
        android:paddingEnd="@dimen/profile_horizontal_margin"
        android:paddingBottom="@dimen/profile_menu_bottom_padding"
        app:layout_constraintBottom_toTopOf="@id/viewBottomDivider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/profile_section_bg"
                app:cardCornerRadius="@dimen/profile_menu_group_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/profile_section_stroke"
                app:strokeWidth="@dimen/stroke_width_default">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Orders -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardOrders"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivOrdersIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_bottom_nav_cart"
                            app:tint="@color/profile_text_primary"  android:contentDescription="@string/cd_nav_cart" />

                        <TextView
                            android:id="@+id/tvOrdersTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/auto_my_orders_f915"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivOrdersChevron"
                            app:layout_constraintStart_toEndOf="@id/ivOrdersIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivOrdersChevron"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/profile_chevron"  android:importantForAccessibility="no" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/profile_section_stroke" />

                    <!-- Addresses -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardAddresses"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivAddressesIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/map"
                            app:tint="@color/profile_text_primary"  android:contentDescription="@string/cd_location" />

                        <TextView
                            android:id="@+id/tvAddressesTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/auto_shipping_addresses_0511"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivAddressesChevron"
                            app:layout_constraintStart_toEndOf="@id/ivAddressesIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivAddressesChevron"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/profile_chevron"  android:importantForAccessibility="no" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/profile_section_stroke" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardAccountCenter"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivAccountCenterIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/cd_profile_avatar"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_nav_user"
                            app:tint="@color/profile_text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/profile_account_center_title"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivAccountCenterChevron"
                            app:layout_constraintStart_toEndOf="@id/ivAccountCenterIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivAccountCenterChevron"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:importantForAccessibility="no"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/profile_chevron" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/profile_section_stroke" />

                    <!-- Settings -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardSettings"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivSettingsIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/settings"
                            app:tint="@color/profile_text_primary"  android:contentDescription="@string/cd_settings" />

                        <TextView
                            android:id="@+id/tvSettingsTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/profile_settings_title"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivSettingsChevron"
                            app:layout_constraintStart_toEndOf="@id/ivSettingsIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivSettingsChevron"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/profile_chevron"  android:importantForAccessibility="no" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/profile_section_stroke" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardPrivacy"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivPrivacyIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/profile_privacy_title"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_admin_shield"
                            app:tint="@color/profile_text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/profile_privacy_title"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivPrivacyChevron"
                            app:layout_constraintStart_toEndOf="@id/ivPrivacyIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivPrivacyChevron"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:importantForAccessibility="no"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/profile_chevron" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/profile_section_stroke" />

                    <!-- Help -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardHelp"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivHelpIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_help"
                            app:tint="@color/profile_text_primary"  android:contentDescription="@string/cd_menu" />

                        <TextView
                            android:id="@+id/tvHelpTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/auto_help_center_efda"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivHelpChevron"
                            app:layout_constraintStart_toEndOf="@id/ivHelpIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivHelpChevron"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/profile_chevron"  android:importantForAccessibility="no" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cardLogout"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/profile_logout_height_exact"
                android:layout_marginTop="@dimen/profile_logout_top_margin_compact"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/auto_log_out_b0c2"
                android:textAllCaps="false"
                android:textSize="@dimen/text_size_body"
                app:backgroundTint="@color/profile_logout_bg"
                app:cornerRadius="@dimen/corner_radius_medium"
                app:icon="@drawable/ic_profile_logout"
                app:iconGravity="textStart"
                app:iconTint="@color/profile_logout_text"
                app:rippleColor="@color/profile_card_icon_bg"
                app:strokeColor="@color/profile_logout_border"
                app:strokeWidth="@dimen/stroke_width_default" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <View
        android:id="@+id/viewBottomDivider"
        android:layout_width="0dp"
        android:layout_height="@dimen/divider_height"
        android:visibility="gone"
        android:background="@color/profile_divider"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/layoutBottomNav"
        android:layout_width="0dp"
        android:layout_height="@dimen/profile_bottom_nav_height_exact"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
