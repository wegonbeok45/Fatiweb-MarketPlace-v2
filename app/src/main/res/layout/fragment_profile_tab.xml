<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".user">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutTopBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        android:paddingStart="@dimen/home_ref_horizontal_padding"
        android:paddingTop="@dimen/home_ref_top_padding"
        android:paddingEnd="@dimen/home_ref_horizontal_padding"
        android:paddingBottom="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@string/cd_back"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/back"
            app:tint="@color/ms_text_primary" />

        <TextView
            android:id="@+id/tvTopBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_semibold"
            android:includeFontPadding="false"
            android:text="@string/nav_tab_profile"
            android:textColor="@color/ms_text_primary"
            android:textSize="@dimen/ms_text_title"
            app:layout_constraintBottom_toBottomOf="@id/notificationContainer"
            app:layout_constraintEnd_toStartOf="@id/notificationContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/notificationContainer" />

        <FrameLayout
            android:id="@+id/notificationContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivNotifications"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_notifications"
                app:srcCompat="@drawable/notification"
                app:tint="@color/ms_text_secondary" />

            <View
                android:id="@+id/notificationBadge"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="9dp"
                android:layout_marginEnd="9dp"
                android:background="@drawable/bg_notification_badge"
                android:backgroundTint="@color/ms_accent_gold"
                android:visibility="gone" />
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/viewTopDivider"
        android:layout_width="0dp"
        android:layout_height="@dimen/divider_height"
        android:background="@color/ms_border_subtle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopBar" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_20"
        android:paddingTop="@dimen/profile_header_padding_top"
        android:paddingEnd="@dimen/space_20"
        android:paddingBottom="@dimen/profile_header_padding_bottom"
        android:background="@color/ms_surface_canvas"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewTopDivider">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAvatar"
            android:layout_width="88dp"
            android:layout_height="88dp"
            app:cardCornerRadius="44dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_profile_avatar"
                android:scaleType="centerCrop"
                android:background="@color/ms_surface_sunken"
                app:srcCompat="@drawable/profile_avatar_art" />

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/cardEdit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_edit_avatar"
            android:contentDescription="@string/cd_edit"
            android:elevation="@dimen/ms_elev_1"
            android:padding="7dp"
            android:translationX="2dp"
            android:translationY="2dp"
            app:layout_constraintBottom_toBottomOf="@id/cardAvatar"
            app:layout_constraintEnd_toEndOf="@id/cardAvatar"
            app:srcCompat="@drawable/ic_profile_edit"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvUserName"
            style="@style/ProfileText.Name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/profile_name_margin_top_compact"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="@string/user_guest_name"
            android:textColor="@color/ms_text_primary"
            android:textSize="@dimen/ms_text_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardAvatar" />

        <TextView
            android:id="@+id/tvAccountHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:gravity="center"
            android:maxLines="2"
            android:textColor="@color/ms_text_secondary"
            android:textSize="@dimen/text_size_caption"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutMeta"
            tools:text="guest@fatiweb.tn â€¢ Email vÃ©rifiÃ©" />

        <LinearLayout
            android:id="@+id/layoutMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:background="@drawable/bg_home_meta_pill"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_12"
            android:paddingTop="@dimen/space_8"
            android:paddingEnd="@dimen/space_12"
            android:paddingBottom="@dimen/space_8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvUserName">

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_signup_chip"
                android:textColor="@color/colorAccentDeep"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_semibold" />

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_notification_badge"
                android:backgroundTint="@color/ms_text_tertiary" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/profile_location_fallback"
                android:textColor="@color/ms_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:fontFamily="@font/manrope_regular" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cardAdmin"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="@dimen/space_12"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:letterSpacing="0"
            android:text="@string/profile_admin_dashboard_action"
            android:textAllCaps="false"
            android:visibility="gone"
            app:backgroundTint="@color/ms_surface_inverse"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_admin_shield"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@color/ms_text_inverse"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvAccountHint"
            app:rippleColor="@color/ms_surface_sunken"
            app:strokeColor="@color/ms_border_default"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditProfileHeader"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:letterSpacing="0"
            android:text="@string/profile_edit_title"
            android:textAllCaps="false"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardAdmin" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollProfileContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/profile_content_overlap_margin"
        android:background="@drawable/bg_profile_content"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="@dimen/profile_horizontal_margin"
        android:paddingTop="@dimen/space_12"
        android:paddingEnd="@dimen/profile_horizontal_margin"
        android:paddingBottom="@dimen/profile_menu_bottom_padding"
        app:layout_constraintBottom_toTopOf="@id/viewBottomDivider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ms_surface_card"
                app:cardCornerRadius="@dimen/profile_menu_group_radius"
                app:cardElevation="0dp"
                app:strokeColor="@color/ms_border_subtle"
                app:strokeWidth="@dimen/stroke_width_default">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Orders -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardOrders"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivOrdersIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_orders_outline"
                            app:tint="@color/ms_text_primary"  android:contentDescription="@string/cd_nav_cart" />

                        <TextView
                            android:id="@+id/tvOrdersTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/profile_orders_label"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivOrdersChevron"
                            app:layout_constraintStart_toEndOf="@id/ivOrdersIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivOrdersChevron"
                            android:layout_width="@dimen/profile_chevron_touch_target"
                            android:layout_height="@dimen/profile_chevron_touch_target"
                            android:padding="@dimen/space_14"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary"  android:importantForAccessibility="no" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/ms_border_subtle" />

                    <!-- Addresses -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardAddresses"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivAddressesIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_map_outline"
                            app:tint="@color/ms_text_primary"  android:contentDescription="@string/cd_location" />

                        <TextView
                            android:id="@+id/tvAddressesTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/addresses_title"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivAddressesChevron"
                            app:layout_constraintStart_toEndOf="@id/ivAddressesIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivAddressesChevron"
                            android:layout_width="@dimen/profile_chevron_touch_target"
                            android:layout_height="@dimen/profile_chevron_touch_target"
                            android:padding="@dimen/space_14"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary"  android:importantForAccessibility="no" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/ms_border_subtle" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardAccountCenter"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivAccountCenterIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@string/cd_profile_avatar"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_user_outline"
                            app:tint="@color/ms_text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/profile_account_center_title"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivAccountCenterChevron"
                            app:layout_constraintStart_toEndOf="@id/ivAccountCenterIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivAccountCenterChevron"
                            android:layout_width="@dimen/profile_chevron_touch_target"
                            android:layout_height="@dimen/profile_chevron_touch_target"
                            android:padding="@dimen/space_14"
                            android:importantForAccessibility="no"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/ms_border_subtle" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnBecomeSeller"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivBecomeSellerIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@string/profile_become_seller"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/shoppingbag"
                            app:tint="@color/ms_text_primary" />

                        <TextView
                            android:id="@+id/tvBecomeSellerTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/profile_become_seller"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivBecomeSellerChevron"
                            app:layout_constraintStart_toEndOf="@id/ivBecomeSellerIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivBecomeSellerChevron"
                            android:layout_width="@dimen/profile_chevron_touch_target"
                            android:layout_height="@dimen/profile_chevron_touch_target"
                            android:importantForAccessibility="no"
                            android:padding="@dimen/space_14"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/ms_border_subtle" />

                    <!-- Settings -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardSettings"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivSettingsIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_settings_outline"
                            app:tint="@color/ms_text_primary"  android:contentDescription="@string/cd_settings" />

                        <TextView
                            android:id="@+id/tvSettingsTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/profile_settings_title"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivSettingsChevron"
                            app:layout_constraintStart_toEndOf="@id/ivSettingsIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivSettingsChevron"
                            android:layout_width="@dimen/profile_chevron_touch_target"
                            android:layout_height="@dimen/profile_chevron_touch_target"
                            android:padding="@dimen/space_14"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary"  android:importantForAccessibility="no" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/ms_border_subtle" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardPrivacy"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivPrivacyIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@string/profile_privacy_title"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_shield_outline"
                            app:tint="@color/ms_text_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/profile_privacy_title"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivPrivacyChevron"
                            app:layout_constraintStart_toEndOf="@id/ivPrivacyIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivPrivacyChevron"
                            android:layout_width="@dimen/profile_chevron_touch_target"
                            android:layout_height="@dimen/profile_chevron_touch_target"
                            android:padding="@dimen/space_14"
                            android:importantForAccessibility="no"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/ms_border_subtle" />

                    <!-- Help -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardHelp"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivHelpIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_help_outline"
                            app:tint="@color/ms_text_primary"  android:contentDescription="@string/cd_menu" />

                        <TextView
                            android:id="@+id/tvHelpTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/help_center_title"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivHelpChevron"
                            app:layout_constraintStart_toEndOf="@id/ivHelpIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivHelpChevron"
                            android:layout_width="@dimen/profile_chevron_touch_target"
                            android:layout_height="@dimen/profile_chevron_touch_target"
                            android:padding="@dimen/space_14"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary"  android:importantForAccessibility="no" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/ms_border_subtle" />

                    <!-- About -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cardAbout"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/profile_menu_item_height_compact"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:id="@+id/ivAboutIcon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@string/settings_about_title"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_help_outline"
                            app:tint="@color/ms_text_primary" />

                        <TextView
                            android:id="@+id/tvAboutTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/manrope_semibold"
                            android:text="@string/settings_about_title"
                            android:textColor="@color/ms_text_primary"
                            android:textSize="@dimen/text_size_body"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/ivAboutChevron"
                            app:layout_constraintStart_toEndOf="@id/ivAboutIcon"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/ivAboutChevron"
                            android:layout_width="@dimen/profile_chevron_touch_target"
                            android:layout_height="@dimen/profile_chevron_touch_target"
                            android:padding="@dimen/space_14"
                            android:importantForAccessibility="no"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutProfileQuickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWishlistQuick"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/ms_surface_card"
                    app:cardCornerRadius="@dimen/corner_radius_medium"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ms_border_subtle"
                    app:strokeWidth="@dimen/stroke_width_default" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardQuickAddresses"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="@dimen/space_8"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/ms_surface_card"
                    app:cardCornerRadius="@dimen/corner_radius_medium"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ms_border_subtle"
                    app:strokeWidth="@dimen/stroke_width_default" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardQuickSupport"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="@dimen/space_8"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/ms_surface_card"
                    app:cardCornerRadius="@dimen/corner_radius_medium"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ms_border_subtle"
                    app:strokeWidth="@dimen/stroke_width_default" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutProfileRecentlyViewedHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_semibold"
                    android:text="@string/profile_recently_viewed_title"
                    android:textColor="@color/ms_text_primary"
                    android:textSize="@dimen/text_size_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/profileRecentSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="@string/common_see_all"
                    android:textColor="@color/ms_text_primary"
                    android:textSize="@dimen/text_size_caption" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/profileRecentlyViewedScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/profileRecentlyViewedList"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/profileRecentlyViewedEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:text="@string/details_reviews_empty"
                android:textColor="@color/ms_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cardLogout"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="@dimen/profile_logout_height_exact"
                android:layout_marginTop="@dimen/profile_logout_top_margin_compact"
                android:fontFamily="@font/manrope_semibold"
                android:gravity="center"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.02"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/profile_logout"
                android:textAllCaps="false"
                android:textSize="@dimen/profile_text_size_logout"
                app:backgroundTint="@color/ms_surface_card"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_profile_logout"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="18dp"
                app:iconTint="@color/ms_text_primary"
                app:rippleColor="@color/ms_accent_gold_soft"
                app:strokeColor="@color/ms_border_default"
                app:strokeWidth="@dimen/stroke_width_default" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <View
        android:id="@+id/viewBottomDivider"
        android:layout_width="0dp"
        android:layout_height="@dimen/divider_height"
        android:visibility="gone"
        android:background="@color/ms_border_subtle"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/layoutBottomNav"
        android:layout_width="0dp"
        android:layout_height="@dimen/profile_bottom_nav_height_exact"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
