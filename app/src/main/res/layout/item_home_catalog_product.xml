<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/ms_surface_card"
    app:cardCornerRadius="@dimen/product_card_corner_radius"
    app:cardElevation="@dimen/product_card_elevation"
    app:strokeColor="@color/ms_border_subtle"
    app:strokeWidth="@dimen/ms_stroke_hairline">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/product_card_inner_padding"
        android:paddingTop="@dimen/product_card_inner_padding"
        android:paddingEnd="@dimen/product_card_inner_padding"
        android:paddingBottom="@dimen/product_card_content_padding_bottom">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/homeDynamicImageFrame"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:cardBackgroundColor="@color/product_card_image_surface"
            app:cardCornerRadius="@dimen/product_card_image_radius"
            app:cardElevation="@dimen/space_0"
            app:strokeWidth="@dimen/space_0"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/homeDynamicProductImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_product_image"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/placeholder" />

                <ImageView
                    android:id="@+id/homeDynamicFavoriteButton"
                    android:layout_width="@dimen/product_card_floating_button_size"
                    android:layout_height="@dimen/product_card_floating_button_size"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="@dimen/space_10"
                    android:layout_marginEnd="@dimen/space_10"
                    android:background="@drawable/bg_product_floating_circle"
                    android:contentDescription="@string/cd_favorite"
                    android:elevation="@dimen/product_card_elevation"
                    android:padding="@dimen/product_card_floating_button_padding"
                    app:srcCompat="@drawable/ic_home_heart"
                    app:tint="@color/ms_text_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/homeDynamicAddCartButton"
                    android:layout_width="@dimen/product_card_floating_button_size"
                    android:layout_height="@dimen/product_card_floating_button_size"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="@dimen/space_10"
                    android:layout_marginBottom="@dimen/space_10"
                    android:contentDescription="@string/details_add_to_cart"
                    android:insetLeft="@dimen/space_0"
                    android:insetTop="@dimen/space_0"
                    android:insetRight="@dimen/space_0"
                    android:insetBottom="@dimen/space_0"
                    android:minWidth="@dimen/space_0"
                    android:minHeight="@dimen/space_0"
                    android:padding="@dimen/product_card_floating_button_padding"
                    android:text=""
                    android:visibility="gone"
                    app:backgroundTint="@color/ms_surface_card"
                    app:cornerRadius="@dimen/product_card_floating_button_radius"
                    app:elevation="@dimen/product_card_elevation"
                    app:icon="@drawable/ic_home_add_cart"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/space_0"
                    app:iconSize="@dimen/product_card_chip_icon_size"
                    app:iconTint="@color/ms_text_primary"
                    app:rippleColor="@color/ms_ripple_on_light"
                    tools:visibility="visible" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/homeDynamicProductTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/product_card_content_padding_horizontal"
            android:layout_marginTop="@dimen/space_12"
            android:layout_marginEnd="@dimen/space_8"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_semibold"
            android:includeFontPadding="false"
            android:lineSpacingExtra="@dimen/space_2"
            android:maxLines="2"
            android:minLines="2"
            android:textColor="@color/ms_text_primary"
            android:textSize="@dimen/product_card_text_title"
            app:layout_constraintEnd_toStartOf="@id/homeDynamicProductPrice"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/homeDynamicImageFrame"
            tools:text="Spider Legacy Hoodie Green" />

        <TextView
            android:id="@+id/homeDynamicProductPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:layout_marginEnd="@dimen/product_card_content_padding_horizontal"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_bold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/ms_text_primary"
            android:textSize="@dimen/product_card_text_price"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/homeDynamicImageFrame"
            tools:text="52 DT" />

        <TextView
            android:id="@+id/homeDynamicProductPriceOriginal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="@dimen/product_card_content_padding_horizontal"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_semibold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/discount_strike_red"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/homeDynamicProductPrice"
            tools:text="65 DT"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/homeDynamicProductDiscountBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_10"
            android:layout_marginTop="@dimen/space_10"
            android:background="@drawable/bg_discount_badge"
            android:fontFamily="@font/manrope_bold"
            android:includeFontPadding="false"
            android:paddingStart="8dp"
            android:paddingTop="3dp"
            android:paddingEnd="8dp"
            android:paddingBottom="3dp"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/homeDynamicImageFrame"
            app:layout_constraintTop_toTopOf="@id/homeDynamicImageFrame"
            tools:text="-20%"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/homeDynamicProductOrigin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/product_card_content_padding_horizontal"
            android:layout_marginTop="@dimen/space_6"
            android:layout_marginEnd="@dimen/product_card_content_padding_horizontal"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_regular"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/ms_text_secondary"
            android:textSize="@dimen/product_card_text_seller"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/homeDynamicProductTitle"
            tools:text="Mohmed Gnounou" />

        <LinearLayout
            android:id="@+id/homeDynamicRatingRow"
            android:layout_width="0dp"
            android:layout_height="@dimen/product_card_chip_height"
            android:layout_marginStart="@dimen/product_card_content_padding_horizontal"
            android:layout_marginTop="@dimen/space_10"
            android:layout_marginEnd="@dimen/space_8"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toStartOf="@id/homeDynamicCategoryChip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/homeDynamicProductOrigin">

            <ImageView
                android:layout_width="@dimen/product_card_star_size"
                android:layout_height="@dimen/product_card_star_size"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_home_star"
                app:tint="@color/ms_accent_gold" />

            <TextView
                android:id="@+id/homeDynamicProductRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:ellipsize="end"
                android:fontFamily="@font/manrope_semibold"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/product_card_rating_text"
                android:textSize="@dimen/product_card_text_meta"
                tools:text="4.8 (12)" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeDynamicCategoryChip"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/product_card_chip_height"
            android:layout_marginEnd="@dimen/product_card_content_padding_horizontal"
            android:background="@drawable/bg_product_category_chip"
            android:gravity="center"
            android:maxWidth="@dimen/product_card_category_max_width"
            android:orientation="horizontal"
            android:paddingStart="@dimen/space_8"
            android:paddingEnd="@dimen/space_8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/homeDynamicRatingRow">

            <ImageView
                android:layout_width="@dimen/product_card_chip_icon_size"
                android:layout_height="@dimen/product_card_chip_icon_size"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_bottom_nav_categories"
                app:tint="@color/product_card_chip_text" />

            <TextView
                android:id="@+id/homeDynamicProductCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:ellipsize="end"
                android:fontFamily="@font/manrope_semibold"
                android:includeFontPadding="false"
                android:maxWidth="@dimen/product_card_category_text_max_width"
                android:maxLines="1"
                android:textColor="@color/product_card_chip_text"
                android:textSize="@dimen/product_card_text_meta"
                tools:text="Fashion" />
        </LinearLayout>

        <!-- Variant hints: color dots + size text (gone for plain products) -->
        <LinearLayout
            android:id="@+id/homeDynamicVariantHints"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/product_card_content_padding_horizontal"
            android:layout_marginTop="@dimen/space_8"
            android:layout_marginEnd="@dimen/product_card_content_padding_horizontal"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/homeDynamicRatingRow">

            <!-- Color dots injected programmatically (up to 4 + "+N") -->
            <LinearLayout
                android:id="@+id/homeDynamicColorDotsRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />

            <TextView
                android:id="@+id/homeDynamicSizeHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_8"
                android:ellipsize="end"
                android:fontFamily="@font/manrope_semibold"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/ms_text_tertiary"
                android:textSize="@dimen/product_card_text_meta"
                android:visibility="gone"
                tools:text="XS · S · M · L"
                tools:visibility="visible" />
        </LinearLayout>

        <View
            android:id="@+id/homeDynamicProductStockChip"
            android:layout_width="@dimen/space_0"
            android:layout_height="@dimen/space_0"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/homeDynamicProductSubtitle"
            android:layout_width="@dimen/space_0"
            android:layout_height="@dimen/space_0"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
