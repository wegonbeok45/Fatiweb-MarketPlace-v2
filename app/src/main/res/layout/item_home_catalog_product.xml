<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/home_divider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <!-- Image Container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/imageContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:cardBackgroundColor="@color/home_surface_raised"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:layout_constrainedHeight="true"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_max="220dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/homeDynamicProductImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="@string/auto_product_image_3c38"
                android:maxHeight="220dp"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- favorite toggle -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/homeDynamicFavoriteButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="6dp"
            app:cardBackgroundColor="@color/overlay_white_80"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="@id/imageContainer"
            app:layout_constraintTop_toTopOf="@id/imageContainer"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/homeDynamicFavoriteIcon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/ic_home_heart"
                app:tint="@color/home_text_primary"  android:contentDescription="@string/cd_product_image" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Availability -->
        <TextView
            android:id="@+id/homeDynamicProductStockText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Info Area -->
        <TextView
            android:id="@+id/homeDynamicProductOrigin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:letterSpacing="0.05"
            android:maxLines="1"
            android:textColor="@color/home_text_secondary"
            android:textSize="@dimen/text_size_overline"
            app:layout_constraintEnd_toStartOf="@id/homeDynamicProductRatingIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageContainer"
            tools:text="HAMMAMET" />

        <ImageView
            android:id="@+id/homeDynamicProductRatingIcon"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:contentDescription="@null"
            app:layout_constraintBottom_toBottomOf="@id/homeDynamicProductOrigin"
            app:layout_constraintEnd_toStartOf="@id/homeDynamicProductRating"
            app:layout_constraintTop_toTopOf="@id/homeDynamicProductOrigin"
            app:srcCompat="@drawable/ic_home_star"
            app:tint="@color/details_star" />

        <TextView
            android:id="@+id/homeDynamicProductRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_overline"
            app:layout_constraintBottom_toBottomOf="@id/homeDynamicProductOrigin"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/homeDynamicProductOrigin"
            tools:text="4.7" />

        <TextView
            android:id="@+id/homeDynamicProductTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:maxLines="1"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_caption"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/homeDynamicProductOrigin"
            tools:text="Fouta de Hammamet" />

        <TextView
            android:id="@+id/homeDynamicProductPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:textColor="?attr/colorPrimary"
            android:textSize="@dimen/text_size_caption"
            app:layout_constraintBottom_toBottomOf="@id/homeDynamicAddButton"
            app:layout_constraintEnd_toStartOf="@+id/homeDynamicAddButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/homeDynamicAddButton"
            tools:text="29.900 DT" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/homeDynamicAddButton"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="14dp"
            android:clickable="false"
            android:focusable="false"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="10dp"
            android:paddingTop="0dp"
            android:paddingEnd="10dp"
            android:paddingBottom="0dp"
            android:textAllCaps="false"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_overline"
            app:backgroundTint="@color/stock_chip_bg_available"
            app:cornerRadius="15dp"
            app:iconPadding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/homeDynamicProductTitle"
            app:rippleColor="@android:color/transparent"
            app:strokeWidth="0dp"
            tools:text="Available" />

        <!-- Compatibility Hooks -->
        <View
            android:id="@+id/homeDynamicProductStockChip"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/homeDynamicProductSubtitle"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
