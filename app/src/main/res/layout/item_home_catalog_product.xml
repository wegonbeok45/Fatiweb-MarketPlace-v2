<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="@dimen/corner_radius_medium"
    app:cardElevation="0dp"
    app:strokeColor="@color/colorBorderLight"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_product_image_height">

            <ImageView
                android:id="@+id/homeDynamicProductImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_product_image"
                android:scaleType="centerCrop"
                app:srcCompat="@drawable/placeholder" />

            <FrameLayout
                android:id="@+id/homeDynamicFavoriteButton"
                android:layout_width="@dimen/home_product_heart_size"
                android:layout_height="@dimen/home_product_heart_size"
                android:layout_gravity="top|end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/homeDynamicFavoriteIcon"
                    android:layout_width="@dimen/home_product_heart_icon_size"
                    android:layout_height="@dimen/home_product_heart_icon_size"
                    android:layout_gravity="center"
                    app:srcCompat="@drawable/ic_home_heart"
                    app:tint="@color/home_text_primary" />
            </FrameLayout>

            <TextView
                android:id="@+id/homeDynamicProductStockText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="@dimen/space_8"
                android:background="@drawable/bg_home_meta_pill"
                android:backgroundTint="@color/colorPrimary"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="@color/colorOnPrimary"
                android:textSize="9sp"
                android:visibility="gone"
                tools:text="NEW"
                tools:visibility="visible" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/home_product_info_min_height"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/space_8"
            android:paddingTop="@dimen/space_8"
            android:paddingBottom="@dimen/space_8">

            <TextView
                android:id="@+id/homeDynamicProductTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:lineSpacingMultiplier="1.2"
                android:maxLines="2"
                android:minLines="2"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_caption"
                tools:text="Premium Handcrafted Tunisian Fouta with Traditional Patterns" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:gravity="center_vertical"
                android:minHeight="20dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/homeDynamicProductOrigin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    android:maxLines="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_overline"
                    tools:text="Hammamet, Tunisia" />

                <ImageView
                    android:layout_width="@dimen/space_8"
                    android:layout_height="@dimen/space_8"
                    android:layout_marginEnd="@dimen/space_2"
                    app:srcCompat="@drawable/ic_home_star"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/homeDynamicProductRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_overline"
                    tools:text="4.9" />
            </LinearLayout>

            <TextView
                android:id="@+id/homeDynamicProductPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_body"
                tools:text="35.000 DT" />

        </LinearLayout>

        <View
            android:id="@+id/homeDynamicProductStockChip"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/homeDynamicProductSubtitle"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
