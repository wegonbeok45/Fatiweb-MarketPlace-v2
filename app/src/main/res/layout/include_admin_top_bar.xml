<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/admin_top_bar_height"
    android:paddingStart="@dimen/home_horizontal_padding"
    android:paddingTop="@dimen/space_8"
    android:paddingEnd="@dimen/home_horizontal_padding"
    android:paddingBottom="@dimen/space_8">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/adminIvBack"
        android:layout_width="@dimen/surface_button_size"
        android:layout_height="@dimen/surface_button_size"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:cardBackgroundColor="@color/profile_card_bg"
        app:cardCornerRadius="@dimen/surface_button_corner_radius"
        app:cardElevation="0dp"
        app:strokeColor="@color/colorBorderLight"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/cd_back"
            android:padding="@dimen/surface_button_inner_padding"
            app:srcCompat="@drawable/back"
            app:tint="@color/profile_text_primary" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/adminTopActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/adminIvBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/adminIvBack">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/adminIvSettings"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/profile_card_bg"
            app:cardCornerRadius="@dimen/surface_button_corner_radius"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorBorderLight"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_settings"
                android:padding="@dimen/surface_button_inner_padding"
                app:srcCompat="@drawable/settings"
                app:tint="@color/profile_text_primary" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/adminShieldBadge"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            android:layout_marginStart="@dimen/space_8"
            app:cardBackgroundColor="@color/profile_card_bg"
            app:cardCornerRadius="@dimen/surface_button_corner_radius"
            app:cardElevation="@dimen/space_0"
            app:strokeColor="@color/colorBorderLight"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_admin_dashboard"
                app:srcCompat="@drawable/ic_admin_shield"
                app:tint="?attr/colorPrimary" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <TextView
        android:id="@+id/adminTvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/admin_top_title_margin_start"
        android:layout_marginEnd="@dimen/space_12"
        android:ellipsize="end"
        android:fontFamily="@font/plus_jakarta_sans_bold"
        android:maxLines="1"
        android:textColor="@color/profile_text_primary"
        android:textSize="@dimen/text_size_subtitle"
        app:layout_constraintBottom_toBottomOf="@id/adminIvBack"
        app:layout_constraintEnd_toStartOf="@id/adminTopActions"
        app:layout_constraintStart_toEndOf="@id/adminIvBack"
        app:layout_constraintTop_toTopOf="@id/adminIvBack" />

</androidx.constraintlayout.widget.ConstraintLayout>
