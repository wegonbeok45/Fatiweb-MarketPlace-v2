<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/ms_surface_card"
    app:cardCornerRadius="@dimen/product_card_corner_radius"
    app:cardElevation="0dp"
    app:strokeColor="@color/ms_border_default"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_16"
        android:paddingTop="@dimen/space_16"
        android:paddingEnd="@dimen/space_16"
        android:paddingBottom="@dimen/space_16">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCartItemImage"
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardBackgroundColor="@color/home_surface_soft"
            app:cardCornerRadius="@dimen/corner_radius_medium"
            app:cardElevation="0dp"
            app:strokeColor="@color/ms_border_default"
            app:strokeWidth="1dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivCartItemImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/details_image_cd"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnRemoveItem"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/cd_delete"
            app:cardBackgroundColor="@color/home_surface_soft"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ms_border_default"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_delete"
                app:srcCompat="@drawable/ic_panier_delete"
                app:tint="@color/ms_text_primary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvCartItemTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_14"
            android:layout_marginEnd="@dimen/space_10"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_semibold"
            android:maxLines="2"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnRemoveItem"
            app:layout_constraintStart_toEndOf="@id/cardCartItemImage"
            app:layout_constraintTop_toTopOf="@id/cardCartItemImage"
            tools:text="Chechia Traditionnelle Rouge" />

        <TextView
            android:id="@+id/tvCartItemSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_6"
            android:layout_marginEnd="@dimen/space_10"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_regular"
            android:maxLines="1"
            android:textColor="@color/home_text_secondary"
            android:textSize="@dimen/text_size_caption"
            app:layout_constraintEnd_toStartOf="@id/btnRemoveItem"
            app:layout_constraintStart_toStartOf="@id/tvCartItemTitle"
            app:layout_constraintTop_toBottomOf="@id/tvCartItemTitle"
            tools:text="Laine pure, fabrication artisanale" />

        <TextView
            android:id="@+id/tvCartItemPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:layout_marginEnd="@dimen/space_10"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_semibold"
            android:maxLines="1"
            android:textColor="@color/ms_text_primary"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/layoutQty"
            app:layout_constraintStart_toStartOf="@id/tvCartItemTitle"
            app:layout_constraintBottom_toBottomOf="@id/cardCartItemImage"
            tools:text="45.500 DT" />

        <LinearLayout
            android:id="@+id/layoutQty"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/panier_qty_height"
            android:background="@drawable/bg_panier_qty_container"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:layout_constraintBottom_toBottomOf="@id/cardCartItemImage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCartItemPrice">

            <TextView
                android:id="@+id/btnQtyMinus"
                android:layout_width="@dimen/panier_qty_button_size"
                android:layout_height="@dimen/panier_qty_button_size"
                android:background="@drawable/bg_panier_qty_button"
                android:contentDescription="@string/cd_decrease_qty"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/common_minus"
                android:textColor="@color/panier_qty_symbol"
                android:textSize="@dimen/panier_text_size_qty"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQtyValue"
                android:layout_width="@dimen/panier_qty_value_width"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_semibold"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/checkout_step_number_1"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnQtyPlus"
                android:layout_width="@dimen/panier_qty_button_size"
                android:layout_height="@dimen/panier_qty_button_size"
                android:background="@drawable/bg_panier_qty_button"
                android:contentDescription="@string/cd_increase_qty"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/common_plus"
                android:textColor="@color/panier_qty_symbol"
                android:textSize="@dimen/panier_text_size_qty"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

