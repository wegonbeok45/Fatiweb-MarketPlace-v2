<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/home_surface_raised"
    app:cardCornerRadius="@dimen/corner_radius_large"
    app:cardElevation="0dp"
    app:strokeColor="@color/colorBorderLight"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/space_14"
        android:paddingTop="@dimen/space_14"
        android:paddingEnd="@dimen/space_14"
        android:paddingBottom="@dimen/space_14">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCartItemImage"
            android:layout_width="84dp"
            android:layout_height="84dp"
            app:cardBackgroundColor="@color/home_surface_soft"
            app:cardCornerRadius="@dimen/corner_radius_medium"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorBorderLight"
            app:strokeWidth="1dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivCartItemImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/details_image_cd"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnRemoveItem"
            android:layout_width="@dimen/surface_button_size"
            android:layout_height="@dimen/surface_button_size"
            android:contentDescription="@string/cd_delete"
            app:cardBackgroundColor="@color/home_surface_soft"
            app:cardCornerRadius="@dimen/surface_button_corner_radius"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorBorderLight"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_delete"
                app:srcCompat="@drawable/ic_panier_delete"
                app:tint="?attr/colorPrimary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvCartItemTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_12"
            android:layout_marginEnd="@dimen/space_10"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:maxLines="2"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnRemoveItem"
            app:layout_constraintStart_toEndOf="@id/cardCartItemImage"
            app:layout_constraintTop_toTopOf="@id/cardCartItemImage"
            tools:text="Chechia Traditionnelle Rouge" />

        <TextView
            android:id="@+id/tvCartItemSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            android:layout_marginEnd="@dimen/space_10"
            android:ellipsize="end"
            android:fontFamily="@font/plus_jakarta_sans_regular"
            android:maxLines="1"
            android:textColor="@color/home_text_secondary"
            android:textSize="@dimen/text_size_caption"
            app:layout_constraintEnd_toStartOf="@id/btnRemoveItem"
            app:layout_constraintStart_toStartOf="@id/tvCartItemTitle"
            app:layout_constraintTop_toBottomOf="@id/tvCartItemTitle"
            tools:text="Laine pure, fabrication artisanale" />

        <TextView
            android:id="@+id/tvCartItemPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_10"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:textColor="?attr/colorPrimary"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tvCartItemTitle"
            app:layout_constraintTop_toBottomOf="@id/tvCartItemSubtitle"
            tools:text="45.500 DT" />

        <LinearLayout
            android:id="@+id/layoutQty"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_home_meta_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/btnQtyMinus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_home_meta_pill"
                android:backgroundTint="?attr/colorPrimary"
                android:contentDescription="@string/cd_decrease_qty"
                android:gravity="center"
                android:text="@string/auto_text_102"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQtyValue"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:gravity="center"
                android:text="@string/auto_text_123"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_caption"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnQtyPlus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_home_meta_pill"
                android:backgroundTint="?attr/colorPrimary"
                android:contentDescription="@string/cd_increase_qty"
                android:gravity="center"
                android:text="@string/auto_text_103"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
