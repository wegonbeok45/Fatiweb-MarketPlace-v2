<?xml version="1.0" encoding="utf-8"?>
<!-- Horizontally scrolling filter row. Caller adds chips into msChipRowContainer. -->
<HorizontalScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:overScrollMode="never"
    android:paddingStart="@dimen/space_20"
    android:paddingEnd="@dimen/space_20"
    android:scrollbars="none">

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/msChipRowContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:layout_marginBottom="@dimen/space_4"
        app:singleLine="true"
        app:singleSelection="true"
        app:chipSpacingHorizontal="@dimen/space_8"
        xmlns:app="http://schemas.android.com/apk/res-auto" />
</HorizontalScrollView>
