<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/vendorHomeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".VendorHomeActivity">

    <!-- ============ Top app bar ============ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/vendorHomeAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/ms_top_bar_height"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20">

            <TextView
                android:id="@+id/vendorHomeTitle"
                style="@style/Ms.Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/vendor_home_title"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/vendorHomeBell"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/vendorHomeBell"
                android:layout_width="@dimen/ms_min_touch"
                android:layout_height="@dimen/ms_min_touch"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/ms_section_notifications"
                android:padding="11dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_admin_nav_notifications"
                app:tint="@color/ms_text_primary" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ============ Scrollable content ============ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/vendorHomeScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="96dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:paddingTop="@dimen/space_4">

            <!-- ====== Hero card ====== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/vendorHomeHero"
                style="@style/Ms.Card.Hero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_20">

                    <TextView
                        style="@style/Ms.Text.Overline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/vendor_home_hero_eyebrow"
                        android:textColor="@color/ms_accent_gold_soft" />

                    <TextView
                        android:id="@+id/vendorHomeHeroGreeting"
                        style="@style/Ms.Text.Display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:textColor="@color/ms_text_inverse"
                        android:textSize="24sp"
                        tools:text="Salut, Boutique Fati" />

                    <TextView
                        android:id="@+id/vendorHomeHeroSummary"
                        style="@style/Ms.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:textColor="@color/ms_text_inverse_muted"
                        tools:text="3 commandes en attente · 2 articles en rupture" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Ms.Text.Overline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/vendor_home_hero_revenue_mtd"
                                android:textColor="@color/ms_text_inverse_muted" />

                            <TextView
                                android:id="@+id/vendorHomeHeroRevenue"
                                style="@style/Ms.Text.KpiValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/ms_text_inverse"
                                tools:text="1 240 DT" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Ms.Text.Overline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/vendor_home_hero_orders_mtd"
                                android:textColor="@color/ms_text_inverse_muted" />

                            <TextView
                                android:id="@+id/vendorHomeHeroOrders"
                                style="@style/Ms.Text.KpiValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/ms_text_inverse"
                                tools:text="18" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ====== Section: Overview ====== -->
            <include
                android:id="@+id/vendorHomeOverviewHeader"
                layout="@layout/ms_component_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24" />

            <!-- KPI grid 2x2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal"
                android:weightSum="2">

                <include
                    android:id="@+id/vendorHomeKpiRevenue"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_6"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/vendorHomeKpiPending"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal"
                android:weightSum="2">

                <include
                    android:id="@+id/vendorHomeKpiLowStock"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_6"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/vendorHomeKpiProducts"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- ====== Section: Quick actions ====== -->
            <include
                android:id="@+id/vendorHomeActionsHeader"
                layout="@layout/ms_component_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="vertical">

                <include
                    android:id="@+id/vendorHomeActionAdd"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_8" />

                <include
                    android:id="@+id/vendorHomeActionProducts"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_8" />

                <include
                    android:id="@+id/vendorHomeActionOrders"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_8" />

                <include
                    android:id="@+id/vendorHomeActionMessages"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_8" />

                <include
                    android:id="@+id/vendorHomeActionAnalytics"
                    layout="@layout/ms_component_quick_action_tile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ====== Section: Recent activity ====== -->
            <include
                android:id="@+id/vendorHomeActivityHeader"
                layout="@layout/ms_component_section_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Ms.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/vendorHomeActivityList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:overScrollMode="never"
                        android:nestedScrollingEnabled="false" />

                    <include
                        android:id="@+id/vendorHomeActivityEmpty"
                        layout="@layout/ms_component_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <include
                        android:id="@+id/vendorHomeActivityError"
                        layout="@layout/ms_component_error_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/vendorHomeActivityLoading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_16"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/ms_bg_skeleton_block" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="@dimen/space_8"
                            android:background="@drawable/ms_bg_skeleton_block" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="@dimen/space_8"
                            android:background="@drawable/ms_bg_skeleton_block" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ============ Bottom nav ============ -->
    <include
        layout="@layout/include_vendor_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
