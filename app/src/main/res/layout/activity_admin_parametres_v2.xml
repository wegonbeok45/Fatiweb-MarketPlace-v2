<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminParametresRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".AdminParametresActivity">

    <!-- ====== Top app bar ====== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminParametresAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/ms_top_bar_height"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20">

            <TextView
                android:id="@+id/adminParamsTitle"
                style="@style/Ms.Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/admin_title_settings"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/adminParamsBell"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/adminParamsBell"
                android:layout_width="@dimen/ms_min_touch"
                android:layout_height="@dimen/ms_min_touch"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/ms_section_notifications"
                android:focusable="true"
                android:padding="11dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_admin_nav_notifications"
                app:tint="@color/ms_text_primary" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ====== Scrollable content ====== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/adminParametresScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="96dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:paddingTop="@dimen/space_16">

            <!-- ── Hero banner ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminParamCardBoutique"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_24"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/ms_radius_lg"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_admin_hero_card"
                    android:orientation="vertical"
                    android:padding="@dimen/space_20">

                    <TextView
                        style="@style/Ms.Text.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@android:color/white" />

                    <TextView
                        style="@style/Ms.Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_4"
                        android:text="@string/admin_settings_hero_subtitle"
                        android:textColor="@color/ms_text_inverse_muted" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Section: Delivery ── -->
            <TextView
                style="@style/Ms.Text.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_8"
                android:text="@string/admin_settings_delivery_title"
                android:textColor="@color/ms_text_secondary" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminParamCardLivraison"
                style="@style/Ms.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_24">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Standard row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingStart="@dimen/space_16"
                        android:paddingEnd="@dimen/space_16">

                        <TextView
                            android:id="@+id/adminParamLivrStandard"
                            style="@style/Ms.Text.Label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_settings_shipping_standard"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/adminParamLivrStandardEditGroup"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/adminParamLivrStandardEditGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/space_8"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <TextView
                                android:id="@+id/adminParamLivrStandardPrice"
                                style="@style/Ms.Text.Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/ms_accent_gold"
                                tools:text="7.000 DT" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="@dimen/space_8"
                                android:contentDescription="@string/cd_stat_icon"
                                app:srcCompat="@drawable/ic_admin_edit"
                                app:tint="@color/ms_text_tertiary" />

                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/space_16"
                        android:layout_marginEnd="@dimen/space_16"
                        android:background="@color/ms_border_subtle" />

                    <!-- Express row -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:paddingStart="@dimen/space_16"
                        android:paddingEnd="@dimen/space_16">

                        <TextView
                            android:id="@+id/adminParamLivrExpress"
                            style="@style/Ms.Text.Label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_settings_shipping_express"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/adminParamLivrExpressEditGroup"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/adminParamLivrExpressEditGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="?selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/space_8"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <TextView
                                android:id="@+id/adminParamLivrExpressPrice"
                                style="@style/Ms.Text.Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/ms_accent_gold"
                                tools:text="15.000 DT" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="@dimen/space_8"
                                android:contentDescription="@string/cd_stat_icon"
                                app:srcCompat="@drawable/ic_admin_edit"
                                app:tint="@color/ms_text_tertiary" />

                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Section: Payments ── -->
            <TextView
                style="@style/Ms.Text.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_8"
                android:text="@string/admin_settings_payments_title"
                android:textColor="@color/ms_text_secondary" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminParamCardPaiement"
                style="@style/Ms.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_24">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Card payment -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="@dimen/space_16"
                        android:paddingEnd="@dimen/space_16">

                        <TextView
                            style="@style/Ms.Text.Label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_settings_payment_card"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/adminParamPayCardChevron"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/adminParamPayCardChevron"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/cd_stat_icon"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/space_16"
                        android:layout_marginEnd="@dimen/space_16"
                        android:background="@color/ms_border_subtle" />

                    <!-- e-Dinar -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="@dimen/space_16"
                        android:paddingEnd="@dimen/space_16">

                        <TextView
                            style="@style/Ms.Text.Label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_settings_payment_edinar"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/adminParamPayEdinarChevron"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/adminParamPayEdinarChevron"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/cd_stat_icon"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/space_16"
                        android:layout_marginEnd="@dimen/space_16"
                        android:background="@color/ms_border_subtle" />

                    <!-- Cash on delivery -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:paddingStart="@dimen/space_16"
                        android:paddingEnd="@dimen/space_16">

                        <TextView
                            style="@style/Ms.Text.Label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_settings_payment_cod"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/adminParamPayCodChevron"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/adminParamPayCodChevron"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/cd_stat_icon"
                            app:srcCompat="@drawable/ic_profile_chevron_right"
                            app:tint="@color/ms_text_tertiary"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Debug: seed button ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminSeedDB"
                style="@style/Ms.Button.Ghost"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="@dimen/space_8"
                android:text="@string/admin_settings_debug_seed"
                android:visibility="gone"
                app:icon="@drawable/ic_home_add_cart"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/space_8" />

            <TextView
                android:id="@+id/tvAdminSeedDBHelper"
                style="@style/Ms.Text.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_16"
                android:text="@string/admin_settings_debug_seed_helper"
                android:textColor="@color/ms_text_tertiary"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ====== Bottom nav ====== -->
    <include
        layout="@layout/include_admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
