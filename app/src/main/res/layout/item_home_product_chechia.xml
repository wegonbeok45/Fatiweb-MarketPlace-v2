<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProductChechia"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_product_image_height">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardBackgroundColor="@color/home_product_surface"
            app:cardCornerRadius="@dimen/home_product_image_radius"
            app:cardElevation="@dimen/home_product_card_elevation"
            app:strokeWidth="@dimen/space_0">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/auto_text_056"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/product1example" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="@dimen/home_product_promo_chip_height"
            android:layout_margin="@dimen/home_product_promo_margin"
            app:cardBackgroundColor="@color/home_chip_bg"
            app:cardCornerRadius="@dimen/home_product_promo_chip_radius"
            app:cardElevation="@dimen/space_0"
            app:strokeWidth="@dimen/space_0">

            <TextView
                style="@style/HomeText.BannerChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingStart="@dimen/home_product_promo_chip_padding_horizontal"
                android:paddingEnd="@dimen/home_product_promo_chip_padding_horizontal"
                android:text="@string/auto_text_057" />
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/btnFavoriteChechia"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|top"
            android:layout_margin="4dp">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/ivFavoriteChechia"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="@string/auto_text_058"
                app:lottie_rawRes="@raw/anim_heart"
                app:lottie_autoPlay="false"
                app:lottie_loop="false" />
        </FrameLayout>
    </FrameLayout>

    <TextView
        style="@style/HomeText.ProductName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_product_name_margin_top"
        android:ellipsize="end"
        android:maxLines="2"
        android:minLines="2"
        android:text="@string/auto_text_059" />

    <TextView
        style="@style/HomeText.ProductSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_product_subtitle_margin_top"
        android:ellipsize="end"
        android:maxLines="1"
        android:minLines="1"
        android:text="@string/auto_text_060" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_product_price_row_height"
        android:layout_marginTop="@dimen/home_product_price_row_margin_top"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="bottom"
            android:orientation="horizontal">

            <TextView
                style="@style/HomeText.ProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/price_amount_chechia" />

            <TextView
                style="@style/HomeText.ProductPriceUnit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/home_product_price_unit_margin_start"
                android:text="@string/currency_dt" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnAddCartChechia"
            android:layout_width="@dimen/home_add_cart_button_size"
            android:layout_height="@dimen/home_add_cart_button_size"
            app:cardBackgroundColor="@color/home_text_primary"
            app:cardCornerRadius="@dimen/home_add_cart_button_radius"
            app:cardElevation="@dimen/space_0"
            app:strokeWidth="@dimen/space_0">

            <ImageView
                android:layout_width="@dimen/home_add_cart_icon_size"
                android:layout_height="@dimen/home_add_cart_icon_size"
                android:layout_gravity="center"
                android:contentDescription="@string/auto_text_062"
                app:srcCompat="@drawable/ic_home_add_cart"
                app:tint="@color/colorSurface" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
