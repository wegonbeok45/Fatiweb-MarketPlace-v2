<?xml version="1.0" encoding="utf-8"?>
<!--
    Admin client list row.
    View IDs must remain stable — AdminClientsAdapter binds to them directly.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="?selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="@dimen/space_20"
    android:paddingEnd="@dimen/space_20">

    <!-- Avatar circle -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/adminClientAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardBackgroundColor="@color/ms_border_subtle"
        app:cardCornerRadius="999dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/adminClientAvatarImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/cd_profile_avatar"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:srcCompat="@drawable/profile_avatar_art" />

        <TextView
            android:id="@+id/adminClientAvatarInitial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="@color/ms_accent_gold"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="A" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Meta line (orders · role · joined) -->
    <TextView
        android:id="@+id/adminClientId"
        style="@style/Ms.Text.Caption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_14"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/ms_text_tertiary"
        app:layout_constraintBottom_toTopOf="@id/adminClientName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/adminClientAvatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="3 commandes · Client · Mai 2024" />

    <!-- Display name -->
    <TextView
        android:id="@+id/adminClientName"
        style="@style/Ms.Text.Label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_14"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintBottom_toTopOf="@id/adminClientEmail"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/adminClientAvatar"
        app:layout_constraintTop_toBottomOf="@id/adminClientId"
        tools:text="Mohmed Gnounou" />

    <!-- Email / phone -->
    <TextView
        android:id="@+id/adminClientEmail"
        style="@style/Ms.Text.Caption"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_14"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/adminClientAvatar"
        app:layout_constraintTop_toBottomOf="@id/adminClientName"
        tools:text="mohmed@email.com · +216 XX XXX XXX" />

</androidx.constraintlayout.widget.ConstraintLayout>
