<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_ref_bg"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/hostFragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/hostLayoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/hostTabLoadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/home_ref_bg"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/hostLayoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/hostTabLoadingState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/hostTabLoadingSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorColor="@color/ms_accent_gold"
                app:indicatorSize="42dp"
                app:trackThickness="4dp" />

            <TextView
                android:id="@+id/hostTabLoadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/ms_loading"
                android:textColor="@color/ms_text_primary"
                android:textSize="@dimen/text_size_caption" />

            <TextView
                android:id="@+id/hostTabLoadingError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/manrope_regular"
                android:textColor="@color/home_ref_text_secondary"
                android:textSize="@dimen/text_size_caption"
                android:visibility="gone"
                tools:text="Something went wrong" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/hostBtnTabRetry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/ms_action_retry"
                android:textAllCaps="false"
                android:visibility="gone"
                app:cornerRadius="20dp" />
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/hostLayoutBottomNav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_ref_nav_height"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/home_ref_surface"
        app:cardCornerRadius="@dimen/home_ref_nav_radius"
        app:cardElevation="8dp"
        app:strokeColor="@color/ms_border_subtle"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/hostBottomNavConstraint"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/nav_indicator"
                android:layout_width="0dp"
                android:layout_height="@dimen/home_ref_nav_indicator_height"
                android:background="@drawable/bg_nav_pill"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/hostNavHome"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintStart_toStartOf="@id/hostNavHome"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/hostNavHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/nav_tab_home"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toStartOf="@id/hostNavExplore"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/hostNavHomeIcon"
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/ic_bottom_nav_home"
                    app:tint="@color/ms_text_primary" />

                <TextView
                    android:id="@+id/hostNavHomeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/home_ref_nav_home"
                    android:textColor="@color/ms_text_primary"
                    android:textSize="@dimen/home_ref_nav_label_size" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/hostNavExplore"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/nav_tab_explore"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toStartOf="@id/hostNavCart"
                app:layout_constraintStart_toEndOf="@id/hostNavHome"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/hostNavExploreIcon"
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/ic_bottom_nav_categories"
                    app:tint="@color/ms_text_secondary" />

                <TextView
                    android:id="@+id/hostNavExploreLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/home_ref_nav_categories"
                    android:textColor="@color/ms_text_secondary"
                    android:textSize="@dimen/home_ref_nav_label_size" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/hostNavCart"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/nav_tab_cart"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toStartOf="@id/hostNavProfile"
                app:layout_constraintStart_toEndOf="@id/hostNavExplore"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="30dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/hostIvBottomCartIcon"
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:layout_gravity="center"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_bottom_nav_cart"
                        app:tint="@color/ms_text_secondary" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBottomCartBadge"
                        android:layout_width="20dp"
                        android:layout_height="18dp"
                        android:layout_gravity="end|top"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/ms_accent_gold"
                        app:cardCornerRadius="9dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <TextView
                            android:id="@+id/tvBottomCartBadge"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:textColor="@color/home_ref_surface"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            tools:text="1" />
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>

                <TextView
                    android:id="@+id/hostNavCartLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/home_ref_nav_cart"
                    android:textColor="@color/ms_text_secondary"
                    android:textSize="@dimen/home_ref_nav_label_size" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/hostNavProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/nav_tab_profile"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/hostNavCart"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/hostNavProfileIcon"
                    android:layout_width="21dp"
                    android:layout_height="21dp"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/ic_bottom_nav_profile"
                    app:tint="@color/ms_text_secondary" />

                <TextView
                    android:id="@+id/hostNavProfileLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/home_ref_nav_account"
                    android:textColor="@color/ms_text_secondary"
                    android:textSize="@dimen/home_ref_nav_label_size" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/chatFab"
        android:layout_width="@dimen/screen_fab_size"
        android:layout_height="@dimen/screen_fab_size"
        android:layout_marginEnd="@dimen/screen_fab_margin_end"
        android:layout_marginBottom="@dimen/screen_fab_margin_bottom"
        android:clickable="true"
        android:contentDescription="FatiBot Assistant IA"
        android:elevation="8dp"
        android:focusable="true"
        app:cardBackgroundColor="@color/ms_surface_inverse"
        app:cardCornerRadius="@dimen/screen_fab_corner_radius"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/hostLayoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:importantForAccessibility="no"
            android:padding="@dimen/screen_fab_icon_padding"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/ic_chat_bubble"
            app:tint="@color/ms_text_inverse" />

    </androidx.cardview.widget.CardView>

    <View
        android:id="@+id/chatFabDot"
        android:layout_width="@dimen/screen_fab_dot_size"
        android:layout_height="@dimen/screen_fab_dot_size"
        android:layout_marginEnd="@dimen/screen_fab_dot_margin_end"
        android:layout_marginBottom="@dimen/screen_fab_dot_margin_bottom"
        android:background="@drawable/bg_chat_dot"
        android:backgroundTint="@android:color/white"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/hostLayoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
