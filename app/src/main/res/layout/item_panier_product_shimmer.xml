<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/ms_surface_card"
    app:cardCornerRadius="@dimen/ms_radius_lg"
    app:cardElevation="@dimen/ms_elev_0"
    app:strokeColor="@color/ms_border_subtle"
    app:strokeWidth="@dimen/ms_stroke_hairline">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="118dp"
        android:padding="@dimen/space_12">

        <View
            android:id="@+id/cartSkeletonImage"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:background="@drawable/ms_bg_skeleton_block"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/cartSkeletonTitle"
            android:layout_width="0dp"
            android:layout_height="14dp"
            android:layout_marginStart="@dimen/space_12"
            android:layout_marginEnd="@dimen/space_24"
            android:background="@drawable/ms_bg_skeleton_block"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cartSkeletonImage"
            app:layout_constraintTop_toTopOf="@id/cartSkeletonImage" />

        <View
            android:id="@+id/cartSkeletonSubtitle"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_marginTop="@dimen/space_8"
            android:background="@drawable/ms_bg_skeleton_block"
            app:layout_constraintEnd_toEndOf="@id/cartSkeletonTitle"
            app:layout_constraintStart_toStartOf="@id/cartSkeletonTitle"
            app:layout_constraintTop_toBottomOf="@id/cartSkeletonTitle" />

        <View
            android:id="@+id/cartSkeletonQty"
            android:layout_width="84dp"
            android:layout_height="30dp"
            android:layout_marginTop="@dimen/space_16"
            android:background="@drawable/ms_bg_skeleton_block"
            app:layout_constraintStart_toStartOf="@id/cartSkeletonTitle"
            app:layout_constraintTop_toBottomOf="@id/cartSkeletonSubtitle" />

        <View
            android:layout_width="68dp"
            android:layout_height="16dp"
            android:background="@drawable/ms_bg_skeleton_block"
            app:layout_constraintBottom_toBottomOf="@id/cartSkeletonQty"
            app:layout_constraintEnd_toEndOf="@id/cartSkeletonTitle"
            app:layout_constraintTop_toTopOf="@id/cartSkeletonQty" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
