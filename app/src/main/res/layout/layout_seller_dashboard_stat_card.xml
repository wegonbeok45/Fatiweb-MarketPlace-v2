<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="106dp"
        android:background="@drawable/bg_admin_card_premium"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Thin gold accent line -->
        <View
            android:layout_width="20dp"
            android:layout_height="2dp"
            android:background="@drawable/bg_admin_section_dot" />

        <TextView
            android:id="@+id/sellerStatValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_semibold"
            android:maxLines="1"
            android:text="@string/str_2f43b4"
            android:textColor="@color/profile_text_primary"
            android:textSize="22sp"
            tools:text="128 DT" />

        <TextView
            android:id="@+id/sellerStatLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/manrope_medium"
            android:letterSpacing="0.04"
            android:maxLines="2"
            android:textAllCaps="true"
            android:textColor="@color/profile_text_secondary"
            android:textSize="10sp"
            tools:text="Revenue" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
