<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTopicOrders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_12"
        app:cardBackgroundColor="@color/home_surface_raised"
        app:cardCornerRadius="@dimen/corner_radius_large"
        app:cardElevation="0dp"
        app:strokeColor="@color/colorBorderLight"
        app:strokeWidth="@dimen/stroke_width_default">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/cd_nav_cart"
                app:srcCompat="@drawable/ic_bottom_nav_cart"
                app:tint="@color/profile_text_secondary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/help_center_topic_orders_title"
                android:textColor="@color/profile_text_primary"
                android:textSize="@dimen/text_size_body" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@string/cd_chevron"
                app:srcCompat="@drawable/ic_profile_chevron_right"
                app:tint="@color/profile_chevron" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTopicShipping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_12"
        app:cardBackgroundColor="@color/home_surface_raised"
        app:cardCornerRadius="@dimen/corner_radius_large"
        app:cardElevation="0dp"
        app:strokeColor="@color/colorBorderLight"
        app:strokeWidth="@dimen/stroke_width_default">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/cd_location"
                app:srcCompat="@drawable/map"
                app:tint="@color/profile_text_secondary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/help_center_topic_shipping_title"
                android:textColor="@color/profile_text_primary"
                android:textSize="@dimen/text_size_body" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@string/cd_chevron"
                app:srcCompat="@drawable/ic_profile_chevron_right"
                app:tint="@color/profile_chevron" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTopicReturns"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_12"
        app:cardBackgroundColor="@color/home_surface_raised"
        app:cardCornerRadius="@dimen/corner_radius_large"
        app:cardElevation="0dp"
        app:strokeColor="@color/colorBorderLight"
        app:strokeWidth="@dimen/stroke_width_default">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/cd_delete"
                app:srcCompat="@drawable/ic_profile_logout"
                app:tint="@color/profile_text_secondary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/help_center_topic_returns_title"
                android:textColor="@color/profile_text_primary"
                android:textSize="@dimen/text_size_body" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@string/cd_chevron"
                app:srcCompat="@drawable/ic_profile_chevron_right"
                app:tint="@color/profile_chevron" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTopicPayments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/home_surface_raised"
        app:cardCornerRadius="@dimen/corner_radius_large"
        app:cardElevation="0dp"
        app:strokeColor="@color/colorBorderLight"
        app:strokeWidth="@dimen/stroke_width_default">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/cd_settings"
                app:srcCompat="@drawable/settings"
                app:tint="@color/colorError" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_12"
                android:layout_weight="1"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/help_center_topic_payments_title"
                android:textColor="@color/profile_text_primary"
                android:textSize="@dimen/text_size_body" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@string/cd_chevron"
                app:srcCompat="@drawable/ic_profile_chevron_right"
                app:tint="@color/profile_chevron" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</merge>

