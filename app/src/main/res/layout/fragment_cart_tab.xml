<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_screen_bg"
    tools:context=".CartTabFragment">

    <LinearLayout
        android:id="@+id/layoutTopSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        android:elevation="2dp"
        android:orientation="vertical"
        android:paddingStart="@dimen/home_horizontal_padding"
        android:paddingTop="@dimen/space_20"
        android:paddingEnd="@dimen/home_horizontal_padding"
        android:paddingBottom="@dimen/space_20"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivHomeLogo"
                    android:layout_width="34dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/auto_text_001"
                    android:scaleType="fitCenter"
                    app:srcCompat="@drawable/fatiweblogo" />

                <TextView
                    android:id="@+id/tvBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_12"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:text="@string/auto_text_002"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardBackgroundColor="@color/home_surface_soft"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorOutline"
                app:strokeWidth="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivTopNotifications"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/notifications_title"
                    app:srcCompat="@drawable/notification"
                    app:tint="@color/home_text_primary" />
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_24"
            android:background="@drawable/bg_home_meta_pill"
            android:fontFamily="@font/plus_jakarta_sans_medium"
            android:paddingStart="@dimen/space_12"
            android:paddingTop="@dimen/space_6"
            android:paddingEnd="@dimen/space_12"
            android:paddingBottom="@dimen/space_6"
            android:text="@string/cart_header_badge"
            android:textColor="@color/home_meta_text"
            android:textSize="@dimen/text_size_overline"
            android:textStyle="bold" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_14">

            <TextView
                android:id="@+id/tvCartTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="@string/auto_text_096"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_title_large"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tvCartCountChip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvCartCountChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_meta_pill"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:paddingStart="@dimen/space_12"
                android:paddingTop="@dimen/space_8"
                android:paddingEnd="@dimen/space_12"
                android:paddingBottom="@dimen/space_8"
                android:text="@string/cart_count_chip_zero"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_overline"
                app:layout_constraintBottom_toBottomOf="@id/tvCartTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvCartTitle" />

            <TextView
                android:id="@+id/tvCartHelper"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:lineSpacingExtra="2dp"
                android:text="@string/cart_header_helper"
                android:textColor="@color/home_text_secondary"
                android:textSize="@dimen/text_size_caption"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvCartTitle" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollPanierContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/home_horizontal_padding"
            android:paddingTop="@dimen/space_20"
            android:paddingEnd="@dimen/home_horizontal_padding"
            android:paddingBottom="112dp">

            <LinearLayout
                android:id="@+id/layoutEmptyCartState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="36dp"
                android:paddingBottom="28dp"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    app:cardBackgroundColor="@color/home_surface_raised"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorOutline"
                    app:strokeWidth="1dp">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/ivEmptyCartAnimation"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/auto_text_097"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        app:lottie_rawRes="@raw/anim_empty_cart" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvEmptyCart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_24"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:gravity="center"
                    android:text="@string/auto_text_097"
                    android:textColor="@color/home_text_primary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEmptyCartSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_10"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/cart_empty_subtitle"
                    android:textColor="@color/home_text_secondary"
                    android:textSize="@dimen/text_size_caption" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEmptyCartBrowse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_marginTop="@dimen/space_20"
                    android:text="@string/auto_text_080"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:paddingHorizontal="@dimen/space_32"
                    app:backgroundTint="?attr/colorPrimary"
                    app:cornerRadius="26dp"
                    app:elevation="0dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutCartItemsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Space
                android:id="@+id/spaceBeforeSummary"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:visibility="gone" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardBackgroundColor="@color/home_surface_raised"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_24">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_meta_pill"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/space_12"
                        android:paddingTop="7dp"
                        android:paddingEnd="@dimen/space_12"
                        android:paddingBottom="7dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="@string/cd_logo"
                            app:srcCompat="@drawable/ic_checkout_truck"
                            app:tint="@color/home_text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_8"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:text="@string/cart_summary_badge"
                            android:textColor="@color/home_text_primary"
                            android:textSize="@dimen/text_size_overline" />
                    </LinearLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_18">

                        <TextView
                            android:id="@+id/tvSubtotalLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:text="@string/auto_text_098"
                            android:textColor="@color/home_text_secondary"
                            android:textSize="@dimen/text_size_caption"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvSubtotalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/auto_text_099"
                            android:textColor="@color/home_text_primary"
                            android:textSize="@dimen/text_size_body"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_14">

                        <TextView
                            android:id="@+id/tvLivraisonLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:text="@string/auto_text_100"
                            android:textColor="@color/home_text_secondary"
                            android:textSize="@dimen/text_size_caption"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvLivraisonValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/auto_text_099"
                            android:textColor="@color/home_text_primary"
                            android:textSize="@dimen/text_size_body"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/space_20"
                        android:background="@color/colorOutline" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_20">

                        <TextView
                            android:id="@+id/tvTotalLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/details_total_label"
                            android:textColor="@color/home_text_primary"
                            android:textSize="@dimen/text_size_subtitle"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvTotalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans_bold"
                            android:text="@string/auto_text_099"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="@dimen/text_size_title"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCheckout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="56dp"
                        android:layout_marginTop="@dimen/space_24"
                        android:text="@string/cart_checkout_action"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/text_size_body"
                        android:paddingVertical="@dimen/space_14"
                        app:backgroundTint="?attr/colorPrimary"
                        app:cornerRadius="22dp"
                        app:elevation="0dp" />

                    <TextView
                        android:id="@+id/tvSummaryHelper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:gravity="center"
                        android:text="@string/cart_summary_helper"
                        android:textColor="@color/home_text_secondary"
                        android:textSize="@dimen/text_size_caption" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
