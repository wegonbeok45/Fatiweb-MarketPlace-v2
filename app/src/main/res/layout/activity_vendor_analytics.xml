<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/vendorAnalyticsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".VendorAnalyticsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/vendorAnalyticsAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/ms_top_bar_height"
            android:paddingStart="@dimen/space_8"
            android:paddingEnd="@dimen/space_20">

            <ImageView
                android:id="@+id/vendorAnalyticsBack"
                android:layout_width="@dimen/ms_min_touch"
                android:layout_height="@dimen/ms_min_touch"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/ms_cd_back"
                android:padding="11dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/back"
                app:tint="@color/ms_text_primary" />

            <TextView
                style="@style/Ms.Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_8"
                android:text="@string/vendor_analytics_title"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/vendorAnalyticsBack"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/vendorAnalyticsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:paddingTop="@dimen/space_8">

            <!-- KPI strip 2x2 -->
            <TextView
                style="@style/Ms.Text.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:text="@string/vendor_analytics_section_overview" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal"
                android:weightSum="2">

                <include
                    android:id="@+id/vendorAnalyticsKpiWeekRevenue"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_6"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/vendorAnalyticsKpiWeekOrders"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal"
                android:weightSum="2">

                <include
                    android:id="@+id/vendorAnalyticsKpiAvgBasket"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_6"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/vendorAnalyticsKpiDeliveryRate"
                    layout="@layout/ms_component_kpi_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_6"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- Bar chart -->
            <TextView
                style="@style/Ms.Text.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:text="@string/vendor_analytics_section_orders_chart" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Ms.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_16">

                    <LinearLayout
                        android:id="@+id/vendorAnalyticsChartBars"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal"
                        android:weightSum="7" />

                    <LinearLayout
                        android:id="@+id/vendorAnalyticsChartLabels"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_8"
                        android:orientation="horizontal"
                        android:weightSum="7" />

                    <TextView
                        android:id="@+id/vendorAnalyticsChartEmpty"
                        style="@style/Ms.Text.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="@dimen/space_24"
                        android:text="@string/vendor_analytics_empty_chart"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Top products -->
            <TextView
                style="@style/Ms.Text.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:text="@string/vendor_analytics_section_top_products" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Ms.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/vendorAnalyticsTopProducts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <include
                        android:id="@+id/vendorAnalyticsTopEmpty"
                        layout="@layout/ms_component_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Low stock -->
            <TextView
                style="@style/Ms.Text.SectionHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_24"
                android:text="@string/vendor_analytics_section_low_stock" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Ms.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/vendorAnalyticsLowStock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <include
                        android:id="@+id/vendorAnalyticsLowStockEmpty"
                        layout="@layout/ms_component_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/vendorAnalyticsError"
        layout="@layout/ms_component_error_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
