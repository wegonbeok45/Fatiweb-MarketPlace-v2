<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sellerOrderRow"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="?selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingStart="14dp"
    android:paddingEnd="14dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/sellerOrderIcon"
        android:layout_width="38dp"
        android:layout_height="38dp"
        app:cardBackgroundColor="@color/ms_surface_sunken"
        app:cardCornerRadius="999dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_order_status"
            app:srcCompat="@drawable/shoppingbag"
            app:tint="@color/ms_text_primary" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/sellerOrderId"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="@color/ms_text_primary"
        android:textSize="@dimen/text_size_caption"
        android:fontFamily="@font/manrope_semibold"
        app:layout_constraintBottom_toTopOf="@id/sellerOrderClient"
        app:layout_constraintEnd_toStartOf="@id/sellerOrderTotal"
        app:layout_constraintStart_toEndOf="@id/sellerOrderIcon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/sellerOrderClient"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/ms_text_secondary"
        android:textSize="@dimen/text_size_overline"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/sellerOrderBadge"
        app:layout_constraintStart_toEndOf="@id/sellerOrderIcon"
        app:layout_constraintTop_toBottomOf="@id/sellerOrderId" />

    <TextView
        android:id="@+id/sellerOrderTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/ms_text_primary"
        android:textSize="@dimen/text_size_caption"
        android:fontFamily="@font/manrope_semibold"
        app:layout_constraintBottom_toTopOf="@id/sellerOrderBadge"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/sellerOrderBadge"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_marginTop="4dp"
        app:cardBackgroundColor="@color/status_bg_warning"
        app:cardCornerRadius="999dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sellerOrderTotal"
        app:strokeWidth="0dp">

        <TextView
            android:id="@+id/sellerOrderBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textColor="@color/status_text_warning"
            android:textSize="@dimen/text_size_overline" />
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
