<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminProduitsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_body_bg"
    tools:context=".AdminProduitsActivity">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminProduitsAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/profile_header_bg"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/adminProduitsTopBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/adminProduitsIvBack"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/back"
                app:tint="@color/profile_text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"

                android:text="Gestion des Produits"
                android:textColor="@color/profile_text_primary"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/adminProduitsIvBack"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/profile_divider" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/adminProduitsScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp">

            <!-- Section Header -->
            <TextView
                android:id="@+id/adminProduitsTvHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:text="Catalogue Produits"
                android:textColor="@color/profile_text_primary"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Products Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminProduitsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/profile_card_bg"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/colorBorderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Product 1 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/adminProduitRow1"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/adminProduitThumb1"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardBackgroundColor="@color/profile_card_icon_bg"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/ic_home_cat_artisanat"
                                app:tint="@color/colorPrimary" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/adminProduitName1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"

                            android:text="Chéchia Traditionnelle"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toTopOf="@id/adminProduitSub1"
                            app:layout_constraintEnd_toStartOf="@id/adminProduitPrice1"
                            app:layout_constraintStart_toEndOf="@id/adminProduitThumb1"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/adminProduitSub1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"

                            android:text="Artisanat • Stock: 15"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/adminProduitPrice1"
                            app:layout_constraintStart_toEndOf="@id/adminProduitThumb1"
                            app:layout_constraintTop_toBottomOf="@id/adminProduitName1" />

                        <TextView
                            android:id="@+id/adminProduitPrice1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="45 DT"
                            android:textColor="@color/colorPrimary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/profile_divider" />

                    <!-- Product 2 - Stock épuisé -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/adminProduitRow2"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/adminProduitThumb2"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardBackgroundColor="#FFF3E0"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/ic_home_cat_huiles"
                                app:tint="#E65100" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/adminProduitName2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"

                            android:text="Huile d'Olive Extra"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toTopOf="@id/adminProduitSub2"
                            app:layout_constraintEnd_toStartOf="@id/adminProduitBadge2"
                            app:layout_constraintStart_toEndOf="@id/adminProduitThumb2"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/adminProduitSub2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"

                            android:text="Bio • Stock épuisé (0)"
                            android:textColor="@color/colorError"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/adminProduitBadge2"
                            app:layout_constraintStart_toEndOf="@id/adminProduitThumb2"
                            app:layout_constraintTop_toBottomOf="@id/adminProduitName2" />

                        <TextView
                            android:id="@+id/adminProduitBadge2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="28 DT"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/profile_divider" />

                    <!-- Product 3 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/adminProduitRow3"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:background="?selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/adminProduitThumb3"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardBackgroundColor="@color/profile_card_icon_bg"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@null"
                                android:scaleType="centerCrop"
                                app:srcCompat="@drawable/ic_home_cat_epices"
                                app:tint="@color/colorPrimary" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/adminProduitName3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"

                            android:text="Mélange d'Épices Harissa"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toTopOf="@id/adminProduitSub3"
                            app:layout_constraintEnd_toStartOf="@id/adminProduitPrice3"
                            app:layout_constraintStart_toEndOf="@id/adminProduitThumb3"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/adminProduitSub3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"

                            android:text="Épices • Stock: 42"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/adminProduitPrice3"
                            app:layout_constraintStart_toEndOf="@id/adminProduitThumb3"
                            app:layout_constraintTop_toBottomOf="@id/adminProduitName3" />

                        <TextView
                            android:id="@+id/adminProduitPrice3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:text="12 DT"
                            android:textColor="@color/colorPrimary"
                            android:textSize="14sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav -->
    <include
        layout="@layout/include_admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
