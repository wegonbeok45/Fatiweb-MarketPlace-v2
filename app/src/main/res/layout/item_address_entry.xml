<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/profile_card_bg"
    app:cardCornerRadius="@dimen/profile_menu_card_radius"
    app:cardElevation="1dp"
    app:strokeColor="@color/ms_border_default"
    app:strokeWidth="@dimen/stroke_width_default">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAddressTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_caption"
                android:fontFamily="@font/manrope_semibold" />

            <TextView
                android:id="@+id/tvAddressState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_home_banner_chip"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@color/home_chip_text"
                android:textSize="@dimen/text_size_overline"
                android:fontFamily="@font/manrope_medium" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAddressSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/text_size_caption"
            android:fontFamily="@font/manrope_regular" />

        <TextView
            android:id="@+id/tvAddressDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/home_text_secondary"
            android:textSize="@dimen/text_size_overline"
            android:fontFamily="@font/manrope_regular" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAddressSetDefault"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/surface_button_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:minWidth="@dimen/surface_button_size"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/address_set_default_action"
                android:textColor="@color/ms_text_primary"
                android:textSize="@dimen/text_size_overline"
                android:fontFamily="@font/manrope_medium" />

            <TextView
                android:id="@+id/tvAddressEdit"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/surface_button_size"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:minWidth="@dimen/surface_button_size"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/ms_action_edit"
                android:textColor="@color/home_text_primary"
                android:textSize="@dimen/text_size_overline"
                android:fontFamily="@font/manrope_medium" />

            <TextView
                android:id="@+id/tvAddressRemove"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/surface_button_size"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:minWidth="@dimen/surface_button_size"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/ms_action_delete"
                android:textColor="@color/ms_text_primary"
                android:textSize="@dimen/text_size_overline"
                android:fontFamily="@font/manrope_medium" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

