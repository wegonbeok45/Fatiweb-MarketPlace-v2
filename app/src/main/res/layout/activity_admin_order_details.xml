<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/profile_header_bg"
    tools:context=".AdminOrderDetailsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- App bar -->
        <LinearLayout
            android:id="@+id/adminOrderDetailsAppBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp">

            <ImageButton
                android:id="@+id/adminOrderDetailsIvBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_shell_action_chip"
                android:contentDescription="@string/admin_back"
                android:padding="12dp"
                android:src="@drawable/back"
                app:tint="@color/profile_text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/admin_order_details_title"
                android:textColor="@color/profile_text_primary"
                android:textSize="20sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/adminOrderDetailsContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="32dp"
                android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Order header card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/profile_section_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/adminOrderDetailsId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="24sp"
                            tools:text="#FW-123ABC" />

                        <TextView
                            android:id="@+id/adminOrderDetailsDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="13sp"
                            tools:text="Créé le 13 mai 2026 - 18:05" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/adminOrderDetailsStatusCard"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardBackgroundColor="@color/status_chip_bg_pending"
                                app:cardCornerRadius="18dp"
                                app:cardElevation="0dp">

                                <TextView
                                    android:id="@+id/adminOrderDetailsStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_medium"
                                    android:paddingStart="14dp"
                                    android:paddingTop="8dp"
                                    android:paddingEnd="14dp"
                                    android:paddingBottom="8dp"
                                    android:textColor="@color/status_chip_text_pending"
                                    android:textSize="13sp"
                                    tools:text="En attente" />
                            </com.google.android.material.card.MaterialCardView>

                            <Space
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/adminOrderDetailsStatusButton"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:text="@string/admin_order_change_status_cta"
                                android:textAllCaps="false"
                                android:textSize="12sp"
                                app:backgroundTint="@color/colorPrimary"
                                app:cornerRadius="16dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Buyer card — full-width, prominent -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/profile_section_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semibold"
                            android:text="@string/admin_order_details_client"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.06" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/adminOrderDetailsClientAvatar"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                android:background="@drawable/bg_admin_avatar_frame"
                                android:padding="2dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/profile_avatar_art" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/adminOrderDetailsClientName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:ellipsize="end"
                                    android:fontFamily="@font/poppins_semibold"
                                    android:maxLines="1"
                                    android:textColor="@color/profile_text_primary"
                                    android:textSize="16sp"
                                    tools:text="Mohmed Gnounou" />

                                <TextView
                                    android:id="@+id/adminOrderDetailsClientMeta"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:ellipsize="end"
                                    android:maxLines="2"
                                    android:textColor="@color/profile_text_secondary"
                                    android:textSize="12sp"
                                    tools:text="client@email.com · +216 XX XXX XXX" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Action chips -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/adminOrderDetailsBtnCall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_admin_price_pill"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/manrope_semibold"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:text="@string/admin_order_action_call"
                                android:textColor="@color/home_ref_gold"
                                android:textSize="12sp"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/adminOrderDetailsBtnEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:background="@drawable/bg_admin_price_pill"
                                android:clickable="true"
                                android:focusable="true"
                                android:fontFamily="@font/manrope_semibold"
                                android:paddingStart="16dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="8dp"
                                android:text="@string/admin_order_action_email"
                                android:textColor="@color/home_ref_gold"
                                android:textSize="12sp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Vendor card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/profile_section_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semibold"
                            android:text="@string/admin_order_details_vendor"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.06" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/adminOrderDetailsVendorAvatar"
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:background="@drawable/bg_admin_avatar_frame"
                                android:padding="2dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/profile_avatar_art" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/adminOrderDetailsVendorName"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:ellipsize="end"
                                    android:fontFamily="@font/poppins_semibold"
                                    android:maxLines="1"
                                    android:textColor="@color/profile_text_primary"
                                    android:textSize="15sp"
                                    tools:text="FatiWeb Seller" />

                                <TextView
                                    android:id="@+id/adminOrderDetailsVendorMeta"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:textColor="@color/profile_text_secondary"
                                    android:textSize="12sp"
                                    tools:text="sellerId" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Delivery address card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/profile_section_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_checkout_pin"
                                app:tint="@color/home_ref_gold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/poppins_semibold"
                                android:text="@string/admin_order_details_address"
                                android:textColor="@color/profile_text_primary"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/adminOrderDetailsAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:lineSpacingExtra="3dp"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="14sp"
                            tools:text="Mohmed Gnounou&#10;Ariana, Tunis&#10;+216 XX XXX XXX" />

                        <TextView
                            android:id="@+id/adminOrderDetailsBtnMap"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/bg_admin_price_pill"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/manrope_semibold"
                            android:paddingStart="16dp"
                            android:paddingTop="8dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="8dp"
                            android:text="@string/admin_order_action_map"
                            android:textColor="@color/home_ref_gold"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="18dp"
                            android:layout_marginBottom="4dp"
                            android:background="@color/profile_divider" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/poppins_semibold"
                            android:text="@string/admin_order_details_notes"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/adminOrderDetailsNotes"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/profile_text_secondary"
                            android:textSize="13sp"
                            tools:text="Call before delivery" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Order items card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/profile_section_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semibold"
                            android:text="@string/admin_order_details_items"
                            android:textColor="@color/profile_text_primary"
                            android:textSize="16sp" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/adminOrderDetailsItemsList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            tools:itemCount="3"
                            tools:listitem="@layout/item_admin_order_detail_product" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Payment summary card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/profile_section_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/admin_order_details_payment"
                                    android:textColor="@color/profile_text_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/adminOrderDetailsPayment"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins_semibold"
                                    android:textColor="@color/profile_text_primary"
                                    android:textSize="15sp"
                                    tools:text="Paiement à la livraison" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="14dp"
                            android:background="@color/profile_divider" />

                        <!-- Subtotal row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/admin_order_details_subtotal"
                                android:textColor="@color/profile_text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/adminOrderDetailsSubtotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_semibold"
                                android:textColor="@color/profile_text_primary"
                                android:textSize="14sp"
                                tools:text="52 DT" />
                        </LinearLayout>

                        <!-- Shipping row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/admin_order_details_shipping"
                                android:textColor="@color/profile_text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/adminOrderDetailsShipping"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_semibold"
                                android:textColor="@color/profile_text_primary"
                                android:textSize="14sp"
                                tools:text="7 DT" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="12dp"
                            android:background="@color/profile_divider" />

                        <!-- Total row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/admin_order_details_total"
                                android:fontFamily="@font/poppins_semibold"
                                android:textColor="@color/profile_text_primary"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/adminOrderDetailsTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_semibold"
                                android:textColor="@color/home_ref_gold"
                                android:textSize="22sp"
                                tools:text="59 DT" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

            <ProgressBar
                android:id="@+id/adminOrderDetailsProgress"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:visibility="visible" />

        </FrameLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
