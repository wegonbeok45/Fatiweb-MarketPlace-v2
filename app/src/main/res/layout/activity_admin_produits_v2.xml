<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/adminProduitsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".AdminProduitsActivity">

    <!-- ====== Top app bar ====== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminProduitsAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <!-- Title row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/ms_top_bar_height"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20">

            <TextView
                android:id="@+id/adminProduitsTitle"
                style="@style/Ms.Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/admin_products_title"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/adminProduitsBell"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Pending badge -->
            <TextView
                android:id="@+id/adminProduitsPendingBadge"
                style="@style/Ms.Chip.Status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ms_bg_status_pending"
                android:textColor="@color/ms_status_pending_fg"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/adminProduitsBell"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="3 en attente"
                tools:visibility="visible" />

            <ImageView
                android:id="@+id/adminProduitsBell"
                android:layout_width="@dimen/ms_min_touch"
                android:layout_height="@dimen/ms_min_touch"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/ms_section_notifications"
                android:focusable="true"
                android:padding="11dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_admin_nav_notifications"
                app:tint="@color/ms_text_primary" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Filter chip row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:paddingBottom="@dimen/space_12"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/adminProduitsChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminProduitsChipAll"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/admin_products_filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminProduitsChipPending"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_products_filter_pending" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminProduitsChipApproved"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_products_filter_approved" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminProduitsChipRejected"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_products_filter_rejected" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminProduitsChipDraft"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_products_filter_draft" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/adminProduitsChipArchived"
                    style="@style/Ms.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_products_filter_archived" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ====== Content ====== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/adminProduitsList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:paddingTop="@dimen/space_12"
            android:paddingBottom="96dp"
            tools:listitem="@layout/item_admin_product" />

        <include
            android:id="@+id/adminProduitsEmpty"
            layout="@layout/ms_component_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:visibility="gone" />

        <include
            android:id="@+id/adminProduitsError"
            layout="@layout/ms_component_error_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:visibility="gone" />

        <!-- Skeleton loading -->
        <LinearLayout
            android:id="@+id/adminProduitsLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingEnd="@dimen/space_20"
            android:visibility="visible">

            <include
                layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include
                layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12" />

            <include
                layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12" />

            <include
                layout="@layout/ms_component_skeleton_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12" />
        </LinearLayout>

        <!-- Load-more spinner anchored at bottom -->
        <ProgressBar
            android:id="@+id/adminProduitsLoadMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="@dimen/space_20"
            android:visibility="gone" />
    </FrameLayout>

    <!-- ====== Bottom nav ====== -->
    <include
        layout="@layout/include_admin_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
