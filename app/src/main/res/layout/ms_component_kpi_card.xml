<?xml version="1.0" encoding="utf-8"?>
<!-- Marketplace KPI card. Bind via findViewById on:
     msKpiIcon, msKpiValue, msKpiLabel, msKpiMeta, msKpiDelta -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Ms.Card.Surface"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/ms_kpi_card_min_height"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_16">

        <FrameLayout
            android:layout_width="@dimen/ms_icon_chip_size"
            android:layout_height="@dimen/ms_icon_chip_size"
            android:background="@drawable/ms_bg_icon_chip_gold">

            <ImageView
                android:id="@+id/msKpiIcon"
                android:layout_width="@dimen/ms_icon_chip_inner"
                android:layout_height="@dimen/ms_icon_chip_inner"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                app:tint="@color/ms_accent_gold"
                tools:srcCompat="@android:drawable/ic_menu_info_details" />
        </FrameLayout>

        <TextView
            android:id="@+id/msKpiValue"
            style="@style/Ms.Text.KpiValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_12"
            tools:text="128" />

        <TextView
            android:id="@+id/msKpiLabel"
            style="@style/Ms.Text.Overline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2"
            tools:text="COMMANDES" />

        <TextView
            android:id="@+id/msKpiDelta"
            style="@style/Ms.Chip.Status.Approved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_8"
            android:visibility="gone"
            tools:text="+12%"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/msKpiMeta"
            style="@style/Ms.Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_4"
            tools:text="3 en attente" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
