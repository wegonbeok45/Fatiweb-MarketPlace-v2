<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ms_surface_canvas"
    tools:context=".AdminClientDetailsActivity">

    <!-- ====== Top bar ====== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/adminClientDetailsAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ms_surface_canvas"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/adminClientDetailsTopBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/ms_top_bar_height"
            android:paddingStart="@dimen/space_8"
            android:paddingEnd="@dimen/space_20">

            <ImageView
                android:id="@+id/adminClientDetailsIvBack"
                android:layout_width="@dimen/ms_min_touch"
                android:layout_height="@dimen/ms_min_touch"
                android:background="?selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/ms_action_back"
                android:padding="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/back"
                app:tint="@color/ms_text_primary" />

            <TextView
                android:id="@+id/adminClientDetailsTitle"
                style="@style/Ms.Text.Title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_4"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/admin_client_details_title"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/adminClientDetailsIvBack"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ====== Scrollable content ====== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/adminClientDetailsScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/space_32"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_20"
            android:paddingTop="@dimen/space_12"
            android:paddingEnd="@dimen/space_20">

            <!-- ── Loading ── -->
            <ProgressBar
                android:id="@+id/adminClientDetailsProgress"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_24"
                android:visibility="gone" />

            <!-- ── Hero card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminClientDetailsHeroCard"
                style="@style/Ms.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="@dimen/space_24">

                    <!-- Avatar -->
                    <ImageView
                        android:id="@+id/adminClientDetailsAvatar"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:background="@drawable/ms_bg_icon_chip_dark"
                        android:contentDescription="@string/cd_profile_avatar"
                        android:scaleType="centerCrop"
                        android:src="@drawable/profile_avatar_art" />

                    <!-- Name -->
                    <TextView
                        android:id="@+id/adminClientDetailsName"
                        style="@style/Ms.Text.Title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:gravity="center"
                        tools:text="Mohamed Gnounou" />

                    <!-- Email -->
                    <TextView
                        android:id="@+id/adminClientDetailsEmail"
                        style="@style/Ms.Text.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2"
                        android:gravity="center"
                        android:textColor="@color/ms_text_secondary"
                        tools:text="client@email.com" />

                    <!-- Role + Status pills -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/adminClientDetailsRole"
                            style="@style/Ms.Chip.Status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="Client" />

                        <TextView
                            android:id="@+id/adminClientDetailsStatus"
                            style="@style/Ms.Chip.Status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_8"
                            tools:text="Actif" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── KPI stats row ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:orientation="horizontal">

                <!-- Total orders -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Ms.Card.Surface"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/adminClientDetailsTotalOrders"
                            style="@style/Ms.Text.Title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="24sp"
                            tools:text="12" />

                        <TextView
                            style="@style/Ms.Text.Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="@string/admin_client_details_total_orders"
                            android:textColor="@color/ms_text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Joined date -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Ms.Card.Surface"
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_marginStart="@dimen/space_12"
                    android:layout_weight="1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_8">

                        <TextView
                            android:id="@+id/adminClientDetailsJoined"
                            style="@style/Ms.Text.Subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="1"
                            tools:text="13 mai 2026" />

                        <TextView
                            style="@style/Ms.Text.Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_2"
                            android:text="@string/admin_client_details_joined"
                            android:textColor="@color/ms_text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── Contact card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminClientDetailsContactCard"
                style="@style/Ms.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_20">

                    <TextView
                        style="@style/Ms.Text.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_client_details_contact_block"
                        android:textColor="@color/ms_text_secondary"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <!-- Phone row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_home_category_phone"
                            app:tint="@color/ms_text_tertiary" />

                        <TextView
                            android:id="@+id/adminClientDetailsPhone"
                            style="@style/Ms.Text.Body"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_10"
                            android:layout_weight="1"
                            tools:text="+216 22 222 222" />
                    </LinearLayout>

                    <!-- Address row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_10"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginTop="2dp"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_profile_map_outline"
                            app:tint="@color/ms_text_tertiary" />

                        <TextView
                            android:id="@+id/adminClientDetailsAddress"
                            style="@style/Ms.Text.Body"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_10"
                            android:layout_weight="1"
                            android:lineSpacingExtra="2dp"
                            tools:text="Tunis, Ariana\n1000" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/space_16"
                        android:background="@color/ms_border_subtle" />

                    <!-- Action buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_16"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/adminClientDetailsContact"
                            style="@style/Ms.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/admin_client_contact" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/adminClientDetailsPromote"
                            style="@style/Ms.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_10"
                            android:layout_weight="1"
                            android:text="@string/admin_client_make_vendeur"
                            android:visibility="gone" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/adminClientDetailsRevoke"
                            style="@style/Ms.Button.Danger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_10"
                            android:layout_weight="1"
                            android:text="@string/admin_client_revoke_vendeur"
                            android:visibility="gone" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Order history card ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adminClientDetailsOrdersCard"
                style="@style/Ms.Card.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_20">

                    <TextView
                        style="@style/Ms.Text.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_client_details_order_history"
                        android:textColor="@color/ms_text_secondary"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/adminClientDetailsOrdersList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_12"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_admin_client_order_history" />

                    <TextView
                        android:id="@+id/adminClientDetailsOrdersEmpty"
                        style="@style/Ms.Text.Label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="@dimen/space_20"
                        android:text="@string/admin_client_details_no_orders"
                        android:textColor="@color/ms_text_secondary"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
