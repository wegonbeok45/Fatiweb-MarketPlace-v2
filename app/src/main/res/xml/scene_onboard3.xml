<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetEnd="@id/end"
        motion:constraintSetStart="@id/start"
        motion:duration="650"
        motion:motionInterpolator="easeInOut" />

    <ConstraintSet android:id="@+id/start">
        <Constraint
            android:id="@id/ivBack"
            android:alpha="0"
            android:translationY="-12dp" />
        <Constraint
            android:id="@id/tvSkip"
            android:alpha="0"
            android:translationY="-12dp" />
        <Constraint
            android:id="@id/cardDeliveryIllustration"
            android:alpha="0"
            android:translationY="32dp"
            android:scaleX="0.94"
            android:scaleY="0.94" />
        <Constraint
            android:id="@id/tvHeadline"
            android:alpha="0"
            android:translationY="40dp" />
        <Constraint
            android:id="@id/tvDescription"
            android:alpha="0"
            android:translationY="44dp" />
        <Constraint
            android:id="@id/layoutPagerIndicator"
            android:alpha="0"
            android:translationY="48dp" />
        <Constraint
            android:id="@id/btnGetStarted"
            android:alpha="0"
            android:translationY="56dp"
            android:scaleX="0.98"
            android:scaleY="0.98" />
    </ConstraintSet>

    <ConstraintSet android:id="@+id/end">
        <Constraint
            android:id="@id/ivBack"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/tvSkip"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/cardDeliveryIllustration"
            android:alpha="1"
            android:translationY="0dp"
            android:scaleX="1"
            android:scaleY="1" />
        <Constraint
            android:id="@id/tvHeadline"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/tvDescription"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/layoutPagerIndicator"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/btnGetStarted"
            android:alpha="1"
            android:translationY="0dp"
            android:scaleX="1"
            android:scaleY="1" />
    </ConstraintSet>
</MotionScene>
