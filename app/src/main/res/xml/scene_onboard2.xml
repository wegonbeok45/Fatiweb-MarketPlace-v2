<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetStart="@id/start"
        motion:constraintSetEnd="@id/end"
        motion:duration="680"
        motion:motionInterpolator="easeInOut" />

    <ConstraintSet android:id="@+id/start">
        <Constraint
            android:id="@id/ivBack"
            android:alpha="0"
            android:translationY="-12dp" />
        <Constraint
            android:id="@id/tvSkip"
            android:alpha="0"
            android:translationY="-12dp" />
        <Constraint
            android:id="@id/tvHeadline"
            android:alpha="0"
            android:translationY="32dp" />
        <Constraint
            android:id="@id/tvSubtitle"
            android:alpha="0"
            android:translationY="40dp" />
        <Constraint
            android:id="@id/cardCategoryFood"
            android:alpha="0"
            android:translationY="36dp"
            android:scaleX="0.97"
            android:scaleY="0.97" />
        <Constraint
            android:id="@id/cardCategoryCosmetics"
            android:alpha="0"
            android:translationY="42dp"
            android:scaleX="0.97"
            android:scaleY="0.97" />
        <Constraint
            android:id="@id/cardCategoryCrafts"
            android:alpha="0"
            android:translationY="48dp"
            android:scaleX="0.97"
            android:scaleY="0.97" />
        <Constraint
            android:id="@id/layoutPagerIndicator"
            android:alpha="0"
            android:translationY="54dp" />
        <Constraint
            android:id="@id/btnContinue"
            android:alpha="0"
            android:translationY="60dp"
            android:scaleX="0.98"
            android:scaleY="0.98" />
    </ConstraintSet>

    <ConstraintSet android:id="@+id/end">
        <Constraint
            android:id="@id/ivBack"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/tvSkip"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/tvHeadline"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/tvSubtitle"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/cardCategoryFood"
            android:alpha="1"
            android:translationY="0dp"
            android:scaleX="1"
            android:scaleY="1" />
        <Constraint
            android:id="@id/cardCategoryCosmetics"
            android:alpha="1"
            android:translationY="0dp"
            android:scaleX="1"
            android:scaleY="1" />
        <Constraint
            android:id="@id/cardCategoryCrafts"
            android:alpha="1"
            android:translationY="0dp"
            android:scaleX="1"
            android:scaleY="1" />
        <Constraint
            android:id="@id/layoutPagerIndicator"
            android:alpha="1"
            android:translationY="0dp" />
        <Constraint
            android:id="@id/btnContinue"
            android:alpha="1"
            android:translationY="0dp"
            android:scaleX="1"
            android:scaleY="1" />
    </ConstraintSet>
</MotionScene>
