<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/home_ref_hero_start"
                android:endColor="@color/home_ref_hero_end"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="@color/overlay_white_12" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>
