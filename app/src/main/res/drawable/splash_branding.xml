<?xml version="1.0" encoding="utf-8"?>
<!--
    Fatiweb splash branding mark.
    Drawn on a 108x108 canvas so the SplashScreen API centers it cleanly.
    A gold rounded tile with a white shopping-bag glyph = curated marketplace.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Gold rounded tile -->
    <path
        android:fillColor="#B8965A"
        android:pathData="M32,16 L76,16 A16,16 0 0 1 92,32 L92,76 A16,16 0 0 1 76,92 L32,92 A16,16 0 0 1 16,76 L16,32 A16,16 0 0 1 32,16 Z" />

    <!-- Shopping bag body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M43,49 L65,49 A5,5 0 0 1 70,53.6 L72,74 A5,5 0 0 1 67,79.4 L41,79.4 A5,5 0 0 1 36,74 L38,53.6 A5,5 0 0 1 43,49 Z" />

    <!-- Bag handle -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#B8965A"
        android:strokeWidth="3.6"
        android:strokeLineCap="round"
        android:pathData="M46,51 L46,44.5 A8,8 0 0 1 62,44.5 L62,51" />

</vector>
