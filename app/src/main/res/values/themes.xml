<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:textViewStyle">@style/Widget.App.TextView</item>
        <item name="android:editTextStyle">@style/Widget.App.EditText</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="toolbarStyle">@style/Widget.App.Toolbar</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/colorOnSurfaceVariant</item>
        <item name="colorOutline">@color/colorOutline</item>
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>
        <item name="android:windowBackground">@color/home_screen_bg</item>
        <item name="android:statusBarColor">@color/home_nav_bg</item>
        <item name="android:navigationBarColor">@color/profile_nav_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="fontFamily">@font/plus_jakarta_sans</item>
    </style>
        
    <!-- Smooth Window Animations - Only enable for the main customer app-->
    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication">
        <item name="android:windowContentTransitions">false</item>
        <item name="android:windowActivityTransitions">false</item>
    </style>

    <!-- Admin Apps get an instant-snap window transition because they render multiple Activities stacked on top of each other -->
    <style name="Theme.MyApplication.Admin" parent="Base.Theme.MyApplication">
        <item name="android:windowContentTransitions">false</item>
        <item name="android:windowActivityTransitions">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/colorBackground</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_branding</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
    </style>

</resources>
