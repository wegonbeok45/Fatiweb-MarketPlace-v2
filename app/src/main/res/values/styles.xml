<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppText.Base" parent="">
        <item name="android:fontFamily">@font/manrope</item>
        <item name="android:textColor">@color/colorOnSurface</item>
    </style>

    <style name="AppText.Title" parent="AppText.Base">
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:textSize">@dimen/text_size_title_large</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">@dimen/space_4</item>
    </style>

    <style name="AppText.Subtitle" parent="AppText.Base">
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:textSize">@dimen/text_size_subtitle</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppText.Body" parent="AppText.Base">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/colorOnSurfaceVariant</item>
        <item name="android:lineSpacingExtra">@dimen/space_2</item>
    </style>

    <style name="AppText.Caption" parent="AppText.Base">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/colorOnSurfaceVariant</item>
    </style>

    <style name="AppText.FieldLabel" parent="AppText.Body">
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppText.Overline" parent="AppText.Caption">
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:textSize">@dimen/text_size_overline</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="AppText.SectionLabel" parent="AppText.Caption">
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="AppButton.Base" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textSize">@dimen/text_size_button</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:includeFontPadding">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/manrope_semibold</item>
        <item name="cornerRadius">@dimen/corner_radius_medium</item>
        <item name="android:insetLeft">@dimen/space_0</item>
        <item name="android:insetRight">@dimen/space_0</item>
        <item name="android:insetTop">@dimen/space_0</item>
        <item name="android:insetBottom">@dimen/space_0</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="AppButton.Primary" parent="AppButton.Base">
        <item name="backgroundTint">@color/ms_surface_inverse</item>
        <item name="android:textColor">@color/ms_text_inverse</item>
        <item name="strokeWidth">@dimen/space_0</item>
        <item name="elevation">@dimen/ms_elev_0</item>
        <item name="rippleColor">@color/ms_ripple_on_dark</item>
    </style>

    <style name="AppButton.Secondary" parent="AppButton.Base">
        <item name="backgroundTint">@color/ms_surface_card</item>
        <item name="android:textColor">@color/ms_text_primary</item>
        <item name="strokeColor">@color/ms_border_default</item>
        <item name="strokeWidth">@dimen/ms_stroke_hairline</item>
        <item name="rippleColor">@color/ms_ripple_on_light</item>
    </style>

    <style name="AppButton.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="rippleColor">@color/colorSecondary</item>
    </style>

    <style name="AppInput.Layout" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_height">@dimen/ms_input_height</item>
        <item name="cardBackgroundColor">@color/ms_surface_card</item>
        <item name="cardCornerRadius">@dimen/ms_radius_md</item>
        <item name="cardElevation">@dimen/ms_elev_0</item>
        <item name="strokeColor">@color/ms_border_default</item>
        <item name="strokeWidth">@dimen/ms_stroke_hairline</item>
    </style>

    <style name="AppInput.EditText" parent="">
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@null</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textColorHint">@color/colorOnSurfaceVariant</item>
        <item name="android:textSize">@dimen/text_size_input</item>
        <item name="android:paddingStart">@dimen/space_16</item>
        <item name="android:paddingEnd">@dimen/space_16</item>
    </style>

    <style name="AppInput.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/ms_surface_card</item>
        <item name="boxStrokeColor">@color/ms_border_default</item>
        <item name="boxStrokeWidth">@dimen/ms_stroke_hairline</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCornerRadiusTopStart">@dimen/ms_radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/ms_radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/ms_radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/ms_radius_md</item>
        <item name="hintTextColor">@color/ms_text_secondary</item>
        <item name="android:textColorHint">@color/ms_text_secondary</item>
        <item name="hintTextAppearance">@style/AppInput.HintText</item>
        <item name="startIconTint">@color/ms_text_tertiary</item>
        <item name="errorTextAppearance">@style/AppInput.ErrorText</item>
    </style>

    <style name="AppInput.TextInputEditText" parent="">
        <item name="android:minHeight">@dimen/ms_input_height</item>
        <item name="android:fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">@dimen/text_size_input</item>
        <item name="android:textColor">@color/ms_text_primary</item>
        <item name="android:textColorHint">@color/ms_text_secondary</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:includeFontPadding">true</item>
    </style>

    <style name="AppInput.HintText" parent="">
        <item name="android:fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/ms_text_secondary</item>
    </style>

    <style name="AppInput.ErrorText" parent="AppInput.HintText">
        <item name="android:textColor">@color/colorError</item>
    </style>

    <style name="AppCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/ms_radius_lg</item>
        <item name="cardElevation">@dimen/ms_elev_0</item>
        <item name="cardBackgroundColor">@color/ms_surface_card</item>
        <item name="strokeWidth">@dimen/ms_stroke_hairline</item>
        <item name="strokeColor">@color/ms_border_subtle</item>
        <item name="cardUseCompatPadding">false</item>
    </style>

    <style name="AppCard.ListItem" parent="AppCard">
        <item name="android:layout_height">@dimen/list_item_height</item>
        <item name="cardCornerRadius">@dimen/corner_radius_medium</item>
        <item name="cardElevation">@dimen/space_0</item>
    </style>

    <style name="AppCard.IconContainer" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/corner_radius_medium</item>
        <item name="cardElevation">@dimen/space_0</item>
        <item name="cardBackgroundColor">@color/colorSurfaceVariant</item>
        <item name="strokeWidth">@dimen/space_0</item>
    </style>

    <style name="AppIndicator.Active" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorPrimary</item>
        <item name="cardCornerRadius">@dimen/space_4</item>
        <item name="cardElevation">@dimen/space_0</item>
    </style>

    <style name="AppIndicator.Inactive" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorOutline</item>
        <item name="cardCornerRadius">@dimen/space_4</item>
        <item name="cardElevation">@dimen/space_0</item>
    </style>

