rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function adminClaim() {
      return signedIn() &&
        (request.auth.token.admin == true || request.auth.token.role == 'admin');
    }

    // Role checks use JWT custom claims only — no cross-document reads.
    // The syncUserRoleClaims Cloud Function keeps claims in sync with the
    // users/{uid}.role field, so any admin action that changes a user's role
    // will also update the claim within seconds.
    function isAdmin() {
      return adminClaim();
    }

    function vendeurClaim() {
      return signedIn() && request.auth.token.role == 'vendeur';
    }

    function isVendeur() {
      return vendeurClaim();
    }

    function isProductOwner() {
      return signedIn() &&
        resource.data.sellerId is string &&
        resource.data.sellerId == request.auth.uid;
    }

    function createsOwnProduct() {
      return signedIn() &&
        request.resource.data.sellerId is string &&
        request.resource.data.sellerId == request.auth.uid;
    }

    function keepsOwnProductOwner() {
      return signedIn() &&
        resource.data.sellerId is string &&
        resource.data.sellerId == request.auth.uid &&
        request.resource.data.sellerId == resource.data.sellerId;
    }

    function allowedVendeurProductCreateKeys() {
      return [
        'id', 'title', 'subtitle', 'description', 'bullets', 'tags',
        'category', 'categoryIds', 'categoryLeafId', 'origin', 'price', 'priceMinor', 'currency',
        'stock', 'isBio', 'discountPercent', 'imageUrl', 'imageUrls',
        'isActive', 'status', 'searchKeywords',
        'rating', 'ratingAvg', 'reviewsCount', 'ratingCount',
        'sellerId', 'sellerName', 'sellerAvatarUrl', 'sellerProfileUpdatedAt',
        'sellerVerifiedAt', 'sellerMemberSince', 'sellerTotalSold', 'sellerRating', 'sellerRatingCount',
        'schemaVersion', 'createdAt', 'updatedAt',
        // Category-based attributes & variants (additive; optional for legacy docs).
        'productType', 'attributes', 'colorOptions', 'sizeOptions', 'variants'
      ];
    }

    function allowedVendeurProductUpdateKeys() {
      return [
        'title', 'subtitle', 'description', 'bullets', 'tags',
        'category', 'categoryIds', 'categoryLeafId', 'origin', 'price', 'priceMinor', 'stock', 'isBio',
        'discountPercent', 'imageUrl', 'imageUrls', 'updatedAt',
        // Category-based attributes & variants (additive; optional for legacy docs).
        'productType', 'attributes', 'colorOptions', 'sizeOptions', 'variants'
      ];
    }

    // Optional variant/attribute payloads. Loose, bounded checks only — the
    // adminUpsertProduct callable (admin SDK) is the authoritative sanitizer;
    // these rules just bound the DEBUG direct-write fallback so it can't be
    // abused to store oversized arrays/maps.
    function variantPayloadIsSafe() {
      return (
        !('productType' in request.resource.data) ||
        (request.resource.data.productType is string && request.resource.data.productType.size() <= 40)
      ) && (
        !('attributes' in request.resource.data) ||
        request.resource.data.attributes is map
      ) && (
        !('colorOptions' in request.resource.data) ||
        (request.resource.data.colorOptions is list && request.resource.data.colorOptions.size() <= 20)
      ) && (
        !('sizeOptions' in request.resource.data) ||
        (request.resource.data.sizeOptions is list && request.resource.data.sizeOptions.size() <= 30)
      ) && (
        !('variants' in request.resource.data) ||
        (request.resource.data.variants is list && request.resource.data.variants.size() <= 200)
      );
    }

    function vendeurProductFieldsSafe() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedVendeurProductUpdateKeys());
    }

    function validProductStatus(status) {
      return ['draft', 'published', 'archived'].hasAny([status]);
    }

    function httpsImageUrlIsSafe(url) {
      return url is string &&
        url.size() >= 12 &&
        url.size() <= 2048 &&
        url.matches('https://.*');
    }

    function imageUrlListIsSafe(urls) {
      return urls is list &&
        urls.size() > 0 &&
        urls.size() <= 5 &&
        (urls.size() < 1 || httpsImageUrlIsSafe(urls[0])) &&
        (urls.size() < 2 || httpsImageUrlIsSafe(urls[1])) &&
        (urls.size() < 3 || httpsImageUrlIsSafe(urls[2])) &&
        (urls.size() < 4 || httpsImageUrlIsSafe(urls[3])) &&
        (urls.size() < 5 || httpsImageUrlIsSafe(urls[4]));
    }

    function optionalStringListIsSafe(values, maxItems, maxLength) {
      return values is list && (
        values.size() <= maxItems &&
        (values.size() < 1 || (values[0] is string && values[0].size() <= maxLength)) &&
        (values.size() < 2 || (values[1] is string && values[1].size() <= maxLength)) &&
        (values.size() < 3 || (values[2] is string && values[2].size() <= maxLength)) &&
        (values.size() < 4 || (values[3] is string && values[3].size() <= maxLength)) &&
        (values.size() < 5 || (values[4] is string && values[4].size() <= maxLength)) &&
        (values.size() < 6 || (values[5] is string && values[5].size() <= maxLength)) &&
        (values.size() < 7 || (values[6] is string && values[6].size() <= maxLength)) &&
        (values.size() < 8 || (values[7] is string && values[7].size() <= maxLength)) &&
        (values.size() < 9 || (values[8] is string && values[8].size() <= maxLength)) &&
        (values.size() < 10 || (values[9] is string && values[9].size() <= maxLength))
      );
    }

    function sellerProductDocumentIsSafe(productId) {
      return request.resource.data.id == productId &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 3 &&
        request.resource.data.title.size() <= 120 &&
        request.resource.data.subtitle is string &&
        request.resource.data.subtitle.size() <= 180 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() >= 12 &&
        request.resource.data.description.size() <= 5000 &&
        request.resource.data.category is string &&
        request.resource.data.category.size() >= 2 &&
        request.resource.data.category.size() <= 80 &&
        optionalStringListIsSafe(request.resource.data.categoryIds, 5, 80) &&
        request.resource.data.categoryIds.size() > 0 &&
        request.resource.data.categoryLeafId is string &&
        request.resource.data.categoryLeafId.size() >= 2 &&
        request.resource.data.categoryLeafId.size() <= 80 &&
        request.resource.data.origin is string &&
        request.resource.data.origin.size() >= 2 &&
        request.resource.data.origin.size() <= 80 &&
        request.resource.data.price is number &&
        request.resource.data.price > 0 &&
        request.resource.data.price <= 100000 &&
        request.resource.data.priceMinor is int &&
        request.resource.data.priceMinor > 0 &&
        request.resource.data.priceMinor <= 100000000 &&
        request.resource.data.stock is int &&
        request.resource.data.stock >= 0 &&
        request.resource.data.stock <= 100000 &&
        (
          !('discountPercent' in request.resource.data) ||
          (
            request.resource.data.discountPercent is int &&
            request.resource.data.discountPercent >= 0 &&
            request.resource.data.discountPercent <= 90
          )
        ) &&
        request.resource.data.isBio is bool &&
        request.resource.data.isActive is bool &&
        validProductStatus(request.resource.data.status) &&
        httpsImageUrlIsSafe(request.resource.data.imageUrl) &&
        imageUrlListIsSafe(request.resource.data.imageUrls) &&
        optionalStringListIsSafe(request.resource.data.tags, 10, 40) &&
        optionalStringListIsSafe(request.resource.data.bullets, 10, 180) &&
        optionalStringListIsSafe(request.resource.data.searchKeywords, 80, 80) &&
        variantPayloadIsSafe();
    }

    function vendeurProductCreateIsSafe(productId) {
      return createsOwnProduct() &&
        request.resource.data.keys().hasOnly(allowedVendeurProductCreateKeys()) &&
        sellerProductDocumentIsSafe(productId);
    }

    function vendeurProductUpdateIsSafe(productId) {
      return keepsOwnProductOwner() &&
        vendeurProductFieldsSafe() &&
        sellerProductDocumentIsSafe(productId);
    }

    function allowedUserProfileKeys() {
      return [
        'uid',
        'name',
        'displayName',
        'email',
        'phone',
        'isPhoneAccount',
        'role',
        'status',
        'avatarUrl',
        'avatar',
        'photoUrl',
        'location',
        'notificationPreferences',
        'vendorStatus',
        'vendorApplicationSubmittedAt',
        'vendorApprovedAt',
        'vendorSuspendedReason',
        'shopName',
        'shopBio',
        'shopBannerUrl',
        'shopLogoUrl',
        'shopOperatingHours',
        'shippingFeeDt',
        'deliveryZones',
        'sellerAccessGrantedAt',
        'sellerAccessGrantedBy',
        'sellerAccessRevokedAt',
        'sellerAccessRevokedBy',
        'schemaVersion',
        'createdAt',
        'updatedAt'
      ];
    }

    function notificationPreferencesAreSafe() {
      return !('notificationPreferences' in request.resource.data) || (
        request.resource.data.notificationPreferences is map &&
        request.resource.data.notificationPreferences.keys()
          .hasOnly(['orderUpdates', 'promotions', 'announcements', 'pushEnabled']) &&
        request.resource.data.notificationPreferences.orderUpdates is bool &&
        request.resource.data.notificationPreferences.promotions is bool &&
        request.resource.data.notificationPreferences.announcements is bool &&
        request.resource.data.notificationPreferences.pushEnabled is bool
      );
    }

    function locationIsSafe() {
      return !('location' in request.resource.data) || (
        request.resource.data.location is map &&
        request.resource.data.location.keys().hasOnly([
          'latitude', 'longitude', 'address', 'city', 'source', 'updatedAt'
        ]) &&
        (!('latitude' in request.resource.data.location) || request.resource.data.location.latitude is number) &&
        (!('longitude' in request.resource.data.location) || request.resource.data.location.longitude is number) &&
        request.resource.data.location.address is string &&
        request.resource.data.location.address.size() <= 240 &&
        request.resource.data.location.city is string &&
        request.resource.data.location.city.size() <= 120 &&
        ['gps', 'manual'].hasAny([request.resource.data.location.source]) &&
        request.resource.data.location.updatedAt is number
      );
    }

    function userVendorFieldsAreSafe() {
      return (
        !('vendorStatus' in request.resource.data) ||
        ['pending', 'approved', 'suspended', 'rejected']
          .hasAny([request.resource.data.vendorStatus])
      ) &&
      (!('shopName' in request.resource.data) || (
        request.resource.data.shopName is string &&
        request.resource.data.shopName.size() <= 80
      )) &&
      (!('shopBio' in request.resource.data) || (
        request.resource.data.shopBio is string &&
        request.resource.data.shopBio.size() <= 500
      )) &&
      (!('shopLogoUrl' in request.resource.data) || (
        request.resource.data.shopLogoUrl is string &&
        request.resource.data.shopLogoUrl.size() <= 2048
      )) &&
      (!('shopBannerUrl' in request.resource.data) || (
        request.resource.data.shopBannerUrl is string &&
        request.resource.data.shopBannerUrl.size() <= 2048
      )) &&
      (!('shopOperatingHours' in request.resource.data) || (
        request.resource.data.shopOperatingHours is string &&
        request.resource.data.shopOperatingHours.size() <= 240
      )) &&
      (!('shippingFeeDt' in request.resource.data) || (
        request.resource.data.shippingFeeDt is number &&
        request.resource.data.shippingFeeDt >= 0 &&
        request.resource.data.shippingFeeDt <= 500
      )) &&
      (!('deliveryZones' in request.resource.data) ||
        optionalStringListIsSafe(request.resource.data.deliveryZones, 10, 80)
      );
    }

    function ownerVendorApplicationSubmitIsSafe() {
      return request.resource.data.role == 'client' &&
        request.resource.data.vendorStatus == 'pending' &&
        request.resource.data.vendorApplicationSubmittedAt == request.time &&
        request.resource.data.shopName is string &&
        request.resource.data.shopName.size() >= 2 &&
        request.resource.data.shopName.size() <= 80 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 8 &&
        request.resource.data.phone.size() <= 24;
    }

    function ownerVendorCreateIsSafe() {
      return userVendorFieldsAreSafe() &&
        (
          !('vendorStatus' in request.resource.data) ||
          ownerVendorApplicationSubmitIsSafe()
        );
    }

    function ownerVendorUpdateIsSafe() {
      return userVendorFieldsAreSafe() &&
        !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'vendorApprovedAt',
          'vendorSuspendedReason',
          'sellerAccessGrantedAt',
          'sellerAccessGrantedBy',
          'sellerAccessRevokedAt',
          'sellerAccessRevokedBy'
        ]) &&
        (
          !request.resource.data.diff(resource.data).changedKeys()
            .hasAny(['vendorStatus', 'vendorApplicationSubmittedAt']) ||
          ownerVendorApplicationSubmitIsSafe()
        );
    }

    function ownerProfileCreateRoleIsSafe() {
      return request.resource.data.role == 'client' ||
        (
          request.auth.token.role == 'vendeur' &&
          request.resource.data.role == 'vendeur'
        ) ||
        (
          (request.auth.token.admin == true || request.auth.token.role == 'admin') &&
          request.resource.data.role == 'admin'
        );
    }

    function ownerProfileCreateIsSafe(userId) {
      return request.resource.data.keys().hasOnly(allowedUserProfileKeys()) &&
        request.resource.data.uid == userId &&
        ownerProfileCreateRoleIsSafe() &&
        notificationPreferencesAreSafe() &&
        locationIsSafe() &&
        ownerVendorCreateIsSafe() &&
        (
          !('status' in request.resource.data) ||
          request.resource.data.status == 'active'
        );
    }

    function ownerProfileUpdateIsSafe(userId) {
      return request.resource.data.keys().hasOnly(allowedUserProfileKeys()) &&
        request.resource.data.uid == userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.createdAt == resource.data.createdAt &&
        !request.resource.data.diff(resource.data).changedKeys()
          .hasAny(['uid', 'role', 'createdAt', 'status']) &&
        notificationPreferencesAreSafe() &&
        locationIsSafe() &&
        ownerVendorUpdateIsSafe();
    }

    function ownerProfileTouchIsSafe() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['updatedAt']) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status;
    }

    function onlyReadStateChanged() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['readAt', 'updatedAt']);
    }

    function validOrderStatus(status) {
      return [
        'pending',
        'confirmed',
        'preparing',
        'shipped',
        'delivered',
        'cancelled'
      ].hasAny([status]);
    }

    function adminOrderUpdateIsSafe() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(['status', 'trackingEvents', 'statusTimeline', 'updatedAt', 'schemaVersion']) &&
        validOrderStatus(request.resource.data.status);
    }

    function vendeurOrderReadAllowed() {
      return isVendeur() &&
        resource.data.sellerIds is list &&
        request.auth.uid in resource.data.sellerIds;
    }

    function publicAnnouncementIsReadable() {
      return signedIn() &&
        resource.data.type == 'announcement' &&
        resource.data.title is string &&
        resource.data.message is string &&
        (
          resource.data.audience == 'all' ||
          resource.data.audience == 'clients' ||
          (resource.data.audience == 'vendeurs' && isVendeur())
        );
    }

    function cartItemIsSafe(item) {
      return item is map &&
        item.keys().hasOnly([
          'productId',
          'nameSnapshot',
          'thumbnailUrl',
          'priceSnapshot',
          'priceSnapshotMinor',
          'quantity',
          'addedAt'
        ]) &&
        item.productId is string &&
        item.productId.size() > 0 &&
        item.quantity is int &&
        item.quantity > 0 &&
        item.quantity <= 99;
    }

    function cartWriteIsSafe(userId, cartId) {
      let items = request.resource.data.items;
      return isOwner(userId) &&
        cartId == 'active' &&
        request.resource.data.keys().hasOnly(['items', 'updatedAt', 'schemaVersion']) &&
        items is list &&
        items.size() <= 20 &&
        (items.size() < 1 || cartItemIsSafe(items[0])) &&
        (items.size() < 2 || cartItemIsSafe(items[1])) &&
        (items.size() < 3 || cartItemIsSafe(items[2])) &&
        (items.size() < 4 || cartItemIsSafe(items[3])) &&
        (items.size() < 5 || cartItemIsSafe(items[4])) &&
        (items.size() < 6 || cartItemIsSafe(items[5])) &&
        (items.size() < 7 || cartItemIsSafe(items[6])) &&
        (items.size() < 8 || cartItemIsSafe(items[7])) &&
        (items.size() < 9 || cartItemIsSafe(items[8])) &&
        (items.size() < 10 || cartItemIsSafe(items[9])) &&
        (items.size() < 11 || cartItemIsSafe(items[10])) &&
        (items.size() < 12 || cartItemIsSafe(items[11])) &&
        (items.size() < 13 || cartItemIsSafe(items[12])) &&
        (items.size() < 14 || cartItemIsSafe(items[13])) &&
        (items.size() < 15 || cartItemIsSafe(items[14])) &&
        (items.size() < 16 || cartItemIsSafe(items[15])) &&
        (items.size() < 17 || cartItemIsSafe(items[16])) &&
        (items.size() < 18 || cartItemIsSafe(items[17])) &&
        (items.size() < 19 || cartItemIsSafe(items[18])) &&
        (items.size() < 20 || cartItemIsSafe(items[19]));
    }

    function isConversationParticipant(conversationId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
        get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
          .hasAny([request.auth.uid]);
    }

    function conversationReportCreateIsSafe() {
      return request.resource.data.keys().hasOnly([
        'id', 'reporterId', 'messageId', 'reason', 'status', 'createdAt'
      ]) &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() <= 500 &&
        request.resource.data.status == 'open';
    }

    function typingWriteIsSafe(userId) {
      return request.auth.uid == userId &&
        request.resource.data.keys().hasOnly(['uid', 'isTyping', 'updatedAt']) &&
        request.resource.data.uid == userId &&
        request.resource.data.isTyping is bool;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || (isOwner(userId) && ownerProfileCreateIsSafe(userId));
      allow update: if isAdmin() ||
        (isOwner(userId) && (ownerProfileUpdateIsSafe(userId) || ownerProfileTouchIsSafe()));
      allow delete: if isAdmin();

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /cart/{cartId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isAdmin() || cartWriteIsSafe(userId, cartId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /notification_reads/{notificationId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /blockedUsers/{blockedUserId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /fcmTokens/{tokenId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /inbox/{notificationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, delete: if isAdmin();
        allow update: if isOwner(userId) && onlyReadStateChanged();
      }

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin() || vendeurOrderReadAllowed();
        allow create: if false;
        allow update: if (isAdmin() || vendeurOrderReadAllowed()) && adminOrderUpdateIsSafe();
        allow delete: if false;
      }

      match /assistant_threads/{threadId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false;

        match /messages/{messageId} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if false;
        }
      }
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid) || vendeurOrderReadAllowed();
      allow create: if false;
      allow update: if (isAdmin() || vendeurOrderReadAllowed()) && adminOrderUpdateIsSafe();
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if isAdmin() || isProductOwner() || (
        resource.data.isActive == true &&
        resource.data.status == 'published'
      );
      allow create: if isAdmin() || (isVendeur() && vendeurProductCreateIsSafe(productId));
      allow update: if isAdmin() || (isVendeur() && vendeurProductUpdateIsSafe(productId));
      allow delete: if isAdmin() || (isVendeur() && isProductOwner());

      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /marketplaceCategories/{categoryId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /categoryConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow read: if isAdmin() || isConversationParticipant(conversationId);
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isAdmin() || isConversationParticipant(conversationId);
        allow write: if false;
      }

      match /typing/{userId} {
        allow read: if isAdmin() || isConversationParticipant(conversationId);
        allow create, update: if isConversationParticipant(conversationId) && typingWriteIsSafe(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /reports/{reportId} {
        allow read: if isAdmin();
        allow create: if isConversationParticipant(conversationId) && conversationReportCreateIsSafe();
        allow update, delete: if isAdmin();
      }
    }

    match /config/commerce {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read, write: if isAdmin();
    }

    match /admin_stats/{statId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /in_app_notifications/{notificationId} {
      allow read: if isAdmin() || publicAnnouncementIsReadable();
      allow create, update, delete: if isAdmin();
    }

    match /carts/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    match /notifications/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    match /assistant_rate_limits/{docId} {
      allow read, write: if false;
    }

    match /conversation_rate_limits/{docId} {
      allow read, write: if false;
    }
  }
}
